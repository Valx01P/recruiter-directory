# Copy to .env.local and fill in. .env.local is gitignored; this example is committed.
# Find these in Supabase Dashboard → Project Settings → API / Database.

# Browser-safe keys (sent to the client)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx

# Legacy anon JWT (optional, for older supabase-js paths)
SUPABASE_ANON_KEY=eyJ...your-anon-jwt...

# Server-only secrets (NEVER expose to the browser)
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-jwt...

# Postgres connection for schema DDL (scripts/setup-db.ts).
# Prefer the Session-pooler URI (IPv4) — the direct db.<ref> host is IPv6-only.
# Dashboard → Project Settings → Database → Connection string → Session mode.
SUPABASE_DB_URL=postgresql://postgres.YOUR-PROJECT-REF:YOUR-DB-PASSWORD@aws-1-YOUR-REGION.pooler.supabase.com:5432/postgres

# Semantic search — embedding is handled by the gte-server service (gte-small, 384d; see ../gte-server).
# Browser + indexing script both call this URL.
#   local dev:  http://localhost:8787
#   production: set in Vercel to your Render/Railway/Fly URL → https://<gte-server>.onrender.com
#   (NEXT_PUBLIC_* is inlined at build time, so redeploy the frontend after changing it)
NEXT_PUBLIC_GTE_SERVER_URL=http://localhost:8787

# Google OAuth client ID (public) for the "Sign in with Google" button.
# Same Client ID whose origins you configured in Google Cloud Console.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
# Used only by scripts/setup-db.ts to size the pgvector column (must match the server model dim).
EMBEDDING_DIM=384
