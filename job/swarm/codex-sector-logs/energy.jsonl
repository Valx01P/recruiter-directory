ed: false,\n      messaged: false,\n      responded: false,\n      date_contacted: '',\n      notes: 'Public LinkedIn jobs list her as Emerson Talent Acquisition Partner for Power & Water Solutions and technical/commercial roles; profile recommendations cite Emerson TA work.'\n    },\n    {\n      name: 'Anna Niichel',\n      title: 'Talent Acquisition Partner',\n      linkedin_url: 'https://www.linkedin.com/in/anna-niichel',\n      email: '',\n      location: 'United States',\n      focus_area: 'Talent Acquisition / Customer Success, Marketing and Automation Roles',\n      connected: false,\n      messaged: false,\n      responded: false,\n      date_contacted: '',\n      notes: 'Public Emerson job posts list Anna as a Talent Acquisition Partner recruiting for customer success and global product marketing roles.'\n    }\n  ],\n  C1175: [\n    {\n      name: 'Candance Goins',\n      title: 'Talent Acquisition / Early Talent and Inclusion Recruiting',\n      linkedin_url: 'https://www.linkedin.com/in/candance-goins',\n      email: '',\n      location: 'Raleigh, NC',\n      focus_area: 'Early Talent Leadership Summit / STEM and Inclusion Recruiting',\n      connected: false,\n      messaged: false,\n      responded: false,\n      date_contacted: '',\n      notes: 'Public LinkedIn profile shows Eaton affiliation; Eaton LinkedIn Life and early-talent summit posts identify her with attracting talent and student leadership outreach.'\n    },\n    {\n      name: 'Nina Erney',\n      title: 'IT Talent / Hiring Contact',\n      linkedin_url: 'https://www.linkedin.com/in/ninadepieroerney',\n      email: '',\n      location: 'United States',\n      focus_area: 'IT Hiring / Data Management / Intern and Early Talent Programs',\n      connected: false,\n      messaged: false,\n      responded: false,\n      date_contacted: '',\n      notes: 'Public LinkedIn profile shows Eaton affiliation; activity highlights IT Data Management hiring and thanks IT summer interns, and early-career recruiter Nick Holbert references her in Eaton hiring process.'\n    }\n  ],\n  C1176: [\n    {\n      name: 'Valencia Griffin',\n      title: 'Talent Acquisition Specialist',\n      linkedin_url: 'https://www.linkedin.com/in/valencia-griffin',\n      email: '',\n      location: 'Cleveland, OH',\n      focus_area: 'Corporate Talent Acquisition / Technical and Operations Hiring',\n      connected: false,\n      messaged: false,\n      responded: false,\n      date_contacted: '',\n      notes: 'Public LinkedIn profile identifies her as a Parker Hannifin Talent Acquisition Specialist in Cleveland.'\n    },\n    {\n      name: 'Sydney Mangus',\n      title: 'Talent Acquisition Partner',\n      linkedin_url: 'https://www.linkedin.com/in/sydney-mangus-507b3218b',\n      email: '',\n      location: 'Phoenix, AZ',\n      focus_area: 'Sales and Marketing Recruiting / East Region Talent Acquisition',\n      connected: false,\n      messaged: false,\n      responded: false,\n      date_contacted: '',\n      notes: 'Public LinkedIn profile shows Parker Hannifin affiliation and activity announcing a Talent Acquisition Partner role supporting sales and marketing for the East Region.'\n    }\n  ]\n};\n\nlet added = 0;\nfor (const [id, people] of Object.entries(additions)) {\n  const company = data.companies.find(c => c.id === id);\n  if (\"'!company) throw new Error(`Company not found: ${id}`);\n  if (!Array.isArray(company.recruiters)) company.recruiters = [];\n  const seenNames = new Set(company.recruiters.map(r => String(r.name || '\"'').trim().toLowerCase()).filter(Boolean));\n  const seenUrls = new Set(company.recruiters.map(r => String(r.linkedin_url || '').trim().toLowerCase()).filter(Boolean));\n  for (const person of people) {\n    if (company.recruiters.length >= 10) break;\n    const nameKey = person.name.trim().toLowerCase();\n    const urlKey = person.linkedin_url.trim().toLowerCase();\n    if (seenNames.has(nameKey) || (urlKey && seenUrls.has(urlKey))) continue;\n    company.recruiters.push(person);\n    seenNames.add(nameKey);\n    if (urlKey) seenUrls.add(urlKey);\n    added++;\n  }\n}\n\nfs.writeFileSync(path, JSON.stringify(data, null, 2) + '\\\\n');\nconsole.log(\"'`Added ${added} recruiter/contact entries to ${Object.keys(additions).length} companies.`);\nNODE'","aggregated_output":"","exit_code":null,"status":"in_progress"}}
