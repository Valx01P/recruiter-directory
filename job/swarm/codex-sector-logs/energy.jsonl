{"type":"item.started","item":{"id":"item_32","type":"command_execution","command":"/bin/zsh -lc \"node <<'NODE'\nconst fs = require('fs');\nconst path = 'job/sectors/recruiter-energy.json';\nconst data = JSON.parse(fs.readFileSync(path, 'utf8'));\n\nfunction contact(name, title, linkedin_url, location, focus_area, notes) {\n  return {\n    name,\n    title,\n    linkedin_url,\n    email: '',\n    location,\n    focus_area,\n    connected: false,\n    messaged: false,\n    responded: false,\n    date_contacted: '',\n    notes\n  };\n}\n\nconst updates = {\n  C1210: {\n    description: 'Ford designs, manufactures, and services Ford and Lincoln vehicles, including electric, hybrid, connected commercial fleet, and software-defined mobility products.',\n    hq_location: 'Dearborn, MI',\n    careers_url: 'https://www.ford.com/careers/',\n    recruiters: [\n      contact('Laura Tedford', 'Talent Acquisition and Recruiting Leader', 'https://www.linkedin.com/in/ljtedford', 'Greater Boston / Remote', 'Talent Acquisition / Recruiting Leadership', 'Public LinkedIn profile shows Ford Motor Company affiliation and talent acquisition/recruiting leadership; recent activity references Ford hiring and employee programs.'),\n      contact('Gregary Coleman', 'Senior Recruiter', 'https://www.linkedin.com/in/gregary-coleman-9772122a', 'Dearborn, MI', 'IT / Professional Services / Product and Corporate Recruiting', 'Public LinkedIn profile shows Ford Motor Company affiliation in Dearborn and senior recruiter/corporate talent acquisition background.'),\n      contact('Conor Boland', 'Strategic Talent Acquisition Leader', 'https://www.linkedin.com/in/conor-boland-8064a733', 'Greater Tampa Bay Area', 'Strategic Talent Acquisition / HR Leadership Hiring', 'Public LinkedIn profile shows Ford Motor Company affiliation and strategic talent acquisition leadership, with posts referencing Ford HR leadership hiring.')\n    ]\n  },\n  C1211: {\n    description: 'Stellantis builds Chrysler, Dodge, Jeep, Ram, Fiat, and other vehicles while investing in EV platforms, software, battery systems, and North American manufacturing.',\n    hq_location: 'Auburn Hills, MI',\n    careers_url: 'https://careers.stellantis.com/',\n    recruiters: [\n      contact('Darin Judge', 'Senior Talent Acquisition Partner', 'https://www.linkedin.com/in/darinjudge1', 'Rochester, MI', 'Corporate / Financial Services Talent Acquisition', 'Public LinkedIn profile shows Senior Talent Acquisition Partner at Stellantis Financial Services US in Auburn Hills; useful for Stellantis US corporate and finance roles.'),\n      contact('Katie Wise', 'Director, Talent Acquisition', 'https://www.linkedin.com/in/katie-wise-8b1329252', 'Grand Blanc, MI', 'Talent Acquisition Leadership / Internal Recruiting', 'Public LinkedIn profile and Stellantis Financial Services posts show talent acquisition leadership and operations work in Auburn Hills.')\n    ]\n  },\n  C1212: {\n    description: 'Toyota North America manufactures and sells Toyota and Lexus vehicles while developing electrified powertrains, connected mobility software, and U.S. manufacturing operations.',\n    hq_location: 'Plano, TX',\n    careers_url: 'https://www.toyota.com/careers/',\n    recruiters: [\n      contact('Vaishali A.', 'Senior Technical Recruiter / Senior Strategic Talent Acquisition Partner', 'https://www.linkedin.com/in/vambalia', 'Dallas-Fort Worth Metroplex', 'Technical Recruiting / Strategic Talent Acquisition', 'Public LinkedIn profile shows Toyota North America affiliation in Plano and about text as a senior technical recruiter and strategic talent acquisition partner.'),\n      contact('Divya pradha Nagarajan', 'Full Cycle Technical Recruiter', 'https://www.linkedin.com/in/divyapradha-nagarajan', 'McKinney, TX', 'Technical Recruiting / Software and Enterprise Hiring', 'Public LinkedIn profile shows Toyota North America affiliation in Plano and full-cycle technical recruiting background, with current Toyota employee activity.'),\n      contact('Marisa Romero', 'Recruiter, College Programs', 'https://www.linkedin.com/in/mmarisar', 'Dallas, TX', 'College Programs / Internship Recruiting', 'Public LinkedIn profile shows Toyota North America affiliation; student posts identify Marisa Romero as a Toyota recruiter for intern and college-program opportunities.')\n    ]\n  },\n  C1213: {\n    description: 'Honda builds Honda and Acura vehicles, power equipment, and mobility products, with U.S. engineering and manufacturing tied to hybrid, EV, and fuel-cell programs.',\n    hq_location: 'Torrance, CA',\n    careers_url: 'https://honda.wd1.myworkdayjobs.com/Honda',\n    recruiters: [\n      contact('Rachana H.', 'Talent Acquisition Specialist', 'https://www.linkedin.com/in/rachanahegde', 'Columbus, OH', 'Talent Acquisition / Technical and Corporate Recruiting', 'Public LinkedIn profile shows American Honda Motor Company affiliation in Columbus and talent acquisition specialist background with recruiting certifications.'),\n      contact('Kat Willwerth', 'Technical Recruiter and HR Operations Specialist', 'https://www.linkedin.com/in/katherinewitkowski', 'Florence, SC', 'Technical Recruiting / HR Operations / Co-op Support', 'Public LinkedIn profile shows Honda affiliation; recommendation describes her talent acquisition support for co-op and intern onboarding at Honda.')\n    ]\n  },\n  C1214: {\n    description: 'Nissan manufactures and sells Nissan and INFINITI vehicles in the U.S., including EVs and connected vehicle platforms across manufacturing, engineering, and sales operations.',\n    hq_location: 'Franklin, TN',\n    careers_url: 'https://www.nissanmotor.jobs/',\n    recruiters: [\n      contact('Morgan Mattox', 'Talent Acquisition / Early Career Programs Leader', 'https://www.linkedin.com/in/morgan-m-mattox', 'Franklin, TN', 'Early Career Hiring / Graduate Development / Talent Programs', 'Public LinkedIn profile shows Nissan Motor Corporation affiliation; recommendations cite executive recruiting, early-career hiring, graduate development, and intern engagement.'),\n      contact('Charla H.', 'Talent Acquisition Recruiter', 'https://www.linkedin.com/in/charla-h-2bb63b28', 'Nashville, TN', 'Talent Acquisition / Manufacturing and Corporate Recruiting', 'Public LinkedIn profile states Talent Acquisition Recruiter at Nissan Motor Corporation and includes Nissan employee activity.'),\n      contact('Gavin Mayo', 'Talent Acquisition Consultant', 'https://www.linkedin.com/in/gavin-mayo-b91406b', 'Smyrna, TN', 'Salaried Hiring / Recruiting Team Leadership', 'Public LinkedIn profile shows experienced Talent Acquisition Consultant at Nissan and a post seeking a recruiter for his salaried hiring team.')\n    ]\n  },\n  C1215: {\n    description: 'Hyundai sells and increasingly manufactures vehicles in the U.S., spanning EVs, hydrogen, connected car, robotics, and smart manufacturing initiatives.',\n    hq_location: 'Fountain Valley, CA',\n    careers_url: 'https://www.hyundaicareers.com/',\n    recruiters: [\n      contact('Jean Yim', 'Talent Acquisition Manager', 'https://www.linkedin.com/in/jean-yim-6970971', 'Irvine, CA', 'Technical Talent / AI, Robotics, Autonomous Driving, SW/IT, Battery and Hydrogen', 'Public LinkedIn profile shows Hyundai Motor America talent acquisition leadership and recent support for Hyundai Motor Group Global Tech Talent Recruitment 2026.'),\n      contact('Tiffani Doty', 'Talent Acquisition Manager', '', 'Irvine, CA / Frisco, TX', 'Talent Acquisition Leadership / Hyundai Capital America', 'Hyundai Capital America public Meet the Recruiter post says Tiffani actively recruits and leads the talent acquisition team supporting Hyundai, Genesis, and Kia finance operations.'),\n      contact('Jenna Smidt', 'Talent Acquisition Manager', 'https://www.linkedin.com/in/jenna-smidt', 'Irvine, CA', 'Corporate Recruiting / Cybersecurity and Finance Roles', 'Public LinkedIn profile and Hyundai Capital America job posts identify Jenna as a Talent Acquisition Manager and direct job poster for corporate, cybersecurity, and finance roles.')\n    ]\n  },\n  C1216: {\n    description: 'BMW sells, engineers, and supports BMW, MINI, and Rolls-Royce vehicles in the U.S., with manufacturing, software, finance, and electrified mobility operations.',\n    hq_location: 'Woodcliff Lake, NJ',\n    careers_url: 'https://www.bmwgroup.jobs/us/en.html',\n    recruiters: [\n      contact('Diana Irwin', 'Talent Acquisition / Strategy / Partnerships / Student Programs', 'https://www.linkedin.com/in/diana-irwin-87175b13', 'Columbus, OH', 'Talent Acquisition / Student Programs / Technical and Corporate Hiring', 'Public LinkedIn profile shows BMW Group US affiliation; BMW job postings list Diana as the job poster for software, security, and student-program-related hiring.')\n    ]\n  },\n  C1217: {\n    description: 'Mercedes-Benz handles U.S. vehicle sales, service, manufacturing, and R&D activity, including EV, connected vehicle, and driver-assistance technology work.',\n    hq_location: 'Atlanta, GA',\n    careers_url: 'https://www.mbusa.com/en/careers',\n    recruiters: [\n      contact('Alison Casley', 'Recruiter', 'https://www.linkedin.com/in/texassouthernbell', 'Waco, TX', 'Full-Cycle Talent Acquisition / Corporate Recruiting', 'Public LinkedIn profile shows Mercedes-Benz USA affiliation and describes hands-on full-cycle talent acquisition recruiting experience.'),\n      contact('Robyn Matos', 'Senior Recruiter', 'https://www.linkedin.com/in/robynmatos', 'San Francisco Bay Area', 'Engineering Recruiting / Mercedes-Benz R&D North America', 'Public LinkedIn profile shows Mercedes-Benz Research & Development North America affiliation and senior recruiter experience, with recommendations citing engineering recruiting.')\n    ]\n  },\n  C1218: {\n    description: 'Canoo was an EV startup that developed modular electric vans and fleet vehicles for commercial and government customers before filing for Chapter 7 liquidation in 2025.',\n    hq_location: 'Defunct; formerly Torrance, CA and Justin, TX',\n    careers_url: '',\n    has_intern_program: false,\n    recruiters: [\n      contact('Tony Aquila', 'Founder, Chairman and CEO, AFV Partners; former Chairman and CEO, Canoo', '', 'Argyle, TX', 'Bankruptcy Asset Owner / Mobility Investment Contact', 'AFV Partners and bankruptcy reporting identify Tony Aquila as Canoo’s former CEO and the investor behind WHS Energy Solutions, which acquired Canoo assets; outreach value is asset/status follow-up, not active recruiting.')\n    ]\n  },\n  C1219: {\n    description: 'Fisker was an EV automaker focused on the Ocean electric SUV and asset-light vehicle programs before filing for Chapter 11 bankruptcy and liquidating assets in 2024.',\n    hq_location: 'Defunct; formerly Manhattan Beach, CA',\n    careers_url: '',\n    has_intern_program: false,\n    recruiters: [\n      contact('Henrik Fisker', 'Founder, Chairman and CEO', 'https://www.linkedin.com/in/henrikfiskerofficial', 'Los Angeles, CA', 'Founder / Bankruptcy-Era Executive Contact', 'Public company and bankruptcy coverage identify Henrik Fisker as founder, chairman, and CEO of Fisker Inc.; company is bankrupt, so this is an executive/status contact rather than active recruiting.')\n    ]\n  },\n  C1220: {\n    description: 'Polestar sells performance electric vehicles and supports North American retail, service, and customer operations for Polestar’s global EV lineup.',\n    hq_location: 'Mahwah, NJ',\n    careers_url: 'https://www.polestar.com/us/careers/',\n    recruiters: [\n      contact('Charlotte Silfversparre', 'Lead Executive Search, Employer Branding and Technical Recruiting', 'https://se.linkedin.com/in/charlotte-silfversparre-993685b', 'Sweden', 'Executive Search / Technical Recruiting / Global Polestar Hiring', 'Public LinkedIn profile shows Polestar affiliation and Lead Executive Search focus; Polestar job postings list Charlotte as recruiter for technical and product roles.')\n    ]\n  },\n  C1221: {\n    description: 'Nikola was a Phoenix-based zero-emission truck and hydrogen infrastructure company that built battery-electric and fuel-cell Class 8 trucks before its 2025 bankruptcy.',\n    hq_location: 'Phoenix, AZ',\n    careers_url: '',\n    has_intern_program: false,\n    recruiters: [\n      contact('Sau Le', 'HR Professional', 'https://www.linkedin.com/in/sau-le-7346407', 'Gilbert, AZ', 'HR Operations / Former or Bankruptcy-Era Nikola Contact', 'Public LinkedIn profile shows Nikola Motor Company affiliation and HR professional background; Nikola is in bankruptcy, so current hiring activity is uncertain.')\n    ]\n  },\n  C1222: {\n    description: 'Proterra developed electric transit buses, battery systems, and fleet charging infrastructure; its bus, battery, and energy assets were sold through bankruptcy proceedings.',\n    hq_location: 'Greer, SC / Burlingame, CA',\n    careers_url: 'https://www.proterra.com/careers/',\n    recruiters: [\n      contact('Brennen Jones', 'Technical Recruiter', 'https://www.linkedin.com/in/brennen-jones-648476b4', 'Greer, SC', 'Technical Recruiting / Electrification and Manufacturing Roles', 'Public LinkedIn profile shows current Proterra affiliation in Greer and technical recruiter background; recommendations cite Proterra recruiting and electrification-sector hiring support.')\n    ]\n  }\n};\n\nlet touched = 0;\nlet added = 0;\nfor (const company of data.companies || []) {\n  const update = updates[company.id];\n  if (\"'!update) continue;\n  touched++;\n  for (const [key, value] of Object.entries(update)) {\n    if (key === '\"'recruiters') continue;\n    company[key] = value;\n  }\n  const existing = company.recruiters || [];\n  const existingKeys = new Set(existing.map(r => \"'`${(r.name || '\"'').toLowerCase()}|\"'${(r.linkedin_url || '\"'').toLowerCase()}\"'`));\n  for (const r of update.recruiters) {\n    const key = `${r.name.toLowerCase()}|${(r.linkedin_url || '\"'').toLowerCase()}\"'`;\n    if (existingKeys.has(key)) continue;\n    existing.push(r);\n    existingKeys.add(key);\n    added++;\n  }\n  company.recruiters = existing;\n}\n\nfs.writeFileSync(path, `${JSON.stringify(data, null, 2)}'\"\\\\n\"'`);\nconsole.log(JSON.stringify({touched, added}, null, 2));\nNODE'","aggregated_output":"","exit_code":null,"status":"in_progress"}}
