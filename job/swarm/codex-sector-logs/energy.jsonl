otes: \\\"Public LinkedIn profile shows current 3M affiliation; recommendations cite leadership of talent acquisition teams supporting the US and Canada, and activity references 3M NSBE campus outreach.\\\"\n      }\n    ]\n  },\n  C1172: {\n    description: \\\"Caterpillar builds construction and mining equipment, engines, turbines, locomotives, electric power systems, and energy solutions for industrial and data-center customers.\\\",\n    recruiters: [\n      {\n        name: \\\"Kamila Smith\\\",\n        title: \\\"Talent Acquisition Manager\\\",\n        linkedin_url: \\\"https://www.linkedin.com/in/kamilasmith\\\",\n        location: \\\"Greater Chicago Area\\\",\n        focus_area: \\\"Power & Energy Talent Acquisition / Technical and Energy Hiring\\\",\n        notes: \\\"Public LinkedIn profile shows Caterpillar affiliation and talent acquisition background; recent activity reposted Caterpillar Power & Energy TA manager hiring for North America.\\\"\n      }\n    ]\n  },\n  C1173: {\n    description: \\\"Deere & Company builds agricultural, construction, and forestry equipment, pairing connected machinery, precision autonomy, and software with large-scale field operations.\\\",\n    recruiters: [\n      {\n        name: \\\"Crystal T. Jones\\\",\n        title: \\\"Talent Acquisition and Employer Brand Leader\\\",\n        linkedin_url: \\\"https://www.linkedin.com/in/crystaltjones\\\",\n        location: \\\"Greater Chicago Area\\\",\n        focus_area: \\\"Talent Acquisition / Employer Brand / Tech Recruiting\\\",\n        notes: \\\"Public LinkedIn profile shows John Deere affiliation; activity identifies her as a John Deere talent acquisition and employer brand leader discussing tech recruitment.\\\"\n      }\n    ]\n  },\n  C1174: {\n    description: \\\"Emerson provides automation, control systems, measurement devices, software, and power/water solutions used in process industries, energy infrastructure, and advanced manufacturing.\\\",\n    recruiters: [\n      {\n        name: \\\"Paul LeBeau\\\",\n        title: \\\"Talent Acquisition Manager\\\",\n        linkedin_url: \\\"https://www.linkedin.com/in/paullebeau\\\",\n        location: \\\"Houston, TX\\\",\n        focus_area: \\\"Talent Acquisition / Power & Water Solutions / Renewables Engineering Hiring\\\",\n        notes: \\\"Public LinkedIn profile shows Emerson affiliation and recruiting leadership; recent posts advertise Emerson Power & Water talent acquisition and renewables engineering roles.\\\"\n      },\n      {\n        name: \\\"Jordan Soy\\\",\n        title: \\\"Recruiter / Talent Acquisition Professional\\\",\n        linkedin_url: \\\"https://www.linkedin.com/in/jordan-soy-shrm-cp\\\",\n        location: \\\"United States\\\",\n        focus_area: \\\"Recruiting / Talent Acquisition\\\",\n        notes: \\\"Public LinkedIn profile shows Emerson affiliation, SHRM talent acquisition credential, and recommendations describing her recruiting support for Emerson hiring.\\\"\n      }\n    ]\n  },\n  C1175: {\n    description: \\\"Eaton builds intelligent power management products for electrical distribution, vehicle electrification, data centers, aerospace, and industrial energy systems.\\\",\n    recruiters: [\n      {\n        name: \\\"Nick Holbert\\\",\n        title: \\\"Early Career Recruiter\\\",\n        linkedin_url: \\\"https://www.linkedin.com/in/nick-holbert-15a45a66\\\",\n        location: \\\"Mentor, OH\\\",\n        focus_area: \\\"Early Talent Recruiting / Internships / Leadership Summit\\\",\n        notes: \\\"Public LinkedIn profile shows Eaton affiliation; activity says he accepted an Early Career Recruiter role supporting Eaton's Early Talent Recruitment Team.\\\"\n      },\n      {\n        name: \\\"Rob Kumengi\\\",\n        title: \\\"Senior Talent Acquisition Executive\\\",\n        linkedin_url: \\\"https://www.linkedin.com/in/robertkumengi\\\",\n        location: \\\"Greater Cleveland\\\",\n        focus_area: \\\"Corporate Talent Acquisition / Engineering and Early Talent Programs\\\",\n        notes: \\\"Public LinkedIn profile shows Eaton affiliation and senior TA role; posts highlight Eaton early talent programs and technical engineering hiring.\\\"\n      }\n    ]\n  },\n  C1176: {\n    description: \\\"Parker Hannifin makes motion and control technologies, including hydraulics, pneumatics, filtration, aerospace systems, and electrification components for industrial equipment.\\\",\n    recruiters: [\n      {\n        name: \\\"Kevin Mendez\\\",\n        title: \\\"Senior Talent Acquisition Partner\\\",\n        linkedin_url: \\\"https://www.linkedin.com/in/kevin-mendez\\\",\n        location: \\\"Los Angeles Metropolitan Area\\\",\n        focus_area: \\\"Talent Acquisition / Aerospace and Industrial Hiring\\\",\n        notes: \\\"Public LinkedIn profile shows Parker Hannifin affiliation; external org/profile pages identify him as a senior talent acquisition partner at Parker Hannifin.\\\"\n      },\n      {\n        name: \\\"Chloe Kephart\\\",\n        title: \\\"Talent Acquisition Partner\\\",\n        linkedin_url: \\\"https://www.linkedin.com/in/chloe-kephart-65b9131b8\\\",\n        location: \\\"Greater Seattle Area\\\",\n        focus_area: \\\"Parker Aerospace / Manufacturing and Operations Hiring\\\",\n        notes: \\\"Public LinkedIn job poster and profile identify her as Talent Acquisition Partner at Exotic Metals Forming, a Division of Parker Aerospace.\\\"\n      }\n    ]\n  },\n  C1178: {\n    description: \\\"Cummins develops engines, power generation systems, drivetrain components, batteries, fuel cells, and hydrogen technologies for commercial vehicles and industrial power.\\\",\n    recruiters: [\n      {\n        name: \\\"Dawn Mifsud\\\",\n        title: \\\"Talent and People Leader\\\",\n        linkedin_url: \\\"https://www.linkedin.com/in/dawnmifsud\\\",\n        location: \\\"Brighton, MI\\\",\n        focus_area: \\\"Talent Acquisition Leadership / North America Recruiting\\\",\n        notes: \\\"Public LinkedIn profile shows Cummins affiliation; recommendations describe her progression from recruiter to team leader and North America leader in talent acquisition.\\\"\n      },\n      {\n        name: \\\"Lindsey Shellenbarger\\\",\n        title: \\\"Associate Recruiter\\\",\n        linkedin_url: \\\"https://www.linkedin.com/in/lindsey-shellenbarger\\\",\n        location: \\\"United States\\\",\n        focus_area: \\\"Recruiting / Talent Acquisition\\\",\n        notes: \\\"Public LinkedIn profile states she is an Associate Recruiter with Cummins and previously worked in talent acquisition supporting Cummins.\\\"\n      }\n    ]\n  }\n};\nlet touched = 0;\nlet added = 0;\nfor (const company of data.companies || []) {\n  const update = updates[company.id];\n  if (\"'!update) continue;\n  touched++;\n  company.description = update.description;\n  company.recruiters = company.recruiters || [];\n  const existingNames = new Set(company.recruiters.map(r => String(r.name || \"\").trim().toLowerCase()).filter(Boolean));\n  const existingUrls = new Set(company.recruiters.map(r => String(r.linkedin_url || \"\").trim().toLowerCase()).filter(Boolean));\n  for (const rec of update.recruiters) {\n    const nameKey = String(rec.name || \"\").trim().toLowerCase();\n    const urlKey = String(rec.linkedin_url || \"\").trim().toLowerCase();\n    if ((nameKey && existingNames.has(nameKey)) || (urlKey && existingUrls.has(urlKey))) continue;\n    company.recruiters.push({\n      name: rec.name,\n      title: rec.title,\n      linkedin_url: rec.linkedin_url,\n      email: schemaDefaults.email,\n      location: rec.location,\n      focus_area: rec.focus_area,\n      connected: schemaDefaults.connected,\n      messaged: schemaDefaults.messaged,\n      responded: schemaDefaults.responded,\n      date_contacted: schemaDefaults.date_contacted,\n      notes: rec.notes\n    });\n    existingNames.add(nameKey);\n    existingUrls.add(urlKey);\n    added++;\n  }\n}\nif (touched !== Object.keys(updates).length) throw new Error(`Touched ${touched}, expected ${Object.keys(updates).length}`);\nfs.writeFileSync(path, JSON.stringify(data, null, 2) + \"'\"\\\\n\\\");\nconsole.log(JSON.stringify({ touched, added }, null, 2));\n'\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
