{"type":"item.started","item":{"id":"item_27","type":"command_execution","command":"/bin/zsh -lc \"node <<'NODE'\nconst fs = require('fs');\nconst path = 'job/sectors/recruiter-energy.json';\nconst data = JSON.parse(fs.readFileSync(path, 'utf8'));\n\nconst base = (contact) => ({\n  name: contact.name,\n  title: contact.title,\n  linkedin_url: contact.linkedin_url || '',\n  email: '',\n  location: contact.location || '',\n  focus_area: contact.focus_area,\n  connected: false,\n  messaged: false,\n  responded: false,\n  date_contacted: '',\n  notes: contact.notes\n});\n\nconst additions = {\n  C0168: [\n    base({\n      name: 'Nadine Guagliano',\n      title: 'Talent Acquisition Leader',\n      linkedin_url: 'https://www.linkedin.com/in/nadineguagliano',\n      location: 'West Palm Beach, FL',\n      focus_area: 'Talent acquisition leadership / energy internships and early-career programs',\n      notes: 'Public LinkedIn profile shows NextEra Energy affiliation and a talent acquisition leadership background; activity engages with NextEra and FPL internship announcements.'\n    })\n  ],\n  C1170: [\n    base({\n      name: 'Miranda Souders',\n      title: 'Americas Talent Acquisition Leader',\n      location: 'United States',\n      focus_area: 'Americas talent acquisition leadership / GE Vernova energy hiring',\n      notes: 'The Org GE Vernova leadership page lists Miranda as Americas Talent Acquisition Leader reporting through the chief people organization.'\n    }),\n    base({\n      name: 'Natalie Van Gramberg',\n      title: 'Senior Manager Talent Acquisition, Electrification Software NAM and LATAM',\n      linkedin_url: 'https://www.linkedin.com/in/natalievangramberg',\n      location: 'Cincinnati, OH',\n      focus_area: 'Electrification software talent acquisition / software, grid and AI-adjacent engineering hiring',\n      notes: 'Public LinkedIn profile shows GE Vernova in Ohio; The Org lists her as senior manager for Electrification Software talent acquisition across NAM and LATAM.'\n    }),\n    base({\n      name: 'Carlos Concha',\n      title: 'Senior Talent Acquisition Partner, Commercial Team',\n      linkedin_url: 'https://www.linkedin.com/in/carlos-concha-25802522',\n      location: 'Greenville-Spartanburg-Anderson, SC area',\n      focus_area: 'Commercial and engineering talent acquisition / next-generation engineering leadership programs',\n      notes: 'Public LinkedIn profile shows GE Vernova affiliation and activity describing a Senior Talent Acquisition Partner role plus engineering leadership program hiring.'\n    }),\n    base({\n      name: 'Brian Gilmore',\n      title: 'Senior Talent Acquisition Partner',\n      location: 'United States',\n      focus_area: 'Talent acquisition / recruiting for GE Vernova business roles',\n      notes: 'The Org GE Vernova talent acquisition page lists Brian as a Senior Talent Acquisition Partner with GE Vernova since July 2022.'\n    }),\n    base({\n      name: 'Caitlin Lowe',\n      title: 'Executive Recruiter',\n      location: 'United States',\n      focus_area: 'Executive recruiting / energy transition leadership hiring',\n      notes: 'The Org and public profile-index results identify Caitlin as an Executive Recruiter at GE Vernova focused on senior leaders for energy transition work.'\n    })\n  ],\n  C1171: [\n    base({\n      name: 'Nikole E. Freeman',\n      title: 'Vice President, Global Talent Acquisition, Talent and Diversity, Human Resources',\n      location: 'Maplewood, MN',\n      focus_area: 'Global talent acquisition and diversity leadership',\n      notes: 'The Org 3M leadership page lists Nikole as Vice President of Global Talent Acquisition, Talent and Diversity, and Human Resources at 3M.'\n    }),\n    base({\n      name: 'Melissa Sinn',\n      title: 'Talent Acquisition Manager',\n      location: 'Greater Minneapolis-St. Paul Area',\n      focus_area: 'Talent acquisition management / US recruiting team leadership',\n      notes: 'The Org and public profile-index results identify Melissa as a 3M Talent Acquisition Manager since 2022, with prior HR and recruiting leadership experience.'\n    })\n  ],\n  C1172: [\n    base({\n      name: 'Stacy Zeller',\n      title: 'Talent Acquisition Manager, Electrification and Energy Solutions',\n      location: 'Chicago, IL',\n      focus_area: 'Electrification, energy solutions and technical hiring',\n      notes: 'Public Caterpillar blog byline identifies Stacy as Talent Acquisition Manager for Electrification and Energy Solutions and describes her global TA team role.'\n    }),\n    base({\n      name: 'Camden M.',\n      title: 'Talent Acquisition Partner, Cat Digital',\n      location: 'Wheaton, IL',\n      focus_area: 'Cat Digital recruiting / software and digital talent acquisition',\n      notes: 'The Org and public profile-index results list Camden as a Caterpillar Talent Acquisition Partner supporting Cat Digital since April 2021.'\n    }),\n    base({\n      name: 'Carly I.',\n      title: 'Segment Global Early Career Talent Leader, Services Distribution and Digital',\n      location: 'Chicago, IL',\n      focus_area: 'Early career talent / services, distribution and digital programs',\n      notes: 'The Org Caterpillar profile lists Carly as Segment Global Early Career Talent Leader for Services Distribution and Digital, with campus recruiting background.'\n    }),\n    base({\n      name: 'Matthew Fritz',\n      title: 'Global Talent Acquisition Leader, Cat Digital',\n      location: 'United States',\n      focus_area: 'Cat Digital talent acquisition leadership / technical and digital recruiting',\n      notes: 'The Org profile identifies Matthew as Global Talent Acquisition Leader for Cat Digital at Caterpillar, with prior GE Digital and aviation recruiting leadership.'\n    })\n  ],\n  C1173: [\n    base({\n      name: 'Amraj Grewal',\n      title: 'Technical Recruiter',\n      location: 'United States',\n      focus_area: 'Technical recruiting / software, engineering and product roles',\n      notes: 'The Org John Deere talent acquisition org chart under Crystal T. Jones lists Amraj as a Technical Recruiter.'\n    }),\n    base({\n      name: 'Carlos Sanchez',\n      title: 'HR Process Lead / Senior Recruiter / ERG and DEI Lead',\n      location: 'United States',\n      focus_area: 'Senior recruiting / DEI and ERG talent pipelines',\n      notes: 'The Org John Deere talent acquisition org chart lists Carlos as HR Process Lead, Senior Recruiter, and ERG and DEI Lead.'\n    }),\n    base({\n      name: 'Filipe Nagao',\n      title: 'Talent Acquisition Specialist',\n      location: 'United States',\n      focus_area: 'Talent acquisition / North America recruiting support',\n      notes: 'The Org John Deere talent acquisition org chart lists Filipe as a Talent Acquisition Specialist under the Americas TA organization.'\n    }),\n    base({\n      name: 'John Carter',\n      title: 'Recruiter, North America Recruiting and Staffing',\n      location: 'Greater Cleveland, OH',\n      focus_area: 'North America recruiting and staffing',\n      notes: 'The Org John Deere org chart and public profile-index results list John as Recruiter, North America Recruiting and Staffing for John Deere.'\n    })\n  ],\n  C1174: [\n    base({\n      name: 'Lesli Hollingshead',\n      title: 'Director, Talent Acquisition',\n      linkedin_url: 'https://www.linkedin.com/in/lesli-hollingshead-bbb05b53',\n      location: 'St. Louis, MO',\n      focus_area: 'Talent acquisition leadership / Emerson recruiting strategy',\n      notes: 'The Org and public profile-index results identify Lesli as Emerson Director, Talent Acquisition since 2022, with prior recruitment leadership at Ameren.'\n    }),\n    base({\n      name: 'Summer Welty',\n      title: 'Senior Talent Acquisition Partner',\n      location: 'Erie, CO',\n      focus_area: 'Engineering, supply chain and technical project hiring',\n      notes: 'Public LinkedIn job-poster pages and The Org list Summer as an Emerson Senior Talent Acquisition Partner recruiting engineering and supply-chain roles.'\n    }),\n    base({\n      name: 'Shea Dunning',\n      title: 'Team Lead, Talent Acquisition',\n      location: 'United States',\n      focus_area: 'Talent acquisition team leadership / Emerson recruiting operations',\n      notes: 'The Org Emerson human resources and talent management team lists Shea as Team Lead, Talent Acquisition.'\n    }),\n    base({\n      name: 'Adrian Rodriguez Hidalgo',\n      title: 'Senior Recruiter',\n      location: 'Mexico City, Mexico',\n      focus_area: 'Software, EV power conversion, ADAS and Test & Measurement recruiting',\n      notes: 'Public LinkedIn job-poster pages list Adrian as Emerson Senior Recruiter managing full-cycle talent hiring for software and EV power conversion roles.'\n    })\n  ],\n  C1175: [\n    base({\n      name: 'Elizabeth E.',\n      title: 'Senior Technical Talent Acquisition Consultant',\n      location: 'Syracuse, NY area',\n      focus_area: 'Technical recruiting / GEIS, controls, safety and engineering roles',\n      notes: 'Public LinkedIn job-poster pages identify Elizabeth as Eaton Senior Technical Talent Acquisition Consultant for engineering and product safety roles.'\n    }),\n    base({\n      name: 'Haley Midili',\n      title: 'Senior Technical Talent Acquisition Consultant',\n      linkedin_url: 'https://www.linkedin.com/in/haley-midili-22415b11b',\n      location: 'Pittsburgh, PA',\n      focus_area: 'Technical talent acquisition / quality, solutions engineering and electrical infrastructure roles',\n      notes: 'Public LinkedIn profile shows Haley as a Senior Technical Talent Acquisition Consultant for Eaton, with active technical hiring posts.'\n    }),\n    base({\n      name: 'Ed Biondo',\n      title: 'Talent Acquisition Manager, North America',\n      location: 'Pennsylvania, United States',\n      focus_area: 'North America talent acquisition management',\n      notes: 'The Org Eaton Talent Acquisition team and public profile-index results list Ed as Talent Acquisition Manager, North America at Eaton.'\n    })\n  ],\n  C1176: [\n    base({\n      name: 'Joan Coyne',\n      title: 'Director, Talent Acquisition and Talent Management',\n      location: 'United States',\n      focus_area: 'Talent acquisition and talent management leadership',\n      notes: 'The Org Parker Hannifin profile lists Joan as Director, Talent Acquisition and Talent Management; public candidate activity also names her in Parker HR program support.'\n    }),\n    base({\n      name: 'Laurie Schwed',\n      title: 'Contract Corporate Recruiter',\n      location: 'Central Colorado',\n      focus_area: 'Corporate recruiting / Parker Hannifin contract recruiting',\n      notes: 'The Org lists Laurie as a Contract Corporate Recruiter for Parker Hannifin, with public background in corporate recruitment.'\n    }),\n    base({\n      name: 'Tammy Newhouse',\n      title: 'Group HR Manager, Talent and Organizational Development',\n      location: 'Cleveland, OH',\n      focus_area: 'Talent development, HR leadership and recruiting-adjacent hiring support',\n      notes: 'The Org Parker Hannifin org chart and public profile-index results list Tammy as Group HR Manager for Talent and Organizational Development.'\n    })\n  ]\n};\n\nlet added = 0;\nfor (const [id, contacts] of Object.entries(additions)) {\n  const company = data.companies.find((c) => c.id === id);\n  if (\"'!company) throw new Error(`Missing company ${id}`);\n  company.recruiters ||= [];\n  for (const contact of contacts) {\n    if (company.recruiters.length >= 10) break;\n    const nameKey = contact.name.trim().toLowerCase();\n    const urlKey = String(contact.linkedin_url || '\"'').trim().toLowerCase();\n    const duplicate = company.recruiters.some((r) => {\n      const existingName = String(r.name || '').trim().toLowerCase();\n      const existingUrl = String(r.linkedin_url || '').trim().toLowerCase();\n      return existingName === nameKey || (urlKey && existingUrl === urlKey);\n    });\n    if (\"'!duplicate) {\n      company.recruiters.push(contact);\n      added += 1;\n    }\n  }\n  if (company.recruiters.length > 10) {\n    throw new Error(`${id} exceeds 10 contacts`);\n  }\n}\n\nfs.writeFileSync(path, JSON.stringify(data, null, 2) + '\"'\\\\n');\nconsole.log(\"'`added=${added}`);\nNODE'","aggregated_output":"","exit_code":null,"status":"in_progress"}}
