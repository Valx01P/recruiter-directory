{"type":"item.started","item":{"id":"item_46","type":"command_execution","command":"/bin/zsh -lc \"node - <<'NODE'\nconst fs = require('fs');\nconst path = 'job/sectors/recruiter-ai.json';\nconst data = JSON.parse(fs.readFileSync(path, 'utf8'));\n\nconst updates = {\n  C0693: {\n    description: 'Starburst provides a Trino-based data lakehouse analytics platform that lets enterprises query distributed data across clouds and on-premises for governed analytics and AI applications.',\n    recruiters: [\n      {\n        name: 'Alexa Shanahan',\n        title: 'Director of Recruiting',\n        linkedin_url: 'https://www.linkedin.com/in/alexashanahan',\n        email: '',\n        location: 'Greater Boston',\n        focus_area: 'Recruiting leadership; Starburst R&D and GTM hiring',\n        connected: false,\n        messaged: false,\n        responded: false,\n        date_contacted: '',\n        notes: 'Public LinkedIn profile and Starburst recruiting pages show current Director of Recruiting leading hiring at Starburst.'\n      },\n      {\n        name: 'Rich Lapham',\n        title: 'Technical Recruiter',\n        linkedin_url: '',\n        email: '',\n        location: '',\n        focus_area: 'Technical recruiting for engineering and product roles',\n        connected: false,\n        messaged: false,\n        responded: false,\n        date_contacted: '',\n        notes: 'The Org lists current Technical Recruiting at Starburst since November 2024; supports engineering hiring.'\n      }\n    ]\n  },\n  C0695: {\n    description: 'Cockroach Labs builds CockroachDB, a cloud-native distributed SQL database for resilient transactional applications that need PostgreSQL compatibility, horizontal scale, and multi-region reliability.',\n    recruiters: [\n      {\n        name: 'Lynette Estrada',\n        title: 'Vice President, Global Talent Acquisition',\n        linkedin_url: 'https://www.linkedin.com/in/lynetteestrada',\n        email: '',\n        location: 'Washington DC-Baltimore Area',\n        focus_area: 'Global talent acquisition and recruiting strategy',\n        connected: false,\n        messaged: false,\n        responded: false,\n        date_contacted: '',\n        notes: 'Public LinkedIn profile and Cockroach Labs talent team listings show VP, Global Talent Acquisition at Cockroach Labs.'\n      },\n      {\n        name: 'Elisha Blanco Marlier',\n        title: 'Senior Recruiter',\n        linkedin_url: 'https://www.linkedin.com/in/elishamarlier',\n        email: '',\n        location: 'Austin, TX',\n        focus_area: 'Recruiting across sales, customer success, and engineering roles',\n        connected: false,\n        messaged: false,\n        responded: false,\n        date_contacted: '',\n        notes: 'Public LinkedIn profile and The Org list current Senior Recruiter at Cockroach Labs.'\n      }\n    ]\n  },\n  C0696: {\n    description: 'PlanetScale offers a managed relational database platform for Vitess, MySQL, and Postgres, emphasizing online schema changes, sharding, observability, and low-latency production workloads.',\n    recruiters: [\n      {\n        name: 'Sam Lambert',\n        title: 'CEO',\n        linkedin_url: 'https://www.linkedin.com/in/isamlambert',\n        email: '',\n        location: 'San Francisco, CA',\n        focus_area: 'Executive and technical hiring; infrastructure and database engineering roles',\n        connected: false,\n        messaged: false,\n        responded: false,\n        date_contacted: '',\n        notes: 'Public LinkedIn activity shows current CEO reposting and promoting PlanetScale engineering hiring across Postgres and database infrastructure.'\n      },\n      {\n        name: 'Nicholas Van Wiggeren',\n        title: 'Chief Technology Officer',\n        linkedin_url: 'https://www.linkedin.com/in/nicholas-van-wiggeren-85444528',\n        email: '',\n        location: 'Seattle, WA',\n        focus_area: 'Technical hiring for database, customer engineering, and infrastructure teams',\n        connected: false,\n        messaged: false,\n        responded: false,\n        date_contacted: '',\n        notes: 'Public LinkedIn profile and posts show CTO at PlanetScale actively sharing current engineering hiring opportunities.'\n      }\n    ]\n  },\n  C0697: {\n    description: 'Neo4j develops a graph database and graph intelligence platform used to model connected data, power knowledge graphs, and ground generative AI applications.',\n    recruiters: [\n      {\n        name: 'Lindsay Te Kanawa',\n        title: 'Senior Recruiter',\n        linkedin_url: 'https://www.linkedin.com/in/lindsay-tekanawa',\n        email: '',\n        location: 'United States',\n        focus_area: 'GTM, G&A, federal, and recruiter interviews at Neo4j',\n        connected: false,\n        messaged: false,\n        responded: false,\n        date_contacted: '',\n        notes: 'Public LinkedIn profile and Neo4j job posts list Senior Recruiter supporting GTM, G&A, and Federal roles.'\n      },\n      {\n        name: 'Pietro Mattei',\n        title: 'Technical Recruiting Manager',\n        linkedin_url: 'https://se.linkedin.com/in/pietromattei',\n        email: '',\n        location: 'Malmo, Sweden',\n        focus_area: 'Engineering and product recruiting across EMEA and US',\n        connected: false,\n        messaged: false,\n        responded: false,\n        date_contacted: '',\n        notes: 'Public LinkedIn profile and personal site list current Neo4j Technical Recruiting Manager hiring engineering, AI, and product roles.'\n      }\n    ]\n  },\n  C0698: {\n    description: 'Redis develops an in-memory real-time data platform for caching, search, vector workloads, messaging, and low-latency application infrastructure used by engineering teams.',\n    recruiters: [\n      {\n        name: 'Edna Yan',\n        title: 'VP, Global Talent Acquisition',\n        linkedin_url: 'https://www.linkedin.com/in/edna-yan',\n        email: '',\n        location: 'Corona del Mar, CA',\n        focus_area: 'Global talent acquisition leadership',\n        connected: false,\n        messaged: false,\n        responded: false,\n        date_contacted: '',\n        notes: 'Public LinkedIn profile and The Org list current Redis VP / Head of Global Talent Acquisition.'\n      },\n      {\n        name: 'Courtney Alvey',\n        title: 'Technical Recruiter',\n        linkedin_url: '',\n        email: '',\n        location: '',\n        focus_area: 'Technical recruiting',\n        connected: false,\n        messaged: false,\n        responded: false,\n        date_contacted: '',\n        notes: 'The Org lists Courtney Alvey on Redis Human Resources and Talent Acquisition as Technical Recruiter.'\n      }\n    ]\n  },\n  C0699: {\n    description: 'SingleStore provides a distributed SQL database for real-time analytics, transactions, and vector search, helping teams build low-latency data applications and AI experiences.',\n    recruiters: [\n      {\n        name: 'Dan Riccio',\n        title: 'Director, Talent Acquisition',\n        linkedin_url: 'https://www.linkedin.com/in/dan-riccio-mba-9486714',\n        email: '',\n        location: 'Schenectady, NY',\n        focus_area: 'Talent acquisition leadership and GTM hiring',\n        connected: false,\n        messaged: false,\n        responded: false,\n        date_contacted: '',\n        notes: 'Public LinkedIn profile and Noon AI post list current Director, Talent Acquisition at SingleStore.'\n      },\n      {\n        name: 'Sakina Makda',\n        title: 'Senior Talent Acquisition Partner',\n        linkedin_url: 'https://in.linkedin.com/in/sakinajmakda',\n        email: '',\n        location: 'India',\n        focus_area: 'Global technical and GTM hiring',\n        connected: false,\n        messaged: false,\n        responded: false,\n        date_contacted: '',\n        notes: 'Public LinkedIn profile and The Org list current SingleStore Senior Talent Acquisition Partner.'\n      }\n    ]\n  },\n  C0700: {\n    description: 'Couchbase provides Capella and its NoSQL database platform for operational, mobile, analytics, vector, and AI workloads across cloud, edge, and enterprise applications.',\n    recruiters: [\n      {\n        name: 'Georgina Protopapas',\n        title: 'Senior Manager, Talent Acquisition',\n        linkedin_url: 'https://uk.linkedin.com/in/georginaprotopapas',\n        email: '',\n        location: 'London, England, United Kingdom',\n        focus_area: 'Talent acquisition for Couchbase technical and sales roles',\n        connected: false,\n        messaged: false,\n        responded: false,\n        date_contacted: '',\n        notes: 'Public LinkedIn profile, The Org, and Couchbase job postings list current Senior Manager, Talent Acquisition.'\n      },\n      {\n        name: 'Peter Algazi',\n        title: 'Senior Recruiter',\n        linkedin_url: 'https://www.linkedin.com/in/peter-algazi-71a4a13',\n        email: '',\n        location: 'Newport Beach, CA',\n        focus_area: 'Recruiting, especially revenue and customer-facing roles',\n        connected: false,\n        messaged: false,\n        responded: false,\n        date_contacted: '',\n        notes: 'Public LinkedIn profile and The Org list Peter as a Couchbase recruiter with active recruiting posts.'\n      }\n    ]\n  },\n  C0701: {\n    description: 'DataStax builds Astra DB and related AI data services on Apache Cassandra, combining serverless databases, vector search, and Langflow for production generative AI applications.',\n    recruiters: [\n      {\n        name: 'Natalie Kenney',\n        title: 'Talent Acquisition / Technical Recruiter',\n        linkedin_url: 'https://www.linkedin.com/in/natalie-kenney',\n        email: '',\n        location: 'Castle Rock, CO',\n        focus_area: 'Technical recruiting and talent acquisition',\n        connected: false,\n        messaged: false,\n        responded: false,\n        date_contacted: '',\n        notes: 'Public LinkedIn profile and The Org list current DataStax talent acquisition; profile highlights technical recruiting experience.'\n      },\n      {\n        name: 'Leah Blalock',\n        title: 'Talent Acquisition - Technical Recruiting',\n        linkedin_url: '',\n        email: '',\n        location: 'San Diego, CA',\n        focus_area: 'Technical recruiting for DataStax / IBM data platform roles',\n        connected: false,\n        messaged: false,\n        responded: false,\n        date_contacted: '',\n        notes: 'The Org lists Leah Blalock under DataStax talent acquisition - technical recruiting; public profile summaries corroborate DataStax technical recruiting.'\n      }\n    ]\n  }\n};\n\nfor (const company of data.companies || []) {\n  const update = updates[company.id];\n  if (\"'!update) continue;\n  company.description = update.description;\n  const existing = new Set((company.recruiters || []).map(r => `${String(r.name || '\"'').toLowerCase()}|\"'${String(r.linkedin_url || '\"'').toLowerCase()}\"'`));\n  company.recruiters = company.recruiters || [];\n  for (const recruiter of update.recruiters) {\n    const key = `${String(recruiter.name || '\"'').toLowerCase()}|\"'${String(recruiter.linkedin_url || '\"'').toLowerCase()}\"'`;\n    if (!existing.has(key)) {\n      company.recruiters.push(recruiter);\n      existing.add(key);\n    }\n  }\n}\n\nfs.writeFileSync(path, JSON.stringify(data, null, 2) + '\"'\\\\n');\nNODE\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
