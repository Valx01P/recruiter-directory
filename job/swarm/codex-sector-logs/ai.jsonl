{"type":"item.started","item":{"id":"item_34","type":"command_execution","command":"/bin/zsh -lc \"node <<'NODE'\nconst fs = require('fs');\nconst path = 'job/sectors/recruiter-ai.json';\nconst data = JSON.parse(fs.readFileSync(path, 'utf8'));\n\nconst updates = {\n  C0678: {\n    description: 'Fivetran provides automated data movement and managed connectors that sync operational data into cloud warehouses and lakes for analytics, AI, and business reporting.',\n    hq_location: 'Oakland, CA',\n    careers_url: 'https://www.fivetran.com/careers',\n    linkedin_url_verified: true,\n    recruiters: [\n      {\n        name: 'Gopikrishnan R.',\n        title: 'Talent Acquisition Lead, APAC',\n        linkedin_url: 'https://in.linkedin.com/in/rgkhr',\n        email: '',\n        location: 'Greater Bengaluru Area',\n        focus_area: 'APAC talent acquisition and technical recruiting',\n        connected: false,\n        messaged: false,\n        responded: false,\n        date_contacted: '',\n        notes: 'Public LinkedIn profile shows current Fivetran talent acquisition leadership for APAC.'\n      },\n      {\n        name: 'Conor Lilly',\n        title: 'Talent Acquisition Leader',\n        linkedin_url: 'https://ie.linkedin.com/in/conorlilly',\n        email: '',\n        location: 'Dublin, Ireland',\n        focus_area: 'Technical and business recruiting across Fivetran regions',\n        connected: false,\n        messaged: false,\n        responded: false,\n        date_contacted: '',\n        notes: 'Public LinkedIn profile identifies him as a talent acquisition leader currently at Fivetran.'\n      }\n    ]\n  },\n  C0679: {\n    description: 'dbt Labs builds the dbt analytics engineering platform, helping data teams transform, document, test, and govern structured data for trusted analytics and AI workflows.',\n    hq_location: 'Philadelphia, PA',\n    careers_url: 'https://www.getdbt.com/careers',\n    linkedin_url_verified: true,\n    recruiters: [\n      {\n        name: 'Kim Ripperger',\n        title: 'Senior Talent Acquisition Partner',\n        linkedin_url: 'https://es.linkedin.com/in/kimberlyripperger',\n        email: '',\n        location: 'Zarauz, Basque Country, Spain',\n        focus_area: 'Technical and product recruiting for dbt Labs',\n        connected: false,\n        messaged: false,\n        responded: false,\n        date_contacted: '',\n        notes: 'Public LinkedIn profile and dbt Labs employee spotlight identify her as a Senior Talent Acquisition Partner.'\n      },\n      {\n        name: 'Alex B.',\n        title: 'Recruiter',\n        linkedin_url: 'https://uk.linkedin.com/in/alexanderbeardsmore',\n        email: '',\n        location: 'United Kingdom',\n        focus_area: 'GTM and international recruiting for dbt Labs',\n        connected: false,\n        messaged: false,\n        responded: false,\n        date_contacted: '',\n        notes: 'Public LinkedIn profile shows current dbt Labs recruiter activity and hiring posts.'\n      }\n    ]\n  },\n  C0680: {\n    description: 'Airbyte develops open-source data movement infrastructure and connectors that replicate data from applications, APIs, and databases into warehouses, lakes, and AI systems.',\n    hq_location: 'San Francisco, CA',\n    careers_url: 'https://airbyte.com/careers',\n    linkedin_url_verified: true,\n    recruiters: [\n      {\n        name: 'Abby Rink',\n        title: 'Senior Technical Recruiter',\n        linkedin_url: 'https://www.linkedin.com/in/abby-r-b1a312193',\n        email: '',\n        location: 'San Francisco, CA',\n        focus_area: 'Technical recruiting for data and AI roles',\n        connected: false,\n        messaged: false,\n        responded: false,\n        date_contacted: '',\n        notes: 'Public LinkedIn post says she joined Airbyte as Senior Technical Recruiter and that Airbyte is hiring in data and AI.'\n      },\n      {\n        name: 'Nicole Lu (Lauterbach), SHRM-CP',\n        title: 