{"type":"item.started","item":{"id":"item_40","type":"command_execution","command":"/bin/zsh -lc \"node <<'NODE'\nconst fs = require('fs');\nconst file = 'job/sectors/recruiter-ai.json';\nconst data = JSON.parse(fs.readFileSync(file, 'utf8'));\n\nconst recruiter = (name, title, linkedin_url, location, focus_area, notes) => ({\n  name,\n  title,\n  linkedin_url,\n  email: '',\n  location,\n  focus_area,\n  connected: false,\n  messaged: false,\n  responded: false,\n  date_contacted: '',\n  notes\n});\n\nconst updates = {\n  C0692: {\n    description: 'Wolfram Research builds computational software and knowledge engines, including Wolfram Language, Mathematica, and Wolfram|Alpha, used for technical computing, data science, and education.',\n    hq_location: 'Champaign, IL',\n    careers_url: 'https://www.wolfram.com/company/careers/',\n    recruiters: [\n      recruiter(\n        'Laura Berg',\n        'Director, Human Resources and Recruiting',\n        'https://www.linkedin.com/in/lauraberg',\n        'Champaign, IL',\n        'Human resources and recruiting',\n        'Official Wolfram Community profile lists Laura Berg at Wolfram Research as Director Human Resources and Recruiting; public profile points to careers.wolfram.com.'\n      )\n    ]\n  },\n  C0708: {\n    description: 'Vectara provides an enterprise AI agent and RAG platform with retrieval, generation, hallucination detection, and governance features for production knowledge applications.',\n    hq_location: 'Palo Alto, CA',\n    careers_url: 'https://job-boards.greenhouse.io/vectara',\n    recruiters: [\n      recruiter(\n        'Vishal Naik',\n        'Machine Learning Engineer',\n        'https://www.linkedin.com/in/vishal-naik-93659230',\n        'San Francisco Bay Area',\n        'ML intern and applied AI hiring',\n        'Current Vectara ML engineer; public LinkedIn post says Vectara is hiring ML interns and invites candidates to DM resumes.'\n      ),\n      recruiter(\n        'Abhishek Pradhan',\n        'Software Engineer',\n        'https://www.linkedin.com/in/abhishekgpradhan',\n        'United States',\n        'Platform engineering hiring signal',\n        'Current Vectara software engineer; public LinkedIn results connect him with Vectara platform engineering hiring activity.'\n      )\n    ]\n  },\n  C0711: {\n    description: 'Modal provides serverless AI infrastructure for running GPU workloads, ML inference, batch jobs, sandboxes, and compute-intensive applications without managing cloud infrastructure.',\n    hq_location: 'New York, NY',\n    careers_url: 'https://modal.com/careers',\n    recruiters: [\n      recruiter(\n        'Audrey Koh',\n        'Head of Talent',\n        'https://www.linkedin.com/in/audreykoh',\n        'United States',\n        'Company-wide and technical recruiting',\n        'Public LinkedIn post says Audrey joined Modal as Head of Talent and that Modal is hiring across NYC, San Francisco, and Stockholm.'\n      ),\n      recruiter(\n        'Rebecka Storm',\n        'Member of Technical Staff',\n        'https://se.linkedin.com/in/rebeckastorm',\n        'Stockholm, Sweden',\n        'Technical team and AI infrastructure hiring signal',\n        'Current Modal technical staff member; public posts invite builders to join Modal and highlight AI infrastructure roles and events.'\n      )\n    ]\n  },\n  C0716: {\n    description: 'Fireworks AI builds a generative AI infrastructure platform for fast open-model inference, fine-tuning, deployment, and production AI application development.',\n    hq_location: 'San Mateo, CA',\n    careers_url: 'https://job-boards.greenhouse.io/fireworksai',\n    recruiters: [\n      recruiter(\n        'Ravi B.',\n        'Technical Recruiter',\n        'https://www.linkedin.com/in/ravi-b-68277a171',\n        'San Jose, CA',\n        'Technical recruiting for AI infrastructure roles',\n        'Current Fireworks AI technical recruiter; public LinkedIn posts advertise cloud infrastructure, applied ML, and AI platform hiring.'\n      ),\n      recruiter(\n        'Lavinia Liu',\n        'Head of People',\n        'https://www.linkedin.com/in/lavinia-liu',\n        'San Francisco Bay Area',\n        'People and recruiting operations',\n        'Public professional profiles list Lavinia Liu as Head of People at Fireworks AI, with HRBP and people operations background.'\n      )\n    ]\n  },\n  C0720: {\n    description: 'Character.AI operates a consumer AI platform where users create, discover, and interact with conversational characters for storytelling, entertainment, learning, and creative exploration.',\n    hq_location: 'Redwood City, CA',\n    careers_url: 'https://jobs.ashbyhq.com/character',\n    recruiters: [\n      recruiter(\n        'Tim Godfrey',\n        'Technical Recruiter',\n        '',\n        'United States',\n        'Research engineering recruiting',\n        'The Org profile lists Tim Godfrey as Technical Recruiter at Character.AI since October 2023, focused on recruiting research engineers.'\n      ),\n      recruiter(\n        'Nicole Miralles Bugay',\n        'Recruiter',\n        'https://www.linkedin.com/in/nicolemiralles',\n        'Los Angeles Metropolitan Area',\n        'Recruiting and technical sourcing',\n        'Current Character.AI recruiter; public LinkedIn and The Org profiles show recruiting work and posts sharing engineering, product, design, and ML roles.'\n      )\n    ]\n  },\n  C0723: {\n    description: 'ElevenLabs develops generative audio and voice AI products for speech synthesis, dubbing, conversational agents, music, and developer-facing audio applications.',\n    hq_location: 'New York, NY',\n    careers_url: 'https://elevenlabs.io/careers',\n    recruiters: [\n      recruiter(\n        'Becky Lee-Roche',\n        'Head of Talent Acquisition',\n        'https://ie.linkedin.com/in/beckylr',\n        'Dublin, Ireland',\n        'Global talent acquisition and GTM hiring',\n        'Current ElevenLabs talent leader; public posts describe scaling ElevenLabs talent from three full-time recruiters to a larger global team.'\n      ),\n      recruiter(\n        'Jake Meer',\n        'Recruiter',\n        'https://www.linkedin.com/in/jacobmeer',\n        'Washington DC-Baltimore Area',\n        'Recruiting and talent acquisition',\n        'Current ElevenLabs recruiter with public LinkedIn profile, recruiting credentials, and history as a full-time recruiter.'\n      ),\n      recruiter(\n        'Maddi Kalkoske',\n        'Talent Team',\n        'https://www.linkedin.com/in/madisonkalkoske',\n        'Brooklyn, NY',\n        'Talent team and product hiring',\n        'Current ElevenLabs talent team member; public LinkedIn activity says she joined the Talent team and invites builders to connect.'\n      )\n    ]\n  },\n  C0724: {\n    description: 'Suno builds AI music creation tools that generate songs, instrumentals, vocals, and editing workflows for consumers, creators, and music production teams.',\n    hq_location: 'Cambridge, MA',\n    careers_url: 'https://suno.com/careers',\n    recruiters: [\n      recruiter(\n        'Lindsay Young',\n        'Recruiter',\n        'https://www.linkedin.com/in/lindsay-young-005b0310b',\n        'San Francisco Bay Area',\n        'Recruiting for AI, data science, engineering, and creative technology roles',\n        'Current Suno recruiter; public posts advertise Suno hiring across AI, data science, machine learning, and engineering roles.'\n      ),\n      recruiter(\n        'Tyler Blum',\n        'Sr. Recruiter, Tech & GTM',\n        'https://www.linkedin.com/in/blum-tyler',\n        'Marina del Rey, CA',\n        'Technical and go-to-market recruiting',\n        'Current Suno recruiting contact; public professional profiles list him as Talent at Suno / Sr. Recruiter for Tech and GTM.'\n      )\n    ]\n  },\n  C0740: {\n    description: 'Fiddler AI provides AI observability and security software for monitoring, evaluating, and governing machine learning, LLM, and agentic systems in production.',\n    hq_location: 'Palo Alto, CA',\n    careers_url: 'https://jobs.ashbyhq.com/fiddler',\n    recruiters: [\n      recruiter(\n        'Marlon Montillano',\n        'Talent Acquisition',\n        'https://www.linkedin.com/in/marlonmontillano',\n        'San Francisco Bay Area',\n        'Talent acquisition for AI science, product, and GTM roles',\n        'Current Fiddler AI talent acquisition contact; public LinkedIn job posts list him as the direct poster for AI science, product, and Federal roles.'\n      ),\n      recruiter(\n        'Chanda T.',\n        'Recruiting / People',\n        'https://www.linkedin.com/in/chandatownsend',\n        'San Francisco Bay Area',\n        'Technical recruiting and people operations',\n        'Current Fiddler AI people/recruiting contact; public profile recommendations cite technical recruiting partnership for engineering teams.'\n      )\n    ]\n  }\n};\n\nlet touched = 0;\nlet added = 0;\nfor (const company of data.companies || []) {\n  const update = updates[company.id];\n  if (\"'!update) continue;\n  touched += 1;\n  company.description = update.description;\n  if (update.hq_location) company.hq_location = update.hq_location;\n  if (update.careers_url) company.careers_url = update.careers_url;\n  company.recruiters = company.recruiters || [];\n  for (const person of update.recruiters) {\n    const exists = company.recruiters.some(existing => {\n      const sameUrl = person.linkedin_url && existing.linkedin_url === person.linkedin_url;\n      const sameName = existing.name && existing.name.toLowerCase() === person.name.toLowerCase();\n      return sameUrl || sameName;\n    });\n    if (!exists && company.recruiters.length < 10) {\n      company.recruiters.push(person);\n      added += 1;\n    }\n  }\n}\n\nfs.writeFileSync(file, JSON.stringify(data, null, 2) + '\"'\\\\n');\nconsole.log(\"'`updated ${touched} companies, added ${added} recruiters`);\nNODE'","aggregated_output":"","exit_code":null,"status":"in_progress"}}
