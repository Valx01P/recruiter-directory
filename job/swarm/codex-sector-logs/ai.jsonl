al Sourcer / Recruiter',\n        linkedin_url: 'https://www.linkedin.com/in/ingridreyes6',\n        location: 'Boston, MA, United States',\n        focus_area: 'Technical sourcing and recruiting',\n        notes: 'Public LinkedIn profile shows technical Sourcer/Recruiter experience and current MathWorks experience in Natick.'\n      })\n    ]\n  },\n  C0694: {\n    description: 'ClickHouse builds an open-source columnar OLAP database and managed cloud platform for real-time analytics, observability, and AI-scale event data.',\n    hq_location: 'Bay Area, CA',\n    careers_url: 'https://clickhouse.com/company/careers',\n    recruiters: [\n      recruiter({\n        name: 'Juliana Redden',\n        title: 'Recruiting Coordinator',\n        linkedin_url: 'https://www.linkedin.com/in/juliana-redden-086957b8',\n        location: 'New York, NY, United States',\n        focus_area: 'Recruiting coordination and candidate experience',\n        notes: 'Public LinkedIn profile says she joined ClickHouse as its first Recruiting Coordinator.'\n      }),\n      recruiter({\n        name: 'Charlotte DePew',\n        title: 'Recruiting / Talent, ClickHouse',\n        linkedin_url: 'https://www.linkedin.com/in/cdepew',\n        location: 'Des Moines Metropolitan Area',\n        focus_area: 'Global remote recruiting and talent placement',\n        notes: 'Public LinkedIn profile shows ClickHouse experience and active posts about ClickHouse hiring across teams and regions.'\n      })\n    ]\n  }\n};\n\nlet touched = 0;\nlet added = 0;\nfor (const company of data.companies || []) {\n  const update = updates[company.id];\n  if (\"'!update) continue;\n  touched += 1;\n  company.description = update.description;\n  if (update.hq_location) company.hq_location = update.hq_location;\n  if (update.careers_url) company.careers_url = update.careers_url;\n  if (!Array.isArray(company.recruiters)) company.recruiters = [];\n  const seenNames = new Set(company.recruiters.map(r => String(r.name || '\"'').trim().toLowerCase()).filter(Boolean));\n  const seenUrls = new Set(company.recruiters.map(r => String(r.linkedin_url || '').trim().toLowerCase()).filter(Boolean));\n  for (const r of update.recruiters) {\n    const nameKey = String(r.name || '').trim().toLowerCase();\n    const urlKey = String(r.linkedin_url || '').trim().toLowerCase();\n    if ((nameKey && seenNames.has(nameKey)) || (urlKey && seenUrls.has(urlKey))) continue;\n    company.recruiters.push(r);\n    if (nameKey) seenNames.add(nameKey);\n    if (urlKey) seenUrls.add(urlKey);\n    added += 1;\n  }\n}\n\nfs.writeFileSync(path, JSON.stringify(data, null, 2) + '\\\\n');\nconsole.log(\"'`touched=${touched} added=${added}`);\nNODE'","aggregated_output":"","exit_code":null,"status":"in_progress"}}
