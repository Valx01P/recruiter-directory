\\\": \\\\\\\"\\\\\\\",\\\\n  \\\\\\\"recruiters\\\\\\\": []\\\\n}\\\\n```\\\\n\\\\nAfter the batch, run the status command again and print this exact marker on its own line:\\\\n\\\\n`=== SECTOR_BATCH_COMPLETE energy <companies-touched> <entries-added> <remaining-unpopulated> <remaining-missing-descriptions> ===`\\\\n\\\",\\\"exit_code\\\":0,\\\"status\\\":\\\"completed\\\"}}\\njob/swarm/codex-sector-logs/ai-batch-0001-prompt.txt:26:=== SECTOR_BATCH_COMPLETE ai <companies-touched> <entries-added> <remaining-unpopulated> <remaining-missing-descriptions> ===\\njob/swarm/codex-sector-logs/ai-batch-0004-prompt.txt:26:=== SECTOR_BATCH_COMPLETE ai <companies-touched> <entries-added> <remaining-unpopulated> <remaining-missing-descriptions> ===\\njob/swarm/codex-sector-logs/consulting-batch-0005-prompt.txt:26:=== SECTOR_BATCH_COMPLETE consulting <companies-touched> <entries-added> <remaining-unpopulated> <remaining-missing-descriptions> ===\\n\",\"exit_code\":0,\"status\":\"completed\"}}\njob/swarm/codex-sector-logs/retail.jsonl:100:{\"type\":\"item.started\",\"item\":{\"id\":\"item_30\",\"type\":\"command_execution\",\"command\":\"/bin/zsh -lc 'rg \\\"SECTOR_BATCH_COMPLETE retail\\\" job/swarm/codex-sector-logs -n'\",\"aggregated_output\":\"\",\"exit_code\":null,\"status\":\"in_progress\"}}\njob/swarm/codex-sector-logs/retail.jsonl:101:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_30\",\"type\":\"command_execution\",\"command\":\"/bin/zsh -lc 'rg \\\"SECTOR_BATCH_COMPLETE retail\\\" job/swarm/codex-sector-logs -n'\",\"aggregated_output\":\"job/swarm/codex-sector-logs/retail-batch-0003-prompt.txt:26:=== SECTOR_BATCH_COMPLETE retail <companies-touched> <entries-added> <remaining-unpopulated> <remaining-missing-descriptions> ===\\njob/swarm/codex-sector-logs/retail-batch-0005-prompt.txt:26:=== SECTOR_BATCH_COMPLETE retail <companies-touched> <entries-added> <remaining-unpopulated> <remaining-missing-descriptions> ===\\njob/swarm/codex-sector-logs/retail-batch-0002-pro