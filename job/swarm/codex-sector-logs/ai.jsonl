{"type":"item.started","item":{"id":"item_29","type":"command_execution","command":"/bin/zsh -lc \"node <<'NODE'\nconst fs = require('fs');\nconst file = 'job/sectors/recruiter-ai.json';\nconst data = JSON.parse(fs.readFileSync(file, 'utf8'));\n\nconst contact = (name, title, linkedin_url, location, focus_area, notes) => ({\n  name,\n  title,\n  linkedin_url,\n  email: '',\n  location,\n  focus_area,\n  connected: false,\n  messaged: false,\n  responded: false,\n  date_contacted: '',\n  notes\n});\n\nconst updates = {\n  C0243: {\n    description: 'Harvey builds domain-specific AI tools for law firms and professional services teams, supporting legal research, drafting, due diligence, compliance, and complex workflow automation.',\n    recruiters: [\n      contact('Charlene Louie', 'Senior Technical Recruiter', 'https://www.linkedin.com/jobs/view/staff-product-manager-agent-platform-at-harvey-4401134650', 'San Francisco, CA', 'Technical recruiting / Product, Engineering, Design hiring', 'LinkedIn job postings list Charlene Louie as Senior Technical Recruiter at Harvey for product and EPD roles.'),\n      contact('Jamie Sperber', 'Business Recruiting Lead', '', 'United States', 'Business recruiting / GTM hiring', 'Public The Org listing shows Jamie Sperber as Business Recruiting Lead at Harvey since March 2024; verify profile before outreach.'),\n      contact('LB Hernandez', 'Senior Business Recruiter', '', 'United States', 'Business recruiting / startup hiring', 'Public The Org listing shows LB Hernandez as Senior Business Recruiter at Harvey since September 2025; verify profile before outreach.')\n    ]\n  },\n  C0244: {\n    description: 'Sierra builds AI agents for customer service and enterprise workflows, helping businesses automate conversational support while preserving brand-specific processes and human escalation paths.',\n    recruiters: [\n      contact('Michelle (Steyer) Carr', 'Recruiter', 'https://www.linkedin.com/in/msteyer', 'San Francisco Bay Area', 'Recruiting / business and product talent', 'Public LinkedIn profile says she is a recruiter dedicated to finding talent for Sierra.'),\n      contact('Katherine Moore', 'Talent / Emerging Talent Recruiting', 'https://www.linkedin.com/in/kathmoore4433', 'San Francisco, CA', 'Emerging talent recruiting / early career hiring', 'Public LinkedIn profile shows current Sierra role and recommendations tied to emerging talent recruiting.')\n    ]\n  },\n  C0247: {\n    description: 'Cohere develops enterprise foundation models and secure AI products for developers and organizations deploying language models across cloud, private cloud, and on-premises environments.',\n    recruiters: [\n      contact('Allie Carney', 'Senior Talent Partner', 'https://www.linkedin.com/in/alliecarney', 'Portland, OR', 'Senior talent partner / technical and leadership hiring', 'Public LinkedIn and The Org listings show Allie Carney as Senior Talent Partner at Cohere.'),\n      contact('Emma Kelly', 'Talent Partner', 'https://uk.linkedin.com/in/emmakelly', 'London, UK', 'Infrastructure and technical recruiting', 'Public LinkedIn profile says she joined Cohere as Talent Partner and has shared infrastructure hiring posts.'),\n      contact('Neil Katz', 'Talent Sourcer', 'https://ca.linkedin.com/in/neilk', 'Toronto, Ontario, Canada', 'Talent sourcing / technical hiring', 'Public LinkedIn search result lists Neil Katz as Talent Sourcer at Cohere in Toronto.')\n    ]\n  },\n  C0250: {\n    description: 'Zipline designs, manufactures, and operates autonomous electric drone logistics systems for healthcare, retail, and government customers needing fast, low-emission delivery.',\n    recruiters: [\n      contact('Casey Malloy', 'Recruiting Coordinator', 'https://www.linkedin.com/in/caseymalloy', 'San Francisco, CA', 'Recruiting coordination / candidate experience', 'Public LinkedIn profile shows Casey Malloy at Zipline and sharing recruiting coordinator hiring content.'),\n      contact('Ciara Rinaudo', 'Technical Recruiter', 'https://www.linkedin.com/in/ciara-rinaudo-94a685104', 'San Francisco Bay Area', 'Technical recruiting / engineering hiring', 'Public LinkedIn profile says she joined Zipline as a Technical Recruiter and shares engineering hiring activity.')\n    ]\n  },\n  C0253: {\n    description: 'Nuro builds an AI-first self-driving system and autonomy platform licensed to automakers and mobility providers for robotaxis, commercial fleets, and personal vehicles.',\n    recruiters: [\n      contact('Monica Jones', 'Talent Acquisition Specialist', 'https://www.linkedin.com/in/monicajones88', 'Hayward, CA', 'Talent acquisition / recruiting operations', 'Public LinkedIn profile describes Monica Jones as an experienced Talent Acquisition Specialist at Nuro.'),\n      contact('Garima Sangwan', 'Talent Acquisition / Recruiting', 'https://www.linkedin.com/in/garima-sangwan-128a448', 'Mountain View, CA', 'Recruiting / diversity recruiting', 'Public LinkedIn profile shows current Nuro role with recruiter recommendations and diversity recruiting certification.'),\n      contact('Christine Dickinson', 'Recruiting Coordinator / University Recruiting', 'https://www.linkedin.com/in/christinedickinson', 'Santa Clara, CA', 'University recruiting coordination / candidate experience', 'Public LinkedIn profile shows current Nuro role; recommendations reference university recruiting coordination experience.')\n    ]\n  },\n  C0673: {\n    description: 'Alteryx provides an AI-ready analytics platform for preparing, automating, and analyzing enterprise data so business teams can turn workflows into governed insights.',\n    recruiters: [\n      contact('Jill Bone', 'People / Recruiting Contact', 'https://www.linkedin.com/in/jill2006', 'United States', 'People and technical recruiting coordination', 'Public LinkedIn profile shows current Alteryx role and recent technical recruiter hiring activity for Engineering, Product, and Design.'),\n      contact('Erica Miller', 'Talent Acquisition Professional', 'https://www.linkedin.com/in/ericaleighmiller', 'United States', 'Talent acquisition / technical recruiting', 'Public LinkedIn profile shows current Alteryx role and talent acquisition background with technical recruiter recommendations.')\n    ]\n  },\n  C0674: {\n    description: 'Teradata provides cloud data platforms, analytics software, and AI services that help enterprises connect business context, governed data, and real-time decisioning.',\n    recruiters: [\n      contact('Chris Pinette', 'Talent Acquisition Partner / Recruiting Leader', 'https://www.linkedin.com/in/chris-pinette-78053255', 'United States', 'Talent acquisition / product engineering and product management hiring', 'Public LinkedIn post says Chris Pinette is hiring a Talent Acquisition Partner for his Teradata team, with Product Engineering focus.'),\n      contact('Manideep Mathurthi', 'Junior Technical Recruiter', 'https://in.linkedin.com/in/manideep-mathurthi-a17b85143', 'Hyderabad, Telangana, India', 'Technical recruiting', 'Public LinkedIn profile says Manideep Mathurthi is currently a Junior Technical Recruiter at Teradata.'),\n      contact('Adel Khisamova', 'Talent Acquisition Partner', 'https://dk.linkedin.com/in/adelkhisamova', 'Copenhagen, Denmark', 'EMEA talent acquisition', 'Public LinkedIn profile says Adel Khisamova is a Talent Acquisition Partner for Teradata in EMEA.')\n    ]\n  },\n  C0675: {\n    description: 'Cloudera provides hybrid data, analytics, and AI platforms that let enterprises manage data and machine learning workloads across clouds, data centers, and edge environments.',\n    recruiters: [\n      contact('Sphoorti Madihalli', 'Technical Recruiter', 'https://www.linkedin.com/in/sphoortimadihalli', 'Kirkland, WA', 'Technical recruiting / software engineering hiring', 'Public LinkedIn profile describes Sphoorti Madihalli as a technical recruiter at Cloudera with software engineering hiring activity.'),\n      contact('Stephanie Z.', 'Senior Talent Acquisition Partner', 'https://www.linkedin.com/in/halestephanie', 'United States', 'Talent acquisition / technical hiring', 'Public LinkedIn post says Stephanie Z. joined Cloudera as a Senior Talent Acquisition Partner; verify profile before outreach.'),\n      contact('Nishmitha Karkera', 'Technical Recruiter', 'https://in.linkedin.com/in/nishmitha-karkera-051681b9', 'Bengaluru, Karnataka, India', 'Technical recruiting / engineering talent', 'Public LinkedIn profile says Nishmitha Karkera is a technical recruiter at Cloudera with seasoned tech hiring expertise.')\n    ]\n  }\n};\n\nlet touched = 0;\nlet added = 0;\nfor (const [id, update] of Object.entries(updates)) {\n  const company = data.companies.find(c => c.id === id);\n  if (\"'!company) throw new Error(`Missing company id ${id}`);\n  touched += 1;\n  company.description = update.description;\n  if (!Array.isArray(company.recruiters)) company.recruiters = [];\n  const existingNames = new Set(company.recruiters.map(r => String(r.name || '\"'').trim().toLowerCase()).filter(Boolean));\n  const existingUrls = new Set(company.recruiters.map(r => String(r.linkedin_url || '').trim().toLowerCase()).filter(Boolean));\n  for (const recruiter of update.recruiters) {\n    const keyName = recruiter.name.trim().toLowerCase();\n    const keyUrl = recruiter.linkedin_url.trim().toLowerCase();\n    if (existingNames.has(keyName) || (keyUrl && existingUrls.has(keyUrl))) continue;\n    company.recruiters.push(recruiter);\n    existingNames.add(keyName);\n    if (keyUrl) existingUrls.add(keyUrl);\n    added += 1;\n  }\n}\n\nfs.writeFileSync(file, \"'`${JSON.stringify(data, null, 2)}'\"\\\\n\"'`);\nconsole.log(`updated ${touched} companies, added ${added} contacts`);\nNODE'","aggregated_output":"","exit_code":null,"status":"in_progress"}}
