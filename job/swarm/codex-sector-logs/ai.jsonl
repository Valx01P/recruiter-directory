 shows current C3 AI role and recruiter recommendations.'\n      }\n    ]\n  },\n  C0685: {\n    description: 'Domo delivers a cloud data and AI platform for integrating data, building analytics apps, visualizing metrics, and operationalizing business intelligence workflows.',\n    hq_location: 'American Fork, UT',\n    careers_url: 'https://www.domo.com/company/careers',\n    linkedin_url_verified: true,\n    recruiters: [\n      {\n        name: 'Sheridan Christensen',\n        title: 'Senior Corporate Recruiter',\n        linkedin_url: 'https://www.linkedin.com/in/sheridan-christensen-65306a83',\n        email: '',\n        location: 'United States',\n        focus_area: 'Corporate recruiting and AI consultant hiring',\n        connected: false,\n        messaged: false,\n        responded: false,\n        date_contacted: '',\n        notes: 'Public LinkedIn profile shows Domo recruiting work and recent posts for AI Consultant hiring.'\n      },\n      {\n        name: 'Jon Cluff',\n        title: 'Director, Talent Acquisition',\n        linkedin_url: '',\n        email: '',\n        location: 'American Fork, UT',\n        focus_area: 'Talent acquisition leadership at Domo',\n        connected: false,\n        messaged: false,\n        responded: false,\n        date_contacted: '',\n        notes: 'Public The Org and SignalHire profiles list Jon Cluff as Domo Director, Talent Acquisition.'\n      }\n    ]\n  }\n};\n\nconst byId = new Map(data.companies.map((company) => [company.id, company]));\nfor (const [id, patch] of Object.entries(updates)) {\n  const company = byId.get(id);\n  if (\"'!company) throw new Error(`Missing company ${id}`);\n  if ((company.recruiters || []).length) throw new Error(`Company ${id} already has recruiters; aborting to avoid overwrite`);\n  company.description = patch.description;\n  company.hq_location = patch.hq_location;\n  company.careers_url = patch.careers_url;\n  company.linkedin_url_verified = patch.linkedin_url_verified;\n  company.recruiters = patch.recruiters;\n}\n\nfs.writeFileSync(path, JSON.stringify(data, null, 2) + '\"'\\\\n');\nNODE\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
