{"type":"item.started","item":{"id":"item_24","type":"command_execution","command":"/bin/zsh -lc \"node <<'NODE'\nconst fs = require('fs');\nconst file = 'job/sectors/recruiter-insurance.json';\nconst data = JSON.parse(fs.readFileSync(file, 'utf8'));\n\nconst descriptions = new Map([\n  ['C0258', 'Oscar Health offers individual, family, small business, and Medicare Advantage health plans built around a full-stack technology platform for member navigation and care access.'],\n  ['C0324', 'UnitedHealth Group combines UnitedHealthcare insurance benefits with Optum health services, pharmacy, care delivery, data, and technology businesses serving patients and employers globally.'],\n  ['C0325', \\\"Optum is UnitedHealth Group's health services arm, connecting care delivery, pharmacy benefits, analytics, and technology platforms for providers, payers, employers, and patients.\\\"],\n  ['C0326', 'Elevance Health operates health benefits brands and Carelon services, using clinical, behavioral, pharmacy, digital, and complex-care capabilities to support whole-health coverage.'],\n  ['C0327', 'The Cigna Group provides global health benefits through Cigna Healthcare and Evernorth services spanning medical, pharmacy, behavioral, dental, and care management solutions.'],\n  ['C0328', 'Humana provides health insurance and healthcare services, with a major focus on Medicare Advantage, primary care, pharmacy, home health, and value-based care programs.'],\n  ['C0329', 'Centene is a managed care company focused on government-sponsored healthcare, serving Medicaid, Medicare, and Marketplace members through health plans and specialty services.'],\n  ['C0330', 'Molina Healthcare provides managed health plans for Medicaid, Medicare, and Health Insurance Marketplace members, with operations centered on government-sponsored coverage programs.'],\n  ['C0331', 'CVS Health combines retail pharmacies, CVS Caremark pharmacy benefits, Aetna health plans, and care delivery services to build consumer-oriented healthcare access.'],\n  ['C0332', 'Aetna, a CVS Health company, offers health insurance and benefits products across medical, dental, pharmacy, behavioral health, Medicare, and employer-sponsored coverage.'],\n  ['C0333', 'Kaiser Permanente is an integrated nonprofit care and coverage system combining health plans, hospitals, pharmacies, and multispecialty medical groups for members.'],\n  ['C0334', 'Anthem Blue Cross and Blue Shield is an Elevance Health insurance brand offering medical, pharmacy, dental, vision, and community health plan coverage.'],\n  ['C0335', 'Progressive is a major U.S. property and casualty insurer best known for auto coverage, usage-based pricing tools, bundled products, and digital claims support.'],\n  ['C0336', 'GEICO, a Berkshire Hathaway insurer, sells auto and related personal insurance directly to consumers through digital channels, phone support, and local offices.']\n]);\n\nconst oscarRecruiters = [\n  {\n    name: 'Stan Gasiewski',\n    title: 'Senior Manager, Technical Recruiting',\n    linkedin_url: 'https://www.linkedin.com/in/stanleycgasiewski',\n    email: '',\n    location: 'New York City Metropolitan Area, United States',\n    focus_area: 'Engineering / Software Engineering Technical Recruiting',\n    connected: false,\n    messaged: false,\n    responded: false,\n    date_contacted: '',\n    notes: \\\"Public LinkedIn and The Org profiles identify him as Oscar Health's Senior Manager, Technical Recruiting leading engineering recruiting.\\\"\n  },\n  {\n    name: 'Derek Marchand',\n    title: 'Senior Technical Recruiter',\n    linkedin_url: 'https://www.linkedin.com/in/derek-marchand',\n    email: '',\n    location: 'Greater Boston, MA, United States',\n    focus_area: 'Technical Recruiting / Product and Engineering Hiring',\n    connected: false,\n    messaged: false,\n    responded: false,\n    date_contacted: '',\n    notes: 'LinkedIn profile shows Oscar Health, and The Org lists him under Oscar Health talent acquisition as Senior Technical Recruiter.'\n  },\n  {\n    name: 'Vanessa Lo',\n    title: 'Sr. Technical Recruiter',\n    linkedin_url: 'https://www.linkedin.com/in/vanessabuilo',\n    email: '',\n    location: 'Los Angeles Metropolitan Area, United States',\n    focus_area: 'Technical Recruiting / Software and Product Hiring',\n    connected: false,\n    messaged: false,\n    responded: false,\n    date_contacted: '',\n    notes: \\\"LinkedIn profile shows Oscar Health; The Org lists Vanessa Lo at Oscar Health's Playa Vista office as sr. technical recruiter.\\\"\n  }\n];\n\nlet touched = 0;\nfor (const company of data.companies || []) {\n  if (descriptions.has(company.id)) {\n    company.description = descriptions.get(company.id);\n    touched += 1;\n  }\n  if (company.id === 'C0258') {\n    company.recruiters = company.recruiters || [];\n    const existingNames = new Set(company.recruiters.map(r => String(r.name || '').trim().toLowerCase()).filter(Boolean));\n    const existingUrls = new Set(company.recruiters.map(r => String(r.linkedin_url || '').trim().toLowerCase()).filter(Boolean));\n    for (const recruiter of oscarRecruiters) {\n      const nameKey = recruiter.name.toLowerCase();\n      const urlKey = recruiter.linkedin_url.toLowerCase();\n      if (\"'!existingNames.has(nameKey) && !existingUrls.has(urlKey) && company.recruiters.length < 10) {\n        company.recruiters.push(recruiter);\n        existingNames.add(nameKey);\n        existingUrls.add(urlKey);\n      }\n    }\n  }\n}\n\nif (touched !== descriptions.size) {\n  throw new Error(`Expected to touch ${descriptions.size} descriptions, touched ${touched}`);\n}\n\nfs.writeFileSync(file, JSON.stringify(data, null, 2) + '\"'\\\\n');\nNODE\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
