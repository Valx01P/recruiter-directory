notes\\\\\\\": \\\\\\\"\\\\\\\"\\\\n    },\\\\n    \\\\\\\"company_field_legend\\\\\\\": {\\\\n      \\\\\\\"name\\\\\\\": \\\\\\\"Company name\\\\\\\",\\\\n      \\\\\\\"category\\\\\\\": \\\\\\\"Primary tech sector\\\\\\\",\\\\n      \\\\\\\"hq_location\\\\\\\": \\\\\\\"US headquarters\\\\\\\",\\\\n      \\\\\\\"linkedin_company_url\\\\\\\": \\\\\\\"Company LinkedIn page. Curated entries are hand-verified; bulk entries are auto-derived from the name.\\\\\\\",\\\\n      \\\\\\\"careers_url\\\\\\\": \\\\\\\"Internship / careers landing page (fill later)\\\\\\\",\\\\n      \\\\\\\"size_estimate\\\\\\\": \\\\\\\"Rough US/global headcount band\\\\\\\",\\\\n      \\\\\\\"has_intern_program\\\\\\\": \\\\\\\"Known to run structured internships\\\\\\\",\\\\n      \\\\\\\"priority\\\\\\\": \\\\\\\"1 = top target, 2 = strong, 3 = stretch/large-but-niche\\\\\\\",\\\\n      \\\\\\\"recruiters\\\\\\\": \\\\\\\"Array of recruiter objects (populate later)\\\\\\\",\\\\n      \\\\\\\"recruiter_search_url\\\\\\\": \\\\\\\"LinkedIn People-tab link filtered to recruiters at this company (open & harvest profiles)\\\\\\\",\\\\n      \\\\\\\"id\\\\\\\": \\\\\\\"Unique sequential ID (C0001...) for counting & tracking\\\\\\\",\\\\n      \\\\\\\"linkedin_url_verified\\\\\\\": \\\\\\\"true = hand-verified slug; false = auto-derived from name (may 404 / hit wrong page — spot-check before trusting)\\\\\\\",\\\\n      \\\\\\\"sector\\\\\\\": \\\\\\\"Primary sector partition key used by Codex sector workers and UI filtering\\\\\\\",\\\\n      \\\\\\\"description\\\\\\\": \\\\\\\"Concise company description for search, semantic matching, and outreach context\\\\\\\"\\\\n    },\\\\n    \\\\\\\"recruiter_links_note\\\\\\\": \\\\\\\"recruiter_search_url is a name-based LinkedIn People search ('<company> recruiter') that works for every company without needing the exact company page slug — open it to see current recruiters, then paste individual profile URLs into recruiters[]. Each company has a unique 'id' (C0001...) so the list is countable/verifiable. NOTE: the first ~263 entries are curated with HQ/size/company-slug; the bulk entries carry verified real names + working recruiter links, with HQ/slug left blank to enrich.\\\\\\\",\\\\n    \\\\\\\"total_companies\\\\\\\": 73,\\\\n    \\\\\\\"notes\\\\\\\": \\\\\\\"Sector working file for Gaming / Media. Codex agents edit only this file; the orchestrator merges sector files back into canonical recruiter.json.\\\\\\\",\\\\n    \\\\\\\"ui_directory\\\\\\\": \\\\\\\"recruiter-directory/ (Next.js searchable UI with direct LinkedIn links + CSV export)\\\\\\\",\\\\n    \\\\\\\"population_progress\\\\\\\": \\\\\\\"Codex sector split. 873 companies populated with 1937 total recruiters; 1250 company descriptions missing. Merge run: 2026-06-01\\\\\\\",\\\\n    \\\\\\\"partition_type\\\\\\\": \\\\\\\"sector\\\\\\\",\\\\n    \\\\\\\"sector\\\\\\\": {\\\\n      \\\\\\\"key\\\\\\\": \\\\\\\"media\\\\\\\",\\\\n      \\\\\\\"label\\\\\\\": \\\\\\\"Gaming / Media\\\\\\\"\\\\n    },\\\\n    \\\\\\\"source_file\\\\\\\": \\\\\\\"job/recruiter.json\\\\\\\",\\\\n    \\\\\\\"last_partition_build\\\\\\\": \\\\\\\"2026-06-01T00:45:06.195Z\\\\\\\"\\\\n  },\\\\n  \\\\\\\"companies\\\\\\\": [\\\\n    {\\\\n      \\\\\\\"id\\\\\\\": \\\\\\\"C0064\\\\\\\",\\\\n      \\\\\\\"name\\\\\\\": \\\\\\\"Pinterest\\\\\\\",\\\\n      \\\\\\\"category\\\\\\\": \\\\\\\"Internet / Social\\\\\\\",\\\\n      \\\\\\\"sector\\\\\\\": \\\\\\\"media\\\\\\\",\\\\n      \\\\\\\"description\\\\\\\": \\\\\\\"\\\\\\\",\\\\n      \\\\\\\"hq_location\\\\\\\": \\\\\\\"San Francisco, CA\\\\\\\",\\\\n      \\\\\\\"priority\\\\\\\": 2,\\\\n      \\\\\\\"size_estimate\\\\\\\": \\\\\\\"4k+\\\\\\\",\\\\n      \\\\\\\"has_intern_program\\\\\\\": true,\\\\n      \\\\\\\"linkedin_company_url\\\\\\\": \\\\\\\"https://www.linkedin.com/company/pinterest/\\\\\\\",\\\\n      \\\\\\\"linkedin_url_verified\\\\\\\": true,\\\\n      \\\\\\\"recruiter_search_url\\\\\\\": \\\\\\\"https: