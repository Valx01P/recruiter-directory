{"type":"item.started","item":{"id":"item_31","type":"command_execution","command":"/bin/zsh -lc \"node - <<'NODE'\nconst fs = require('fs');\nconst path = 'job/sectors/recruiter-cloud.json';\nconst data = JSON.parse(fs.readFileSync(path, 'utf8'));\n\nconst contact = (name, title, linkedin_url, location, focus_area, notes) => ({\n  name,\n  title,\n  linkedin_url,\n  email: '',\n  location,\n  focus_area,\n  connected: false,\n  messaged: false,\n  responded: false,\n  date_contacted: '',\n  notes\n});\n\nconst updates = {\n  C0574: {\n    description: 'Expensify provides expense management, corporate cards, travel booking, invoicing, bill pay, and reimbursement software for businesses and distributed teams.',\n    hq_location: 'San Francisco, CA',\n    size_estimate: '51-200 employees',\n    careers_url: 'https://we.are.expensify.com/careers',\n    recruiters: [\n      contact(\n        'Adele Kennedy',\n        'People Operations Generalist',\n        'https://www.linkedin.com/in/adele-kennedy-083346145',\n        'Portland, OR',\n        'People operations, recruiting process, and software/SRE hiring',\n        'Public LinkedIn profile lists current Expensify experience; Recruitment.com identifies her as People Operations Generalist and part of Expensify recruiting/hiring team.'\n      )\n    ]\n  },\n  C0582: {\n    description: 'DocuWare delivers cloud and on-premises document management, content services, workflow automation, OCR, and process digitization software for midsize and enterprise organizations.',\n    hq_location: 'Germering, Germany; Beacon, NY',\n    size_estimate: '501-1,000 employees',\n    careers_url: 'https://careers.docuware.com/',\n    recruiters: [\n      contact(\n        'Patricia Nigemeier',\n        'Recruiting & Employer Branding',\n        'https://de.linkedin.com/in/patricia-nigemeier/en',\n        'Germering, Germany',\n        'Recruiting, employer branding, internships, and early-career programs',\n        'DocuWare careers page lists Patricia on the recruiting team; LinkedIn profile shows Recruiting & Employer Branding Specialist at DocuWare.'\n      )\n    ]\n  },\n  C0600: {\n    description: 'Customer.io provides a data-driven customer engagement platform for email, push, SMS, in-app messages, webhooks, audience segmentation, and lifecycle marketing automation.',\n    hq_location: 'Portland, OR',\n    size_estimate: '201-500 employees',\n    careers_url: 'https://customer.io/careers/',\n    recruiters: [\n      contact(\n        'Nick Cortesi',\n        'Director, Talent Acquisition',\n        'https://www.linkedin.com/in/nickcortesi',\n        'Nashville Metropolitan Area',\n        'Talent acquisition leadership and recruiting operations',\n        'Customer.io Lead Recruiter posting names Nick as Director, Talent Acquisition; LinkedIn profile lists Customer.io experience.'\n      )\n    ]\n  },\n  C0601: {\n    description: 'Iterable is a cross-channel customer engagement platform that helps marketers create, personalize, test, and measure customer journeys across email, mobile, web, and messaging.',\n    hq_location: 'San Francisco, CA',\n    size_estimate: '501-1,000 employees',\n    careers_url: 'https://iterable.com/careers/',\n    recruiters: [\n      contact(\n        'Laura Goodrich',\n        'Senior Global Talent Partner',\n        'https://www.linkedin.com/in/laura-goodrich-2b9974a',\n        'Park City, UT',\n        'Global talent partner for recruiting and specialized hiring',\n        'The Org lists Laura as Senior Global Talent Partner at Iterable; LinkedIn profile shows current Iterable experience and recruiting recommendations.'\n      )\n    ]\n  },\n  C0602: {\n    description: 'MoEngage provides an insights-led customer engagement platform for marketers and product teams to analyze behavior and orchestrate personalized campaigns across digital channels.',\n    hq_location: 'San Francisco, CA',\n    size_estimate: '501-1,000 employees',\n    careers_url: 'https://www.moengage.com/careers/',\n    recruiters: [\n      contact(\n        'Mohammed Ismail',\n        'Global Talent Acquisition & HR Leader',\n        'https://www.linkedin.com/in/mohammed-ismail-746218210',\n        'San Francisco, CA',\n        'Global talent acquisition and HR leadership for MoEngage hiring',\n        'Public LinkedIn profile lists MoEngage experience and describes global talent acquisition and HR leadership; profile location is San Francisco.'\n      )\n    ]\n  },\n  C0605: {\n    description: 'Mixpanel provides AI-first product analytics that help product, growth, and engineering teams understand adoption, retention, experimentation, and user behavior.',\n    hq_location: 'San Francisco, CA',\n    size_estimate: '201-500 employees',\n    careers_url: 'https://mixpanel.com/jobs/',\n    recruiters: [\n      contact(\n        'Connor Fehmel',\n        'Principal Technical Recruiter',\n        'https://www.linkedin.com/in/epd-talent-solutions',\n        'Los Angeles Metropolitan Area',\n        'Product, design, and engineering recruiting',\n        'Recent Mixpanel LinkedIn job posting identifies Connor as Principal Technical Recruiter; The Org lists him in HR/recruitment for product, design, and engineering.'\n      )\n    ]\n  },\n  C0607: {\n    description: 'PostHog builds an open-source product analytics platform with feature flags, session replay, experiments, surveys, data warehouse tools, and AI-assisted product workflows.',\n    hq_location: 'San Francisco, CA',\n    size_estimate: '51-200 employees',\n    careers_url: 'https://posthog.com/careers',\n    recruiters: [\n      contact(\n        'Yari Garcia',\n        'Senior Talent Partner',\n        'https://www.linkedin.com/in/yari-garcia',\n        'New York, NY',\n        'Talent acquisition, talent brand, people, and DEI',\n        'Public LinkedIn profile lists current PostHog experience and talent acquisition focus; GTMWiki identifies Yari as Senior Talent Partner joining PostHog in 