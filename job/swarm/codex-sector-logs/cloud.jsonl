{"type":"item.started","item":{"id":"item_25","type":"command_execution","command":"/bin/zsh -lc \"node <<'NODE'\nconst fs = require('fs');\nconst path = 'job/sectors/recruiter-cloud.json';\nconst data = JSON.parse(fs.readFileSync(path, 'utf8'));\n\nconst recruiter = ({ name, title, linkedin_url, location, focus_area, notes }) => ({\n  name,\n  title,\n  linkedin_url,\n  email: '',\n  location,\n  focus_area,\n  connected: false,\n  messaged: false,\n  responded: false,\n  date_contacted: '',\n  notes\n});\n\nconst updates = {\n  C0546: {\n    description: 'Vonage provides cloud communications APIs, unified communications, and contact center software that help enterprises embed voice, messaging, video, authentication, and AI-enabled customer engagement.',\n    hq_location: 'Holmdel, NJ',\n    careers_url: 'https://www.vonage.com/careers/',\n    recruiters: [\n      recruiter({\n        name: 'Haven B.',\n        title: 'Talent Acquisition Partner',\n        linkedin_url: 'https://www.linkedin.com/in/havenboaz',\n        location: 'United States',\n        focus_area: 'Talent Acquisition / US and Mexico hiring',\n        notes: 'Public LinkedIn profile lists current Talent Acquisition Partner at Vonage filling open US, Mexico, and related roles.'\n      }),\n      recruiter({\n        name: 'Akash Pradhan',\n        title: 'Global Technical Talent Acquisition Partner',\n        linkedin_url: 'https://in.linkedin.com/in/akash-pradhan-22a512119',\n        location: 'Bengaluru, Karnataka, India',\n        focus_area: 'Technical recruiting / engineering apprenticeships',\n        notes: 'Public LinkedIn profile describes global technical talent acquisition at Vonage and shows 2026 engineering apprentice hiring activity.'\n      })\n    ]\n  },\n  C0547: {\n    description: 'LivePerson builds conversational AI and messaging software that lets enterprises automate customer service, route conversations, and analyze brand-consumer interactions across digital channels.',\n    hq_location: 'New York, NY',\n    careers_url: 'https://www.liveperson.com/company/careers/',\n    recruiters: [\n      recruiter({\n        name: 'Courtney Rivera',\n        title: 'Recruiter at LivePerson',\n        linkedin_url: 'https://www.linkedin.com/in/courtney-rivera-a4775016a',\n        location: 'Greater Boston',\n        focus_area: 'International talent acquisition / AI and engineering hiring',\n        notes: 'Public LinkedIn profile and LivePerson job postings identify Courtney as a Recruiter at LivePerson; activity includes engineering architect hiring.'\n      })\n    ]\n  },\n  C0548: {\n    description: 'Zendesk provides customer service software and AI tools for support, employee service, ticketing, messaging, knowledge management, and customer experience operations.',\n    hq_location: 'San Francisco, CA',\n    careers_url: 'https://www.zendesk.com/jobs/',\n    recruiters: [\n      recruiter({\n        name: 'Buddy Johnson',\n        title: 'Senior AI Technical Sourcer',\n        linkedin_url: 'https://www.linkedin.com/in/buddyj',\n        location: 'Austin, TX',\n        focus_area: 'AI technical sourcing / engineering talent',\n        notes: 'Public LinkedIn profile lists Zendesk experience and senior-level AI technical sourcing with recruiting project background.'\n      })\n    ]\n  },\n  C0549: {\n    description: 'Freshworks builds cloud software for customer service, IT service management, CRM, and sales engagement, with AI features aimed at simpler business operations.',\n    hq_location: 'San Mateo, CA',\n    careers_url: 'https://www.freshworks.com/company/careers/',\n    recruiters: [\n      recruiter({\n        name: 'Alli Wojchik',\n        title: 'Senior Recruiter',\n        linkedin_url: 'https://www.linkedin.com/in/alli-wojchik',\n        location: 'Madison, WI',\n        focus_area: 'SaaS recruiting / technology hiring',\n        notes: 'Public LinkedIn profile lists Freshworks experience and describes senior recruiting experience supporting high-growth SaaS and technology teams.'\n      }),\n      recruiter({\n        name: 'Sahana Venkataraman',\n        title: 'Talent Acquisition Professional',\n        linkedin_url: 'https://in.linkedin.com/in/sahanavenk',\n        location: 'Chennai, Tamil Nadu, India',\n        focus_area: 'GTM recruiting / sales, customer success, and solution engineering',\n        notes: 'Public LinkedIn profile lists Freshworks; recommendation references recruiting across sales, customer success, solution engineering, and GTM functions.'\n      })\n    ]\n  },\n  C0550: {\n    description: 'HubSpot offers an AI-powered customer platform combining CRM, marketing, sales, service, content, and operations tools for growing businesses.',\n    hq_location: 'Cambridge, MA',\n    careers_url: 'https://www.hubspot.com/careers',\n    recruiters: [\n      recruiter({\n        name: 'Linda Huard',\n        title: 'Full-Cycle Technical Recruiter',\n        linkedin_url: 'https://www.linkedin.com/in/lindaannhuard',\n        location: 'Greater Boston',\n        focus_area: 'Technical recruiting / security and engineering hiring',\n        notes: 'Public LinkedIn profile lists HubSpot and full-cycle technical recruiting; recent activity promotes principal software engineering security roles.'\n      }),\n      recruiter({\n        name: 'Annemarie DeSmet',\n        title: 'Full-Cycle Technical Recruiter',\n        linkedin_url: 'https://www.linkedin.com/in/annemarie-desmet-9059aa25',\n        location: 'Greater Boston',\n        focus_area: 'Product and engineering recruiting',\n        notes: 'Public LinkedIn profile says she is a full-cycle Technical Recruiter at HubSpot supporting global Product roles.'\n      }),\n      recruiter({\n        name: 'Bethany Allen',\n        title: 'Senior Technical Recruiter',\n        linkedin_url: 'https://www.linkedin.com/in/bethanyg-allen',\n        location: 'Austin, TX',\n        focus_area: 'Engineering and technical recruiting',\n        notes: 'Public LinkedIn profile lists Senior Technical Recruiter at HubSpot focused on connecting engineering and technical talent.'\n      })\n    ]\n  },\n  C0551: {\n    description: 'Klaviyo provides a B2C CRM and AI marketing platform that unifies customer data with email, SMS, analytics, service, and omnichannel automation.',\n    hq_location: 'Boston, MA',\n    careers_url: 'https://www.klaviyo.com/careers',\n    recruiters: [\n      recruiter({\n        name: 'Doug Hamilton, MBA',\n        title: 'Senior Technical Recruiter',\n        linkedin_url: 'https://www.linkedin.com/in/hamiltondoug',\n        location: 'Boston, MA',\n        focus_area: 'Technical recruiting / security engineering',\n        notes: 'Public LinkedIn profile lists Senior Technical Recruiter at Klaviyo; LinkedIn job posting shows him recruiting for security engineering.'\n      }),\n      recruiter({\n        name: 'Shawn Lugdon',\n        title: 'Technical Talent Acquisition Partner',\n        linkedin_url: 'https://www.linkedin.com/in/shawnlugdon',\n        location: 'Newburyport, MA',\n        focus_area: 'Technical recruiting / AI and engineering hiring',\n        notes: 'Public LinkedIn profile lists Klaviyo and technical talent acquisition; recent activity promotes Klaviyo AI and engineering hiring.'\n      }),\n      recruiter({\n        name: 'Reggie Smith',\n        title: 'Technical Recruiter',\n        linkedin_url: 'https://www.linkedin.com/in/smithreggie',\n        location: 'El Dorado Hills, CA',\n        focus_area: 'AI/ML, distributed systems, and data infrastructure hiring',\n        notes: 'Public LinkedIn profile lists Klaviyo and technical recruiting; activity promotes Klaviyo data infrastructure and engineering roles.'\n      })\n    ]\n  },\n  C0552: {\n    description: 'Braze builds a customer engagement platform for cross-channel messaging, journey orchestration, first-party data activation, and AI-powered personalization across consumer brands.',\n    hq_location: 'New York, NY',\n    careers_url: 'https://www.braze.com/careers',\n    recruiters: [\n      recruiter({\n        name: 'Alec Argento',\n        title: 'Sr. Manager, Technical Talent Acquisition',\n        linkedin_url: 'https://www.linkedin.com/in/alec-argento-89105497',\n        location: 'Hoboken, NJ',\n        focus_area: 'Product, design, and engineering recruiting',\n        notes: 'Public LinkedIn profile lists Braze and Sr. Manager of Technical Talent Acquisition responsible for technical hiring teams.'\n      }),\n      recruiter({\n        name: 'Brian Scannell',\n        title: 'North American GTM Talent Acquisition Lead',\n        linkedin_url: 'https://www.linkedin.com/in/brian-scannell-a618a078',\n        location: 'Greater Chicago Area',\n        focus_area: 'North America GTM talent acquisition',\n        notes: 'Public LinkedIn profile lists Braze and states he helps lead North American GTM Talent Acquisition; activity includes Braze TA hiring.'\n      })\n    ]\n  },\n  C0553: {\n    description: 'Sprout Social provides social media management and analytics software for publishing, engagement, customer care, influencer marketing, and AI-powered social intelligence.',\n    hq_location: 'Chicago, IL',\n    careers_url: 'https://sproutsocial.com/careers/',\n    recruiters: [\n      recruiter({\n        name: 'Nikki Casper',\n        title: 'Senior Technical Recruiter',\n        linkedin_url: 'https://www.linkedin.com/in/nikki-casper',\n        location: 'Boston, MA',\n        focus_area: 'Engineering, product, and data recruiting',\n        notes: 'Public LinkedIn profile lists Sprout Social and senior technical recruiting for engineering, product, and related technology roles.'\n      }),\n      recruiter({\n        name: 'Rejoice Adebola Folashade',\n        title: 'Senior Talent Acquisition Partner',\n        linkedin_url: 'https://ie.linkedin.com/in/rejoiceafolashade',\n        location: 'Ireland',\n        focus_area: 'Global talent acquisition / GTM and support hiring',\n        notes: 'Public LinkedIn profile lists Sprout Social; LinkedIn job postings identify Rejoice as Senior Talent Acquisition Partner at Sprout Social.'\n      }),\n      recruiter({\n        name: 'Klaudia Kordzikowska',\n        title: 'Technical Recruiter',\n        linkedin_url: '',\n        location: 'Krakow, Poland',\n        focus_area: 'Engineering recruiting',\n        notes: 'Public LinkedIn job posting identifies Klaudia as Technical Recruiter at Sprout Social for a senior engineering manager role.'\n      })\n    ]\n  }\n};\n\nconst byId = new Map(data.companies.map((company) => [company.id, company]));\nfor (const [id, update] of Object.entries(updates)) {\n  const company = byId.get(id);\n  if (\"'!company) throw new Error(`Missing company ${id}`);\n  company.description = update.description;\n  company.hq_location = update.hq_location;\n  company.careers_url = update.careers_url;\n  const existing = new Set((company.recruiters || []).map((r) => `${(r.name || '\"'').toLowerCase()}|\"'${(r.linkedin_url || '\"'').toLowerCase()}\"'`));\n  company.recruiters = company.recruiters || [];\n  for (const person of update.recruiters) {\n    const key = `${person.name.toLowerCase()}|${person.linkedin_url.toLowerCase()}`;\n    if (!existing.has(key) && company.recruiters.length < 10) {\n      company.recruiters.push(person);\n      existing.add(key);\n    }\n  }\n}\n\nfs.writeFileSync(path, `${JSON.stringify(data, null, 2)}'\"\\\\n\"'`);\nNODE'","aggregated_output":"","exit_code":null,"status":"in_progress"}}
