{"type":"item.started","item":{"id":"item_24","type":"command_execution","command":"/bin/zsh -lc \"node <<'NODE'\nconst fs = require('fs');\nconst path = 'job/sectors/recruiter-cloud.json';\nconst data = JSON.parse(fs.readFileSync(path, 'utf8'));\n\nconst byId = new Map((data.companies || []).map((c) => [c.id, c]));\nconst contact = (name, title, linkedin_url, location, focus_area, notes) => ({\n  name,\n  title,\n  linkedin_url,\n  email: '',\n  location,\n  focus_area,\n  connected: false,\n  messaged: false,\n  responded: false,\n  date_contacted: '',\n  notes\n});\n\nconst updates = {\n  C0558: {\n    description: 'Momentive, associated with SurveyMonkey, provides survey, feedback, and experience-management software that helps organizations collect customer, employee, and market insights.',\n    hq_location: 'San Mateo, CA',\n    recruiters: [\n      contact('Julia Jacques', 'Senior Executive Recruiter', 'https://www.linkedin.com/in/jacquesjulia', 'Portland, OR, United States', 'Executive recruiting and talent acquisition for SurveyMonkey/Momentive', 'Public LinkedIn profile lists Senior Executive Recruiter at SurveyMonkey and references Momentive/SurveyMonkey recruiting experience.')\n    ]\n  },\n  C0576: {\n    description: 'Airbase provides spend management software for procurement, bill payments, corporate cards, and accounting workflows, now integrated into Paylocity finance offerings.',\n    hq_location: 'San Francisco, CA',\n    recruiters: [\n      contact('Suzanna Stanley', 'Airbase Recruiter', '', 'India', 'Technical and product recruiting for Airbase/Paylocity transition roles', 'Public LinkedIn job posts and Paylocity transition posts identify Suzanna Stanley as an Airbase recruiter and job poster for engineering roles.')\n    ]\n  },\n  C0589: {\n    description: 'Procore builds cloud construction management software connecting owners, contractors, and project teams across bidding, financials, field execution, and project analytics.',\n    hq_location: 'Carpinteria, CA',\n    linkedin_company_url: 'https://www.linkedin.com/company/procore-technologies/',\n    linkedin_url_verified: true,\n    recruiters: [\n      contact('Lindsey Zuzich', 'Senior Recruiter', 'https://www.linkedin.com/in/lindsey-zuzich-0a991088', 'Del Rio, TX, United States', 'Recruiting for Procore teams', 'Public LinkedIn profile lists Lindsey Zuzich as a strategic Senior Recruiter with Procore Technologies.'),\n      contact('Danny Rowley', 'Staff Recruiter', 'https://www.linkedin.com/in/danny-rowley-27147914a', 'Denver, CO, United States', 'Recruiting and staff-level talent acquisition', 'Public LinkedIn profile activity states promotion to Staff Recruiter at Procore Technologies.')\n    ]\n  },\n  C0590: {\n    description: 'Buildertrend offers residential construction management software for home builders, remodelers, and contractors to manage schedules, budgets, clients, documents, and payments.',\n    hq_location: 'Omaha, NE',\n    recruiters: [\n      contact('Haley Ramm', 'Talent Acquisition Specialist II', 'https://www.linkedin.com/in/haleyramm', 'Omaha, NE, United States', 'Talent acquisition coordination and recruiting for Buildertrend', 'Public LinkedIn and The Org profiles identify Haley Ramm on Buildertrend talent acquisition.'),\n      contact('Brandy Menaugh', 'Vice President of People', '', 'Omaha, NE, United States', 'People leadership, recruiting organization, and workforce programs', 'The Org and Buildertrend public pages list Brandy Menaugh as VP of People responsible for talent, engagement, and people programs.')\n    ]\n  },\n  C0592: {\n    description: 'Squarespace provides website building, domains, ecommerce, scheduling, and marketing tools for entrepreneurs and businesses managing their online presence.',\n    hq_location: 'New York, NY',\n    recruiters: [\n      contact('Erin Campagna', 'Talent Acquisition Partner', 'https://www.linkedin.com/in/erin-campagna', 'Brooklyn, NY, United States', 'Talent acquisition partnership for Squarespace hiring', 'Public LinkedIn profile and post state Erin joined Squarespace as a Talent Acquisition Partner in New York City.'),\n      contact('Carly Brown', 'Talent Acquisition Partner - Engineering', 'https://www.linkedin.com/in/carly-brown-recruiter', 'New York City Metropolitan Area', 'Engineering recruiting and product/technical hiring', 'Public LinkedIn profile lists Carly Brown at Squarespace and states a Talent Acquisition Partner - Engineering role.')\n    ]\n  },\n  C0593: {\n    description: 'Wix offers cloud-based website creation, ecommerce, business-management, and AI site-building tools for independent creators, agencies, and small businesses.',\n    hq_location: 'New York, NY',\n    linkedin_company_url: 'https://www.linkedin.com/company/wix-com/',\n    linkedin_url_verified: true,\n    recruiters: [\n      contact('Anthony Rodriguez', 'Head of Talent Acquisition - US, Canada and Global GTM', '', 'Miami, FL, United States', 'US, Canada, and global go-to-market talent acquisition', 'The Org profile lists Anthony Rodriguez as Wix Head of Talent Acquisition for the US, Canada, and Global GTM.'),\n      contact('Caitlin Carr', 'Senior Recruiter', 'https://www.linkedin.com/in/caitlin-carr-83332834', 'New York City Metropolitan Area', 'Wix.com talent acquisition for New York and Miami roles', 'Public LinkedIn profile lists Caitlin Carr at Wix.com and posts about Wix Talent Acquisition hiring in New York and Miami.')\n    ]\n  },\n  C0594: {\n    description: 'GoDaddy provides domain registration, hosting, commerce, payments, and website tools used by small businesses to launch and manage online operations.',\n    hq_location: 'Tempe, AZ',\n    recruiters: [\n      contact('Suzeth C.', 'University Recruiter', 'https://www.linkedin.com/in/suzethc', 'Phoenix, AZ, United States', 'University recruiting and early-career hiring', 'Public LinkedIn profile lists Suzeth C. as a GoDaddy University Recruiter helping college students start careers.'),\n      contact('Mohit Verma', 'Technical Recruiter', 'https://in.linkedin.com/in/vmohit', 'Gurugram, Haryana, India', 'Technical recruiting for software engineering and machine learning roles', 'Public LinkedIn profile lists Mohit Verma as a Technical Recruiter at GoDaddy and shows engineering hiring activity.')\n    ]\n  },\n  C0596: {\n    description: 'Mailchimp, part of Intuit, offers marketing automation, email, SMS, CRM, analytics, and ecommerce campaign tools for small and mid-market businesses.',\n    hq_location: 'Atlanta, GA',\n    linkedin_company_url: 'https://www.linkedin.com/company/intuitmailchimp/',\n    linkedin_url_verified: true,\n    recruiters: [\n      contact('Justina Kelly', 'Senior Recruiter - GTM Sales, Risk Operations and Corporate Functions', 'https://www.linkedin.com/in/jskelly105', 'Atlanta, GA, United States', 'Intuit and Mailchimp GTM/corporate recruiting', 'Public LinkedIn profile lists Justina Kelly as a Senior Recruiter at Intuit and shows Mailchimp hiring partnership activity.'),\n      contact('Laura Hostetler', 'Talent Acquisition Leader', 'https://www.linkedin.com/in/laura-hostetler-06322435', 'Atlanta, GA, United States', 'Mailchimp and Intuit technical recruiting leadership', 'Public LinkedIn profile lists Laura Hostetler at Intuit; public post recruited a senior technical recruiter for Intuit Mailchimp in Atlanta.')\n    ]\n  },\n  C0597: {\n    description: 'Constant Contact provides email marketing, SMS, social, event, and automation tools that help small businesses and nonprofits manage digital customer engagement.',\n    hq_location: 'Waltham, MA',\n    recruiters: [\n      contact('Howie Kalman', 'Talent Acquisition Partner', 'https://www.linkedin.com/in/howiekalman', 'Nashua, NH, United States', 'Talent acquisition and recruiting for Constant Contact roles', 'Public LinkedIn profile lists Howie Kalman as a Talent Acquisition Partner at Constant Contact and reposts open roles.'),\n      contact('Christine Newton', 'Recruiter', 'https://www.linkedin.com/in/christine-newton-543252103', 'Greater Boston, United States', 'Recruiting and talent acquisition for Constant Contact', 'Public LinkedIn profile lists Christine Newton as a motivated recruiter at Constant Contact with active hiring-related posts.')\n    ]\n  }\n};\n\nlet touched = 0;\nlet added = 0;\nfor (const [id, update] of Object.entries(updates)) {\n  const company = byId.get(id);\n  if (\"'!company) throw new Error(`Missing company ${id}`);\n  touched += 1;\n  for (const key of ['\"'description', 'hq_location', 'linkedin_company_url', 'linkedin_url_verified']) {\n    if (Object.prototype.hasOwnProperty.call(update, key)) company[key] = update[key];\n  }\n  const existing = new Set((company.recruiters || []).map((r) => \"'`${(r.name || '\"'').toLowerCase()}|\"'${(r.linkedin_url || '\"'').toLowerCase()}\"'`));\n  company.recruiters = company.recruiters || [];\n  for (const rec of update.recruiters) {\n    const sig = `${rec.name.toLowerCase()}|${(rec.linkedin_url || '\"'').toLowerCase()}\"'`;\n    if (!existing.has(sig)) {\n      company.recruiters.push(rec);\n      existing.add(sig);\n      added += 1;\n    }\n  }\n}\n\nfs.writeFileSync(path, `${JSON.stringify(data, null, 2)}'\"\\\\n\"'`);\nconsole.log(`updated ${touched} companies, added ${added} recruiters`);\nNODE'","aggregated_output":"","exit_code":null,"status":"in_progress"}}
