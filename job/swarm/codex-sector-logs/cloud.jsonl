      'Recruiter',\n        'https://www.linkedin.com/in/alexander-hall-63690249',\n        'San Diego, CA',\n        'Recruiting and hiring operations for LogRocket growth roles',\n        'Public LinkedIn profile lists current LogRocket experience and recruiter background; LogRocket job listings show active recruiting across technical and GTM roles.'\n      )\n    ]\n  }\n};\n\nlet touched = 0;\nlet added = 0;\nfor (const [id, update] of Object.entries(updates)) {\n  const company = data.companies.find(c => c.id === id);\n  if (\"'!company) throw new Error(`Missing company ${id}`);\n  const existing = company.recruiters || [];\n  const existingKeys = new Set(existing.map(r => `${(r.name || '\"'').toLowerCase()}|\"'${(r.linkedin_url || '\"'').toLowerCase()}\"'`));\n  const newRecruiters = update.recruiters.filter(r => !existingKeys.has(`${r.name.toLowerCase()}|${r.linkedin_url.toLowerCase()}`));\n  if (newRecruiters.length) {\n    company.recruiters = [...existing, ...newRecruiters];\n    added += newRecruiters.length;\n  }\n  for (const key of ['\"'description', 'hq_location', 'size_estimate', 'careers_url']) {\n    if (update[key]) company[key] = update[key];\n  }\n  touched++;\n}\n\nfs.writeFileSync(path, JSON.stringify(data, null, 2) + '\\\\n');\nconsole.log(\"'`updated ${touched} companies, added ${added} recruiters`);\nNODE'","aggregated_output":"","exit_code":null,"status":"in_progress"}}
