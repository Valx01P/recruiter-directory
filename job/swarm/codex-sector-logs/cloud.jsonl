{"type":"item.started","item":{"id":"item_24","type":"command_execution","command":"/bin/zsh -lc \"node <<'NODE'\nconst fs = require('fs');\nconst path = 'job/sectors/recruiter-cloud.json';\nconst data = JSON.parse(fs.readFileSync(path, 'utf8'));\n\nfunction contact(name, title, linkedin_url, location, focus_area, notes) {\n  return {\n    name,\n    title,\n    linkedin_url,\n    email: '',\n    location,\n    focus_area,\n    connected: false,\n    messaged: false,\n    responded: false,\n    date_contacted: '',\n    notes\n  };\n}\n\nconst updates = {\n  C0598: {\n    description: \\\"Campaign Monitor is Marigold's email marketing platform for small businesses, nonprofits, and agencies, providing campaign design, automation, audience engagement, and marketing analytics tools.\\\",\n    recruiters: [\n      contact(\n        'Kourtney Young',\n        'Talent Acquisition Partner',\n        '',\n        'Beverly Hills, FL, United States',\n        'Talent Acquisition, Technical Recruiting, SaaS hiring',\n        'Public SignalHire profile lists Kourtney as Talent Acquisition Partner at Marigold since Oct 2024; Campaign Monitor is a Marigold product.'\n      ),\n      contact(\n        'Joe Biggert',\n        'Director of Engineering',\n        'https://www.linkedin.com/in/biggert',\n        'Nashville, TN, United States',\n        'Engineering hiring manager for Marigold / CM Group products',\n        'LinkedIn profile shows Director of Engineering at Marigold; prior public posts referenced CM Group and related product engineering hiring.'\n      )\n    ]\n  },\n  C0613: {\n    description: 'Wrike is a collaborative work management platform that helps teams plan projects, automate workflows, manage resources, and coordinate enterprise work across distributed organizations.',\n    recruiters: [\n      contact(\n        'Aleksandar Chernev',\n        'Senior Technical Recruiter with an AI Driven Approach',\n        'https://cz.linkedin.com/in/aleksandar-chernev-479785214',\n        'Prague, Czechia',\n        'Technical recruiting, backend engineering, product and platform roles',\n        'LinkedIn profile lists Senior Technical Recruiter at Wrike; current Wrike engineering job posts name Aleksandar as recruitment buddy.'\n      ),\n      contact(\n        'Ulviyya S. Cerna',\n        'Talent Acquisition',\n        'https://cz.linkedin.com/in/ulviyyasc/ru',\n        'Prague, Czechia',\n        'Talent acquisition for engineering, product design, IT, EMEA/APAC/US hiring',\n        'LinkedIn profile lists Talent Acquisition at Wrike, sourcing across IT, product design, engineering, and international teams.'\n      ),\n      contact(\n        'Aziza Talhi',\n        'Senior Go-To-Market Recruiter',\n        'https://cz.linkedin.com/in/azizatalhi',\n        'Prague, Czechia',\n        'GTM recruiting across EMEA and US SaaS teams',\n        'LinkedIn profile states Aziza is a senior GTM recruiter at Wrike partnering with leaders across Europe and the US.'\n      )\n    ]\n  },\n  C0614: {\n    description: 'Coda builds an all-in-one collaborative doc platform that combines documents, tables, automations, and AI-enabled workflows for teams managing structured work.',\n    recruiters: [\n      contact(\n        'Harry Dannenbaum',\n        'Head of Recruiting',\n        '',\n        'Palo Alto, CA, United States',\n        'Recruiting leadership, hiring process, talent acquisition strategy',\n        'Datapeople and The Official Board public pages list Harry as Head of Recruiting at Coda.'\n      ),\n      contact(\n        'Rosetta Phan',\n        'Recruiter / Recruiting Programs',\n        'https://www.linkedin.com/in/rosettaphan',\n        'San Francisco Bay Area',\n        'Recruiting operations, headcount planning, Coda/Superhuman hiring workflows',\n        'Coda recruiting content identifies Rosetta as a recruiter walking through headcount approval; LinkedIn shows ongoing Superhuman/Coda-related recruiting activity.'\n      )\n    ]\n  },\n  C0615: {\n    description: \\\"Quip is Salesforce's collaborative productivity suite for documents, spreadsheets, chat, and embedded CRM workflows, now supporting Slack productivity features such as Canvas.\\\",\n    recruiters: [\n      contact(\n        'Gemma Quinn',\n        'Senior Recruiter, Futureforce EMEA',\n        'https://www.linkedin.com/in/gemmaq',\n        'San Francisco, CA, United States',\n        'Salesforce Futureforce, university recruiting, interns and new grads',\n        'LinkedIn profile and activity show Gemma on Salesforce Futureforce university recruiting; Quip hiring now sits inside Salesforce/Slack productivity teams.'\n      ),\n      contact(\n        'Alison Kindem',\n        'Technical Recruiter, Salesforce / Slack Engineering',\n        'https://www.linkedin.com/in/alison-kindem-693914b1',\n        'Bellevue, WA, United States',\n        'Technical recruiting for Salesforce and Slack software engineering roles',\n        'Public Stackforce profile and posts show Alison recruiting Salesforce and Slack software engineers; Quip is part of Salesforce Slack Productivity.'\n      )\n    ]\n  },\n  C0617: {\n    description: \\\"FigJam is Figma's online whiteboarding product for brainstorming, workshops, diagrams, and team collaboration within the broader design and product development platform.\\\",\n    recruiters: [\n      contact(\n        'Ashley Nair',\n        'Manager, Early Career Recruiting',\n        'https://www.linkedin.com/in/ashleynair2',\n        'Seattle, WA, United States',\n        'Early career recruiting and intern programs for Figma products including FigJam',\n        'The Org lists Ashley as Manager, Early Career Recruiting at Figma; Figma job postings reference familiarity with Figma and FigJam.'\n      ),\n      contact(\n        \\\"Hannah O'Toole\\\",\n        'Early Career Recruiter',\n        'https://www.linkedin.com/in/hannahotoole',\n        'San Francisco Bay Area',\n        'Early career recruiting, internships, new-grad programs',\n        'Figma early career public content names Hannah on the Early Career Recruiting team supporting intern and early-career hiring.'\n      ),\n      contact(\n        'Carolynn Choi',\n        'Senior University Recruiter',\n        'https://www.linkedin.com/in/carolynnchoi',\n        'New York, NY, United States',\n        'University recruiting and early career programs',\n        'Figma early career public content names Carolynn as a mentor and university recruiting team member.'\n      )\n    ]\n  },\n  C0748: {\n    description: 'A10 Networks builds secure application delivery, DDoS protection, load balancing, and cloud-native security products for enterprises, service providers, and 5G infrastructure.',\n    recruiters: [\n      contact(\n        'Lisa Jensen',\n        'Senior Director, Head of Global HR Business Partners & Talent Acquisition',\n        '',\n        'San Jose, CA, United States',\n        'Global HR, talent acquisition, recruiting leadership',\n        'The Org public HQ listing identifies Lisa as Senior Director and head of global HR business partners and talent acquisition at A10 Networks.'\n      ),\n      contact(\n        'Wes Sage',\n        'Senior Recruiter',\n        '',\n        'San Jose, CA, United States',\n        'Corporate and technical recruiting',\n        'The Org public HQ listing identifies Wes as Senior Recruiter at A10 Networks.'\n      ),\n      contact(\n        'Michelle Goulart',\n        'Recruiting Coordinator / Junior Recruiter',\n        '',\n        'San Jose, CA, United States',\n        'Recruiting coordination and early talent support',\n        'The Org and Wiza public listings identify Michelle as Recruiting Coordinator / Junior Recruiter at A10 Networks.'\n      )\n    ]\n  },\n  C0750: {\n    description: 'Extreme Networks provides cloud-managed enterprise networking, Wi-Fi, switching, SD-WAN, analytics, and automation tools for campus, branch, data center, and service-provider environments.',\n    recruiters: [\n      contact(\n        'Scott Hathaway',\n        'Senior Corporate Recruiter',\n        '',\n        'United States',\n        'Corporate recruiting, technical recruiting, networking roles',\n        'The Org lists Scott as Senior Corporate Recruiter at Extreme Networks since 2015.'\n      ),\n      contact(\n        'Cindy Hammer',\n        'Senior Recruiter, Talent Acquisition',\n        '',\n        'Raleigh-Durham-Chapel Hill Area',\n        'Talent acquisition and corporate recruiting',\n        'Wiza public profile lists Cindy as Sr. Recruiter - Talent Acquisition at Extreme Networks, updated Sept 2025.'\n      ),\n      contact(\n        'Srinadh Perala',\n        'Recruiter',\n        '',\n        'United States',\n        'Recruiting services and corporate hiring',\n        'The Org public Extreme Networks recruitment services page lists Srinadh as a recruiter reporting under corporate recruiting.'\n      )\n    ]\n  },\n  C0753: {\n    description: 'Infinera develops optical transport, coherent networking, and network automation systems used by telecom carriers, cloud operators, data centers, and subsea network providers.',\n    recruiters: [\n      contact(\n        'Paul Whitney',\n        'Vice President of Human Resources',\n        '',\n        'United States',\n        'Human resources leadership and recruiting systems',\n        'Public Jobvite customer materials identify Paul as Vice President of Human Resources at Infinera.'\n      )\n    ]\n  },\n  C0756: {\n    description: 'Ubiquiti builds networking, Wi-Fi, switching, routing, video security, and ISP access hardware with integrated software for businesses, homes, and service providers.',\n    recruiters: [\n      contact(\n        'Alice Ho',\n        'Technical Recruiter',\n        'https://tw.linkedin.com/in/aliiiicceee/zh-tw',\n        'Taipei-Keelung Metropolitan Area, Taiwan',\n        'Hardware engineering, networking products, embedded and electrical engineering hiring',\n        'LinkedIn profile lists Technical Recruiter at Ubiquiti and public posts recruiting hardware engineers for switching, routing, gateway, storage, and NVR products.'\n      )\n    ]\n  }\n};\n\nconst touched = [];\nfor (const company of data.companies || []) {\n  const update = updates[company.id];\n  if (\"'!update) continue;\n  company.description = update.description;\n  const existing = new Set((company.recruiters || []).map(r => `${(r.name || '\"'').toLowerCase()}|\"'${(r.linkedin_url || '\"'').toLowerCase()}\"'`));\n  company.recruiters = company.recruiters || [];\n  for (const recruiter of update.recruiters) {\n    const key = `${recruiter.name.toLowerCase()}|${(recruiter.linkedin_url || '\"'').toLowerCase()}\"'`;\n    if (!existing.has(key)) {\n      company.recruiters.push(recruiter);\n      existing.add(key);\n    }\n  }\n  touched.push(company.id);\n}\n\nfs.writeFileSync(path, JSON.stringify(data, null, 2) + '\"'\\\\n');\nconsole.log(\"'`updated ${touched.length} companies: ${touched.join('\"', ')}\"'`);\nNODE'","aggregated_output":"","exit_code":null,"status":"in_progress"}}
