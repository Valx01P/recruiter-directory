{"type":"item.started","item":{"id":"item_37","type":"command_execution","command":"/bin/zsh -lc \"node - <<'NODE'\nconst fs=require('fs');\nconst d=JSON.parse(fs.readFileSync('job/sectors/recruiter-cloud.json','utf8'));\nconst ids=['C0595','C0599','C0603','C0604','C0606','C0611','C0612','C0616','C0618'];\nfor (const id of ids) {\n  const c=d.companies.find(x=>x.id===id);\n  const words=String(c.description||'').trim().split(/\\\\s+/).filter(Boolean).length;\n  const dupes=[]; const seen=new Set();\n  for (const r of c.recruiters||[]) {\n    const key=((r.name||'')+'|'+(r.linkedin_url||'')).toLowerCase();\n    if(seen.has(key)) dupes.push(r.name); else seen.add(key);\n  }\n  console.log(id, c.name, 'recs='+c.recruiters.length, 'desc_words='+words, 'dupes='+(dupes.length?dupes.join(','):'none'));\n}\nNODE\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
