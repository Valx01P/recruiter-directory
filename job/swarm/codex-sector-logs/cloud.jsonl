{"type":"item.started","item":{"id":"item_24","type":"command_execution","command":"/bin/zsh -lc \"node <<'NODE'\nconst fs = require('fs');\nconst path = 'job/sectors/recruiter-cloud.json';\nconst data = JSON.parse(fs.readFileSync(path, 'utf8'));\n\nconst baseFlags = {\n  email: '',\n  connected: false,\n  messaged: false,\n  responded: false,\n  date_contacted: ''\n};\n\nconst updates = {\n  C0571: {\n    description: 'Vertex provides indirect tax automation and compliance software that integrates with enterprise ERP, procurement, billing, point-of-sale, and e-commerce systems.',\n    hq_location: 'King of Prussia, PA',\n    size_estimate: '1k-5k',\n    linkedin_company_url: 'https://www.linkedin.com/company/vertex-inc./',\n    linkedin_url_verified: true,\n    careers_url: 'https://www.vertexinc.com/company/join-our-team',\n    recruiters: [\n      {\n        name: 'Paul Chung',\n        title: 'Talent Advisor - Early Career Recruiting',\n        linkedin_url: 'https://www.linkedin.com/in/paul-chung-5b047313b',\n        location: 'Irvine, CA, United States',\n        focus_area: 'Early career recruiting, internships, new grad, campus recruiting',\n        notes: 'Public LinkedIn profile and Vertex post identify him as Talent Advisor - Early Career Recruiting; activity references intern, new grad, campus, and university recruiting.'\n      },\n      {\n        name: 'Roger Blackburn',\n        title: 'Talent Acquisition Specialist',\n        linkedin_url: 'https://www.linkedin.com/in/blackburnroger',\n        location: 'Columbus, OH Metropolitan Area',\n        focus_area: 'Talent acquisition and recruiting',\n        notes: 'Public LinkedIn profile lists Vertex Inc. experience and describes him as a Talent Acquisition Specialist with technical recruiting certifications.'\n      }\n    ]\n  },\n  C0581: {\n    description: 'Icertis builds an AI-native contract intelligence platform for contract lifecycle management, compliance, sourcing, risk analysis, and enterprise workflow automation.',\n    hq_location: 'Bellevue, WA',\n    size_estimate: '1k-5k',\n    linkedin_url_verified: true,\n    careers_url: 'https://www.icertis.com/careers/',\n    recruiters: [\n      {\n        name: 'Rob Layton',\n        title: 'Talent Acquisition / Recruiting',\n        linkedin_url: 'https://www.linkedin.com/in/rob-l-b314155',\n        location: 'Seattle, WA, United States',\n        focus_area: 'Talent acquisition and technical recruiting',\n        notes: 'Public LinkedIn profile shows Icertis experience and describes talent acquisition expertise; recommendations reference technical recruiting work.'\n      }\n    ]\n  },\n  C0583: {\n    description: 'Nintex provides process automation, workflow, document generation, e-signature, RPA, and process intelligence software for public and private organizations.',\n    hq_location: 'Bellevue, WA',\n    size_estimate: '1k-5k',\n    linkedin_url_verified: true,\n    careers_url: 'https://www.nintex.com/company/careers/',\n    recruiters: [\n      {\n        name: 'Candice Olson',\n        title: 'Recruiter / Talent Acquisition',\n        linkedin_url: 'https://www.linkedin.com/in/candiceaolson',\n        location: 'Denver Metropolitan Area',\n        focus_area: 'Full-cycle recruiting and talent acquisition',\n        notes: 'Public LinkedIn profile lists Nintex experience and recruiting background; recent activity shared Nintex recruiter hiring for the TA organization.'\n      },\n      {\n        name: 'Mike Mitton',\n        title: 'Talent Acquisition Partner',\n        linkedin_url: 'https://www.linkedin.com/in/michaelmitton',\n        location: 'Boston, MA, United States',\n        focus_area: 'Talent acquisition for technology roles',\n        notes: 'Public LinkedIn profile lists Nintex experience and describes him as an experienced Talent Acquisition Partner in the tech industry.'\n      }\n    ]\n  },\n  C0585: {\n    description: 'OutSystems offers an AI-powered low-code platform for building, deploying, securing, and evolving enterprise applications, agents, and mission-critical systems.',\n    hq_location: 'Boston, MA',\n    size_estimate: '1k-5k',\n    linkedin_url_verified: true,\n    careers_url: 'https://www.outsystems.com/careers/',\n    recruiters: [\n      {\n        name: 'Laurinda Lopes',\n        title: 'Talent Acquisition Leader',\n        linkedin_url: 'https://www.linkedin.com/in/laurinda-lopes-15a11567',\n        location: 'Porto, Portugal',\n        focus_area: 'Engineering recruiting across EMEA, APAC, and US',\n        notes: 'Public LinkedIn profile states she leads Talent Acquisition across EMEA, APAC, and the US with a focus on engineering and technology hiring at OutSystems.'\n      },\n      {\n        name: 'Paul Barnett',\n        title: 'Talent Acquisition / Recruiter',\n        linkedin_url: 'https://www.linkedin.com/in/paulbarnett77',\n        location: 'Windsor, England, United Kingdom',\n        focus_area: 'Talent acquisition and GTM recruiting',\n        notes: 'Public LinkedIn profile lists OutSystems experience and recent hiring activity for regional go-to-market roles.'\n      }\n    ]\n  },\n  C0586: {\n    description: 'Mendix, a Siemens business, provides an enterprise low-code application development platform for building web, mobile, cloud, and workflow applications.',\n    hq_location: 'Boston, MA',\n    size_estimate: '1k-5k',\n    linkedin_url_verified: true,\n    careers_url: 'https://www.mendix.com/careers/',\n    recruiters: [\n      {\n        name: 'Louisa Allen',\n        title: 'Talent Acquisition Partner',\n        linkedin_url: '',\n        location: 'Greater Boston, United States',\n        focus_area: 'Talent acquisition and active hiring at Mendix',\n        notes: 'Public hiring-contact listings identify Louisa Allen as a Mendix Talent Acquisition Partner in Greater Boston; public LinkedIn activity thanks her and the recruiting team.'\n      }\n    ]\n  },\n  C0587: {\n    description: 'Pega builds enterprise workflow automation, CRM, decisioning, and generative AI platforms that help large organizations automate service, sales, operations, and case management.',\n    hq_location: 'Waltham, MA',\n    size_estimate: '5k+',\n    linkedin_company_url: 'https://www.linkedin.com/company/pegasystems/',\n    linkedin_url_verified: true,\n    careers_url: 'https://www.pega.com/about/careers',\n    recruiters: [\n      {\n        name: 'Edward Rennie',\n        title: 'Technical Recruiter',\n        linkedin_url: 'https://www.linkedin.com/in/edrennie',\n        location: 'Blackwater, England, United Kingdom',\n        focus_area: 'Technical recruiting at Pegasystems',\n        notes: 'Public LinkedIn profile lists Pegasystems experience and describes him as a dedicated Technical Recruiter.'\n      },\n      {\n        name: 'David Martin',\n        title: 'Talent Acquisition Leader',\n        linkedin_url: 'https://www.linkedin.com/in/davidcwmartin',\n        location: 'Boston, MA, United States',\n        focus_area: 'Global talent acquisition and recruiting leadership',\n        notes: 'Public LinkedIn profile lists Pegasystems experience and describes a global background in talent acquisition; recommendations reference recruiting leadership.'\n      }\n    ]\n  },\n  C0588: {\n    description: 'ServiceTitan provides cloud software for trade contractors, covering scheduling, dispatch, CRM, payments, marketing, analytics, and field service operations.',\n    hq_location: 'Glendale, CA',\n    size_estimate: '1k-5k',\n    linkedin_url_verified: true,\n    careers_url: 'https://www.servicetitan.com/careers',\n    recruiters: [\n      {\n        name: 'Carina Jarabroviski',\n        title: 'Talent Acquisition Professional',\n        linkedin_url: 'https://www.linkedin.com/in/carina-jarabroviski-5389282a',\n        location: 'San Francisco, CA, United States',\n        focus_area: 'Talent acquisition and recruiting operations',\n        notes: 'Public LinkedIn profile lists ServiceTitan and describes more than 13 years of talent acquisition experience.'\n      },\n      {\n        name: 'Lindsay Joseph',\n        title: 'Talent Acquisition Professional / Recruiter',\n        linkedin_url: 'https://www.linkedin.com/in/lindsay-joseph-dba-airs-certified-recruiter-22211b62',\n        location: 'United States',\n        focus_area: 'Talent acquisition and recruiting',\n        notes: 'Public LinkedIn profile connects to ServiceTitan and describes nearly 10 years of talent acquisition experience; recommendations reference recruiting work.'\n      }\n    ]\n  },\n  C0591: {\n    description: 'Olo provides restaurant technology for digital ordering, payments, delivery integrations, guest engagement, and data-driven hospitality operations across enterprise brands.',\n    hq_location: 'New York, NY',\n    size_estimate: '500-1k',\n    linkedin_url_verified: true,\n    careers_url: 'https://www.olo.com/careers/',\n    recruiters: [\n      {\n        name: 'Shilpa Oommen',\n        title: 'Associate Director, Talent Acquisition / Tech Recruiting',\n        linkedin_url: 'https://www.linkedin.com/in/shilpaoommen',\n        location: 'New York, NY, United States',\n        focus_area: 'Technical recruiting and talent acquisition',\n        notes: 'Public profile and contact listings identify her as Associate Director of Talent Acquisition, Tech Recruiting, and former Senior Technical Recruiter at Olo.'\n      },\n      {\n        name: 'Danielle DePasquale',\n        title: 'Talent Acquisition Professional',\n        linkedin_url: 'https://www.linkedin.com/in/danielle-depasquale',\n        location: 'New York City Metropolitan Area',\n        focus_area: 'Full-cycle recruiting and candidate experience',\n        notes: 'Public LinkedIn profile lists Olo and describes a dynamic talent acquisition professional with full-cycle recruitment experience.'\n      }\n    ]\n  }\n};\n\nlet touched = 0;\nlet added = 0;\nfor (const company of data.companies || []) {\n  const update = updates[company.id];\n  if (\"'!update) continue;\n  touched += 1;\n  for (const [key, value] of Object.entries(update)) {\n    if (key !== '\"'recruiters') company[key] = value;\n  }\n  const existingUrls = new Set((company.recruiters || []).map(r => String(r.linkedin_url || '').toLowerCase()).filter(Boolean));\n  const existingNames = new Set((company.recruiters || []).map(r => String(r.name || '').toLowerCase()).filter(Boolean));\n  company.recruiters = company.recruiters || [];\n  for (const r of update.recruiters) {\n    const url = String(r.linkedin_url || '').toLowerCase();\n    const name = String(r.name || '').toLowerCase();\n    if ((url && existingUrls.has(url)) || existingNames.has(name)) continue;\n    company.recruiters.push({ ...r, ...baseFlags });\n    if (url) existingUrls.add(url);\n    existingNames.add(name);\n    added += 1;\n  }\n}\n\nfs.writeFileSync(path, JSON.stringify(data, null, 2) + '\\\\n');\nconsole.log(\"'`updated ${touched} companies, added ${added} recruiters`);\nNODE'","aggregated_output":"","exit_code":null,"status":"in_progress"}}
