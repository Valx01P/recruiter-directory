{"type":"item.started","item":{"id":"item_26","type":"command_execution","command":"/bin/zsh -lc \"node - <<'NODE'\nconst fs = require('fs');\nconst path = 'job/sectors/recruiter-cloud.json';\nconst data = JSON.parse(fs.readFileSync(path, 'utf8'));\n\nconst updates = {\n  C0559: {\n    description: 'SurveyMonkey provides survey and forms software with AI-assisted research tools that help organizations collect customer, employee, and market feedback for decision-making.',\n    recruiters: [\n      {\n        name: 'Michelle Konerman',\n        title: 'Global Head of Talent Acquisition',\n        linkedin_url: 'https://www.linkedin.com/in/michelle-konerman-ba7763a',\n        email: '',\n        location: 'Cincinnati, OH',\n        focus_area: 'Talent acquisition leadership and recruiting team management',\n        connected: false,\n        messaged: false,\n        responded: false,\n        date_contacted: '',\n        notes: 'Public LinkedIn profile states she is Global Head of Talent Acquisition at SurveyMonkey.'\n      },\n      {\n        name: 'Julia Jacques',\n        title: 'Senior Executive Recruiter',\n        linkedin_url: 'https://www.linkedin.com/in/jacquesjulia',\n        email: '',\n        location: 'Portland, OR',\n        focus_area: 'Executive recruiting across functions and regions',\n        connected: false,\n        messaged: false,\n        responded: false,\n        date_contacted: '',\n        notes: 'Public LinkedIn profile states she is a Senior Executive Recruiter at SurveyMonkey.'\n      }\n    ]\n  },\n  C0560: {\n    description: 'Typeform builds interactive forms, surveys, quizzes, and AI-powered data capture experiences that integrate with SaaS workflows for marketing, research, and customer engagement.',\n    recruiters: [\n      {\n        name: 'Viktor Tamang',\n        title: 'People and Culture, Product Hiring Lead',\n        linkedin_url: 'https://uk.linkedin.com/in/viktamang',\n        email: '',\n        location: 'London, UK',\n        focus_area: 'Product, design, growth, and PLG SaaS hiring',\n        connected: false,\n        messaged: false,\n        responded: false,\n        date_contacted: '',\n        notes: 'Public LinkedIn profile and Typeform job posts list him as building product, design, and growth teams at Typeform.'\n      }\n    ]\n  },\n  C0561: {\n    description: 'UserTesting provides a customer-insights platform for moderated and unmoderated testing, surveys, and AI analysis, helping product teams validate digital experiences.',\n    recruiters: [\n      {\n        name: 'Nikki Morello',\n        title: 'Chief Transformation Officer',\n        linkedin_url: 'https://www.linkedin.com/in/nikkimorello',\n        email: '',\n        location: 'San Antonio, TX',\n        focus_area: 'People organization, transformation leadership, and AI operations hiring',\n        connected: false,\n        messaged: false,\n        responded: false,\n        date_contacted: '',\n        notes: 'UserTesting announcement says she leads the People organization; public LinkedIn posts show active hiring for internal AI strategy roles.'\n      }\n    ]\n  },\n  C0564: {\n    description: 'WalkMe, now part of SAP, provides digital adoption software that overlays guidance, automation, and analytics on enterprise applications to improve employee productivity.',\n    recruiters: [\n      {\n        name: 'Adam Garrison',\n        title: 'Senior Talent Recruiter',\n        linkedin_url: 'https://www.linkedin.com/in/adamgarrisonhr',\n        email: '',\n        location: 'San Francisco Bay Area',\n        focus_area: 'GTM and sales recruiting',\n        connected: false,\n        messaged: false,\n        responded: false,\n        date_contacted: '',\n        notes: 'Public LinkedIn profile lists WalkMe and a senior talent recruiter background; recent activity includes WalkMe sales hiring.'\n      },\n      {\n        name: 'Chase Younts',\n        title: 'Talent Acquisition Leader',\n        linkedin_url: 'https://www.linkedin.com/in/chase-younts-a2544a16',\n        email: '',\n        location: 'Raleigh, NC',\n        focus_area: 'Technical, GTM, and executive recruiting',\n        connected: false,\n        messaged: false,\n        responded: false,\n        date_contacted: '',\n        notes: 'Public LinkedIn profile lists WalkMe and a talent acquisition leadership background, with recent WalkMe hiring activity.'\n      }\n    ]\n  },\n  C0565: {\n    description: 'Docebo provides an AI-powered learning management platform for enterprises to create, deliver, and measure training across employees, customers, and partners.',\n    recruiters: [\n      {\n        name: 'Dylan Dargavel',\n        title: 'Talent Acquisition Specialist',\n        linkedin_url: 'https://www.linkedin.com/in/dylan-dargavel-82b970108',\n        email: '',\n        location: 'Buffalo, NY',\n        focus_area: 'G&A, GTM, product, and engineering recruiting',\n        connected: false,\n        messaged: false,\n        responded: false,\n        date_contacted: '',\n        notes: 'Public LinkedIn profile states he is a Talent Acquisition Specialist at Docebo and shares active Docebo hiring posts.'\n      }\n    ]\n  },\n  C0568: {\n    description: 'BlackLine provides cloud finance and accounting automation software for financial close, reconciliation, intercompany accounting, and controls used by enterprise accounting teams.',\n    recruiters: [\n      {\n        name: 'LaQuita Hester',\n        title: 'Senior Manager, Global Talent Acquisition, Tech and Product',\n        linkedin_url: 'https://www.linkedin.com/in/laquita-hester-97aa2931',\n        email: '',\n        location: 'United States',\n        focus_area: 'Technology, product, AI/ML, and engineering recruiting',\n        connected: false,\n        messaged: false,\n        responded: false,\n        date_contacted: '',\n        notes: 'Public profile and supporting web profile identify her as Senior Manager, Global Talent Acquisition for Tech and Product at BlackLine.'\n      }\n    ]\n  },\n  C0569: {\n    description: 'BILL, formerly Bill.com, provides financial automation software for small and mid-sized businesses to manage payables, receivables, expenses, and cash flow.',\n    recruiters: [\n      {\n        name: 'Savannah Davis',\n        title: 'Staff Technical Recruiter, Software Engineering',\n        linkedin_url: 'https://www.linkedin.com/in/thesavvytechrecruiter',\n        email: '',\n        location: 'Newport Beach, CA',\n        focus_area: 'Software engineering and technical recruiting',\n        connected: false,\n        messaged: false,\n        responded: false,\n        date_contacted: '',\n        notes: 'Public LinkedIn profile lists BILL in San Jose; The Org lists her as Staff Technical Recruiter for software engineering.'\n      },\n      {\n        name: 'Leslie Batto',\n        title: 'Staff Technical Recruiter, Engineering',\n        linkedin_url: 'https://www.linkedin.com/in/lbatto',\n        email: '',\n        location: 'San Ramon, CA',\n        focus_area: 'Engineering recruiting and scalable recruiting processes',\n        connected: false,\n        messaged: false,\n        responded: false,\n        date_contacted: '',\n        notes: 'Public LinkedIn profile lists BILL in San Jose; The Org lists her as Staff Technical Recruiter for engineering.'\n      }\n    ]\n  },\n  C0570: {\n    description: 'Avalara provides cloud tax compliance software and APIs that automate tax calculations, exemptions, returns, and e-invoicing across global commerce workflows.',\n    recruiters: [\n      {\n        name: 'John Murrel',\n        title: 'Technical and Professional Recruiter',\n        linkedin_url: 'https://www.linkedin.com/in/jlmurrel',\n        email: '',\n        location: 'Detroit Metro Area',\n        focus_area: 'Technical, professional, and AI-driven recruiting',\n        connected: false,\n        messaged: false,\n        responded: false,\n        date_contacted: '',\n        notes: 'Public LinkedIn profile lists Avalara and experienced technical/professional recruiting; recent activity points candidates to Avalara hiring.'\n      },\n      {\n        name: 'Tara Jones',\n        title: 'Talent Acquisition / Full Life Cycle Recruiting',\n        linkedin_url: 'https://www.linkedin.com/in/taraejones',\n        email: '',\n        location: 'Andover, NJ',\n        focus_area: 'Full-cycle recruiting and junior recruiter hiring',\n        connected: false,\n        messaged: false,\n        responded: false,\n        date_contacted: '',\n        notes: 'Public LinkedIn profile lists Avalara and full life cycle recruiting; public activity includes hiring a Junior Recruiter.'\n      }\n    ]\n  }\n};\n\nlet touched = 0;\nlet added = 0;\nfor (const [id, update] of Object.entries(updates)) {\n  const company = data.companies.find(c => c.id === id);\n  if (\"'!company) throw new Error(`Company not found: ${id}`);\n  touched++;\n  company.description = update.description;\n  if (!Array.isArray(company.recruiters)) company.recruiters = [];\n  const seen = new Set(company.recruiters.map(r => `${(r.name || '\"'').toLowerCase()}|\"'${(r.linkedin_url || '\"'').toLowerCase()}\"'`));\n  for (const recruiter of update.recruiters) {\n    const key = `${recruiter.name.toLowerCase()}|${recruiter.linkedin_url.toLowerCase()}`;\n    if (!seen.has(key)) {\n      company.recruiters.push(recruiter);\n      seen.add(key);\n      added++;\n    }\n  }\n}\n\nfs.writeFileSync(path, JSON.stringify(data, null, 2) + '\"'\\\\n');\nconsole.log(\"'`updated ${touched} companies, added ${added} recruiter entries`);\nNODE'","aggregated_output":"","exit_code":null,"status":"in_progress"}}
