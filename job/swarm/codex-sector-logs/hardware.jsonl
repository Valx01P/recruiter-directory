\n--- JSON HEAD ---\\\\n{\\\\n  \\\\\\\"meta\\\\\\\": {\\\\n    \\\\\\\"description\\\\\\\": \\\\\\\"US-based tech companies large enough to run dedicated recruiting + internship programs. Target for LinkedIn outreach to recruiters. Populate each company's 'recruiters' array over time with the recruiter object schema below.\\\\\\\",\\\\n    \\\\\\\"version\\\\\\\": \\\\\\\"2.1\\\\\\\",\\\\n    \\\\\\\"last_updated\\\\\\\": \\\\\\\"2026-06-08\\\\\\\",\\\\n    \\\\\\\"owner\\\\\\\": \\\\\\\"Pablo Valdes\\\\\\\",\\\\n    \\\\\\\"use_case\\\\\\\": \\\\\\\"Connect with recruiters at top US tech companies on LinkedIn to source SWE / AI internship opportunities.\\\\\\\",\\\\n    \\\\\\\"recruiter_object_schema\\\\\\\": {\\\\n      \\\\\\\"name\\\\\\\": \\\\\\\"\\\\\\\",\\\\n      \\\\\\\"title\\\\\\\": \\\\\\\"\\\\\\\",\\\\n      \\\\\\\"linkedin_url\\\\\\\": \\\\\\\"\\\\\\\",\\\\n      \\\\\\\"email\\\\\\\": \\\\\\\"\\\\\\\",\\\\n      \\\\\\\"location\\\\\\\": \\\\\\\"\\\\\\\",\\\\n      \\\\\\\"focus_area\\\\\\\": \\\\\\\"e.g. University Recruiting / SWE Intern / New Grad\\\\\\\",\\\\n      \\\\\\\"connected\\\\\\\": false,\\\\n      \\\\\\\"messaged\\\\\\\": false,\\\\n      \\\\\\\"responded\\\\\\\": false,\\\\n      \\\\\\\"date_contacted\\\\\\\": \\\\\\\"\\\\\\\",\\\\n      \\\\\\\"notes\\\\\\\": \\\\\\\"\\\\\\\"\\\\n    },\\\\n    \\\\\\\"company_field_legend\\\\\\\": {\\\\n      \\\\\\\"name\\\\\\\": \\\\\\\"Company name\\\\\\\",\\\\n      \\\\\\\"category\\\\\\\": \\\\\\\"Primary tech sector\\\\\\\",\\\\n      \\\\\\\"hq_location\\\\\\\": \\\\\\\"US headquarters\\\\\\\",\\\\n      \\\\\\\"linkedin_company_url\\\\\\\": \\\\\\\"Company LinkedIn page. Curated entries are hand-verified; bulk entries are auto-derived from the name.\\\\\\\",\\\\n      \\\\\\\"careers_url\\\\\\\": \\\\\\\"Internship / careers landing page (fill later)\\\\\\\",\\\\n      \\\\\\\"size_estimate\\\\\\\": \\\\\\\"Rough US/global headcount band\\\\\\\",\\\\n      \\\\\\\"has_intern_program\\\