mpanies populated with 1937 total recruiters; 1250 company descriptions missing. Merge run: 2026-06-01\\\\\\\",\\\\n    \\\\\\\"partition_type\\\\\\\": \\\\\\\"sector\\\\\\\",\\\\n    \\\\\\\"sector\\\\\\\": {\\\\n      \\\\\\\"key\\\\\\\": \\\\\\\"media\\\\\\\",\\\\n      \\\\\\\"label\\\\\\\": \\\\\\\"Gaming / Media\\\\\\\"\\\\n    },\\\\n    \\\\\\\"source_file\\\\\\\": \\\\\\\"job/recruiter.json\\\\\\\",\\\\n    \\\\\\\"last_partition_build\\\\\\\": \\\\\\\"2026-06-01T00:45:06.195Z\\\\\\\"\\\\n  },\\\\n  \\\\\\\"companies\\\\\\\": [\\\\n    {\\\\n      \\\\\\\"id\\\\\\\": \\\\\\\"C0064\\\\\\\",\\\\n      \\\\\\\"name\\\\\\\": \\\\\\\"Pinterest\\\\\\\",\\\\n      \\\\\\\"category\\\\\\\": \\\\\\\"Internet / Social\\\\\\\",\\\\n      \\\\\\\"sector\\\\\\\": \\\\\\\"media\\\\\\\",\\\\n      \\\\\\\"description\\\\\\\": \\\\\\\"\\\\\\\",\\\\n      \\\\\\\"hq_location\\\\\\\": \\\\\\\"San Francisco, CA\\\\\\\",\\\\n      \\\\\\\"priority\\\\\\\": 2,\\\\n      \\\\\\\"size_estimate\\\\\\\": \\\\\\\"4k+\\\\\\\",\\\\n      \\\\\\\"has_intern_program\\\\\\\": true,\\\\n      \\\\\\\"linkedin_company_url\\\\\\\": \\\\\\\"https://www.linkedin.com/company/pinterest/\\\\\\\",\\\\n      \\\\\\\"linkedin_url_verified\\\\\\\": true,\\\\n      \\\\\\\"recruiter_search_url\\\\\\\": \\\\\\\"https://www.linkedin.com/search/results/people/?keywords=Pinterest%20recruiter\\\\\\\",\\\\n      \\\\\\\"careers_url\\\\\\\": \\\\\\\"\\\\\\\",\\\\n      \\\\\\\"recruiters\\\\\\\": [\\\\n        {\\\\n          \\\\\\\"name\\\\\\\": \\\\\\\"Adriana I. Garcia\\\\\\\",\\\\n          \\\\\\\"title\\\\\\\": \\\\\\\"Senior Recruiter, University / Early Career Recruiting\\\\\\\",\\\\n          \\\\\\\"linkedin_url\\\\\\\": \\\\\\\"https://www.linkedin.com/in/adrianaigarcia\\\\\\\",\\\\n          \\\\\\\"email\\\\\\\": \\\\\\\"\\\\\\\",\\\\n          \\\\\\\"location\\\\\\\": \\\\\\\"San Francisco, CA, United States\\\\\\\",\\\\n          \\\\\\\"focus_area\\\\\\\": \\\\\\\"University Recruiting / Early Career Programs (SWE, ML internships & new grad)\\\\\\\",\\\\n          \\\\\\\"connected\\\\\\\": false,\\\\n          \\\\\\\"messaged\\\\\\\": false,\\\\n          \\\\\\\"responded\\\\\\\": false,\\\\n          \\\\\\\"date_contacted\\\\\\\": \\\\\\\"\\\\\\\",\\\\n          \\\\\\\"notes\\\\\\\": \\\\\\\"Senior Recruiter, University / Early Career Recruiting at Pinterest (SF Bay Area). Leads university programs with focus on software engineering and machine learning internships/new grad. Active posts welcoming intern cohorts and running events. Prior university recruiting at Facebook and IBM.\\\\\\\"\\\\n        },\\\\n        {\\\\n          \\\\\\\"name\\\\\\\": \\\\\\\"Kelli Schulte\\\\\\\",\\\\n          \\\\\\\"title\\\\\\\": \\\\\\\"University Recruiter, ML & DS\\\\\\\",\\\\n          \\\\\\\"linkedin_url\\\\\\\": \\\\\\\"https://www.linkedin.com/in/kelli-schulte\\\\\\\",\\\\n          \\\\\\\"email\\\\\\\": \\\\\\\"\\\\\\\",\\\\n          \\\\\\\"location\\\\\\\": \\\\\\\"Greater Chicago Area, United States\\\\\\\",\\\\n          \\\\\\\"focus_area\\\\\\\": \\\\\\\"University Recruiting - Machine Learning & Data Science\\\\\\\",\\\\n          \\\\\\\"connected\\\\\\\": false,\\\\n          \\\\\\\"messaged\\\\\\\": false,\\\\n          \\\\\\\"responded\\\\\\\": false,\\\\n          \\\\\\\"date_contacted\\\\\\\": \\\\\\\"\\\\\\\",\\\\n          \\\\\\\"notes\\\\\\\": \\\\\\\"University Recruiter, ML & DS at Pinterest. Focuses on ML/Data Science university recruiting and Pinternship program. Posts about internship wrap-ups, conferences (CVPR), and program recognition.\\\\\\\"\\\\n        }\\\\n      ]\\\\n    },\\\\n    {\\\\n      \\\\\\\"id\\\\\\\": \\\\\\\"C0065\\\\\\\",\\\\n      \\\\\\\"name\\\\\\\": \\\\\\\"Snap Inc.\\\\\\\",\\\\n      \\\\\\\"category\\\\\\\": \\\\\\\"Internet / Social\\\\\\\",\\\\n      \\\\\\\"sector\\\\\\\": \\\\\\\"media\\\\\\\",\\\\n      \\\\\\\"description\\\\\\\": \\\\\\\"\\\\\\\",\\\\n      \\\\\\\"hq_location\\\\\\\"