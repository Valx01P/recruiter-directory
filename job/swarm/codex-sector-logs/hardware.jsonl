{"type":"item.started","item":{"id":"item_13","type":"command_execution","command":"/bin/zsh -lc \"node - <<'NODE'\nconst fs = require('fs');\nconst path = 'job/sectors/recruiter-hardware.json';\nconst data = JSON.parse(fs.readFileSync(path, 'utf8'));\nconst descriptions = new Map(Object.entries({\n  C0823: 'Wolfspeed develops silicon carbide materials, power modules, discrete devices, and power die used in electric vehicles, renewable energy systems, industrial power, and high-efficiency electronics.',\n  C0824: 'Allegro MicroSystems designs magnetic sensor ICs, power management chips, and motor control semiconductors for automotive, industrial, and clean-energy motion and electrification systems.',\n  C0825: 'Silicon Labs builds secure wireless SoCs, modules, and software for IoT devices using Bluetooth, Wi-Fi, Matter, Zigbee, Z-Wave, and low-power embedded connectivity.',\n  C0826: 'Diodes Incorporated supplies analog, discrete, power, logic, and mixed-signal semiconductor products for automotive, computing, communications, industrial, and consumer electronics designs.',\n  C0827: 'Amkor Technology provides outsourced semiconductor assembly, advanced packaging, wafer-level processing, and test services for chipmakers serving smartphones, data centers, AI, automotive, and wearables.',\n  C0828: 'Entegris supplies specialty materials, filtration, fluid handling, contamination control, and process solutions that help semiconductor manufacturers improve wafer yield and material purity.',\n  C0829: 'Teradyne builds automated test equipment for semiconductor devices, circuit boards, wireless products, storage systems, and industrial automation workflows across high-volume electronics manufacturing.',\n  C0830: 'Onto Innovation makes semiconductor process control tools spanning optical metrology, wafer and package inspection, lithography, and analytics software for advanced device manufacturing.',\n  C0831: 'GlobalFoundries operates semiconductor foundries that manufacture essential chips and differentiated process technologies for automotive, IoT, communications, defense, aerospace, and AI infrastructure customers.',\n  C0832: 'Astera Labs develops connectivity silicon, hardware, and software for AI and cloud infrastructure, including PCIe, CXL, Ethernet, NVLink, and rack-scale interconnect products.',\n  C0833: 'Ambarella designs low-power edge AI and computer vision SoCs used in video security, advanced driver assistance, autonomous vehicles, robotics, and smart camera systems.',\n  C0834: 'Rambus develops memory interface chips, high-speed silicon IP, and hardware security technologies that accelerate and protect data movement in AI and data center systems.',\n  C0835: 'MaxLinear designs high-performance analog, mixed-signal, RF, and communications SoCs for broadband access, data center connectivity, wireless infrastructure, and industrial networking equipment.',\n  C0836: 'Semtech provides high-performance semiconductors, optical networking ICs, LoRa wireless technology, IoT systems, and cloud connectivity for AI data centers and connected devices.'\n}));\nlet touched = 0;\nfor (const company of data.companies || []) {\n  if (\"'!descriptions.has(company.id)) continue;\n  if (String(company.description || '\"'').trim()) {\n    throw new Error(\"'`${company.id} already has a description`);\n  }\n  company.description = descriptions.get(company.id);\n  touched += 1;\n}\nif (touched !== descriptions.size) {\n  throw new Error(`Expected ${descriptions.size} updates, made ${touched}`);\n}\nfs.writeFileSync(path, `${JSON.stringify(data, null, 2)}'\"\\\\n\"'`);\nNODE'","aggregated_output":"","exit_code":null,"status":"in_progress"}}
