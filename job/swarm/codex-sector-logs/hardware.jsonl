{"type":"item.started","item":{"id":"item_13","type":"command_execution","command":"/bin/zsh -lc \"node <<'NODE'\nconst fs = require('fs');\nconst path = 'job/sectors/recruiter-hardware.json';\nconst data = JSON.parse(fs.readFileSync(path, 'utf8'));\nconst descriptions = {\n  C0837: 'Vishay Intertechnology manufactures discrete semiconductors and passive electronic components, including diodes, MOSFETs, resistors, capacitors, and inductors for automotive, industrial, computing, and consumer markets.',\n  C0838: 'Universal Display develops and licenses OLED technologies and phosphorescent materials used by display makers in energy-efficient screens, lighting, and other organic electronics applications.',\n  C0839: 'Coherent supplies lasers, optical transceivers, photonic components, and engineered materials for data centers, semiconductor equipment, industrial manufacturing, aerospace, and scientific systems.',\n  C0840: 'Lumentum designs optical and photonic products, including lasers, transceiver modules, amplifiers, and sensing components for cloud data centers, telecom networks, and manufacturing.',\n  C0841: 'VIAVI builds network test, monitoring, assurance, timing, and optical technology products for data centers, communications networks, defense, aerospace, rail, and industrial customers.',\n  C0842: 'Corning applies glass science, ceramics, and optical physics to make fiber, display glass, environmental substrates, life-science tools, and specialty materials.',\n  C0843: 'II-VI, now part of Coherent, developed engineered materials, optoelectronic components, and photonic subsystems for communications, industrial, defense, semiconductor, and automotive markets.',\n  C0844: 'SiTime develops silicon MEMS timing chips, oscillators, resonators, clock generators, and synchronization software for automotive, communications, data center, IoT, industrial, and aerospace systems.',\n  C0845: 'Navitas Semiconductor develops GaN power ICs and silicon-carbide power devices that improve efficiency in AI data centers, EVs, chargers, solar, and industrial power systems.',\n  C0846: 'Indie Semiconductor provides automotive semiconductors, hardware, and software platforms for ADAS, user-experience, connectivity, electrification, and safety systems in software-defined vehicles.',\n  C0847: 'Kulicke and Soffa builds semiconductor assembly, packaging, and interconnect equipment, including bonding and advanced packaging systems used by chipmakers and outsourced assembly providers.',\n  C0848: 'Photronics manufactures photomasks and reticles used to pattern integrated circuits and flat-panel displays, supporting mainstream and leading-edge semiconductor and display manufacturing nodes.',\n  C0849: 'iRobot develops consumer robots and smart home cleaning products, led by Roomba robotic vacuums and Braava mops with navigation, mapping, and app-connected features.',\n  C0850: 'Sonos designs wireless speakers, soundbars, subwoofers, portable audio devices, and home theater software for networked multiroom listening and spatial audio.'\n};\nconst touched = [];\nfor (const company of data.companies || []) {\n  if (Object.prototype.hasOwnProperty.call(descriptions, company.id)) {\n    if (String(company.description || '').trim()) {\n      throw new Error(\"'`${company.id} already has a description`);\n    }\n    company.description = descriptions[company.id];\n    touched.push(company.id);\n  }\n}\nif (touched.length !== Object.keys(descriptions).length) {\n  throw new Error(`Updated ${touched.length}, expected ${Object.keys(descriptions).length}`);\n}\nfs.writeFileSync(path, `${JSON.stringify(data, null, 2)}'\"\\\\n\"'`);\nconsole.log(`updated ${touched.length}: ${touched.join('\"', ')}\"'`);\nNODE'","aggregated_output":"","exit_code":null,"status":"in_progress"}}
