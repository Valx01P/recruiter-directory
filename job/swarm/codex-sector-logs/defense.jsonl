{"type":"item.started","item":{"id":"item_27","type":"command_execution","command":"/bin/zsh -lc \"node <<'NODE'\nconst fs = require('fs');\nconst path = 'job/sectors/recruiter-defense.json';\nconst d = JSON.parse(fs.readFileSync(path, 'utf8'));\n\nconst descriptions = {\n  C0011: 'SpaceX designs, manufactures, and launches reusable rockets, spacecraft, Starlink satellites, and ground systems for commercial, civil, and national security space missions.',\n  C0113: 'Blue Origin develops reusable launch vehicles, rocket engines, lunar landers, and space infrastructure supporting commercial, civil, and national security missions.',\n  C0114: 'Anduril builds AI-enabled defense systems, autonomous aircraft, sensors, command software, and manufacturing infrastructure for U.S. and allied military customers.',\n  C0115: 'Lockheed Martin builds aircraft, missiles, spacecraft, sensors, and mission systems for U.S. defense, civil agencies, and allied security customers.',\n  C0116: 'Boeing designs, manufactures, and services commercial airplanes, defense aircraft, rotorcraft, satellites, missiles, and space systems for global government and airline customers.',\n  C0117: 'Northrop Grumman develops aircraft, space systems, missile defense, sensors, cyber, and autonomous technologies for U.S. and allied defense missions.',\n  C0118: 'RTX combines Raytheon, Collins Aerospace, and Pratt & Whitney to build missiles, avionics, engines, sensors, and aerospace-defense systems.',\n  C0119: 'General Dynamics builds aerospace, combat systems, shipbuilding, IT, and mission systems through units including Gulfstream, Bath Iron Works, and GD Mission Systems.',\n  C0120: 'L3Harris develops defense electronics, tactical communications, sensors, space payloads, missile-warning systems, and mission networks for military and government customers.',\n  C0194: 'HEICO manufactures FAA-approved aircraft replacement parts, repair services, and mission-critical electronic components for aviation, defense, space, medical, and telecom customers.',\n  C0254: 'Relativity Space develops Terran R, a reusable medium-to-heavy-lift rocket, using additive manufacturing, robotics, and software-defined production for launch services.',\n  C0255: 'Rocket Lab provides end-to-end space services, including Electron launch, Neutron development, spacecraft manufacturing, satellite components, and mission operations.',\n  C0256: 'Planet Labs operates Earth-imaging satellite constellations and geospatial data platforms used for daily monitoring, defense intelligence, climate, agriculture, and commercial analytics.',\n  C0257: 'Maxar provides high-resolution satellite imagery, geospatial intelligence, 3D mapping, and space technology used by government, defense, commercial, and humanitarian customers.'\n};\n\nconst newRecruiters = {\n  C0194: [\n    {\n      name: 'Steven Mendez, MBA',\n      title: 'Human Resources Generalist, Sensor Systems - A HEICO Company',\n      linkedin_url: 'https://www.linkedin.com/in/steven-mendez-mba-1b859753',\n      email: '',\n      location: 'Los Angeles, CA, United States',\n      focus_area: 'HR generalist / full-cycle recruiting for HEICO aerospace subsidiary engineering roles',\n      connected: false,\n      messaged: false,\n      responded: false,\n      date_contacted: '',\n      notes: 'LinkedIn job poster for Sensor Systems, a HEICO company, on RF Engineer roles; public posting identifies him as Human Resources Generalist supporting aerospace engineering hiring.'\n    },\n    {\n      name: 'Elizabeth Sooklall',\n      title: 'HR Administrator at HEICO',\n      linkedin_url: 'https://www.linkedin.com/in/elizabeth-sooklall-4b069a173',\n      email: '',\n      location: 'Miami/Fort Lauderdale Area',\n      focus_area: 'HR administration / recruiting operations at HEICO corporate',\n      connected: false,\n      messaged: false,\n      responded: false,\n      date_contacted: '',\n      notes: 'Public LinkedIn profile shows current HEICO HR a