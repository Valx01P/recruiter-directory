    focus_area: 'Talent Acquisition leadership for Maxar Space / engineering, manufacturing, and government programs',\n      connected: false,\n      messaged: false,\n      responded: false,\n      date_contacted: '',\n      notes: 'Public LinkedIn and company-profile sources identify Lauren as Maxar Space head/director of talent acquisition with aerospace, engineering, and government hiring scope.'\n    },\n    {\n      name: 'Maxar Space Senior Talent Acquisition Business Partner',\n      title: 'Sr. Talent Acquisition Business Partner / Lead Recruiter',\n      linkedin_url: 'https://jobs.spacetalent.org/companies/maxar-technologies-2/jobs/54240061-lead-recruiter',\n      email: '',\n      location: 'Palo Alto, CA / Remote',\n      focus_area: 'Full-cycle recruiting for Maxar Space engineering and technology roles',\n      connected: false,\n      messaged: false,\n      responded: false,\n      date_contacted: '',\n      notes: 'Public Maxar Space posting described a senior TA business partner role managing sourcing, candidate pipelines, and full-cycle recruiting for technical hiring groups.'\n    }\n  ]\n};\n\nfunction keyForPerson(r) {\n  return [r.linkedin_url || '', String(r.name || '').toLowerCase()].join('|');\n}\n\nfor (const company of d.companies || []) {\n  if (descriptions[company.id]) company.description = descriptions[company.id];\n  const additions = newRecruiters[company.id];\n  if (\"'!additions) continue;\n  company.recruiters = company.recruiters || [];\n  const seen = new Set(company.recruiters.map(keyForPerson));\n  for (const r of additions) {\n    const key = keyForPerson(r);\n    if (!seen.has(key)) {\n      company.recruiters.push(r);\n      seen.add(key);\n    }\n  }\n}\n\nfs.writeFileSync(path, JSON.stringify(d, null, 2) + '\"'\\\\n');\nNODE\"","aggregated_output":"","exit_code":0,"status":"completed"}}
