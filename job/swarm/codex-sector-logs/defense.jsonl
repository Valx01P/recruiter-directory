{"type":"item.started","item":{"id":"item_16","type":"command_execution","command":"/bin/zsh -lc \"node -e '\nconst fs=require(\\\"fs\\\"); const d=JSON.parse(fs.readFileSync(\\\"job/sectors/recruiter-defense.json\\\",\\\"utf8\\\"));\nconst touched=[\\\"C0895\\\",\\\"C0896\\\",\\\"C0897\\\",\\\"C0898\\\",\\\"C0899\\\",\\\"C0900\\\",\\\"C0901\\\",\\\"C0902\\\",\\\"C0903\\\",\\\"C0904\\\",\\\"C0905\\\",\\\"C0906\\\",\\\"C0907\\\",\\\"C0908\\\"];\nfor (const id of touched) {\n  const c=d.companies.find(x=>x.id===id);\n  const words=String(c.description||\\\"\\\").trim().split(/\\\\s+/).filter(Boolean).length;\n  console.log(id, c.name, words, c.description);\n}\nconsole.log(\\\"missing\\\", d.companies.filter(c=>\"'!String(c.description||\"\").trim()).length);\nconsole.log(\"unpop\", d.companies.filter(c=>!(c.recruiters||[]).length).length);\nconsole.log(\"recruiters\", d.companies.reduce((s,c)=>s+(c.recruiters||[]).length,0));\n'\"'\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
{"type":"item.completed","item":{"id":"item_16","type":"command_execution","command":"/bin/zsh -lc \"node -e '\nconst fs=require(\\\"fs\\\"); const d=JSON.parse(fs.readFileSync(\\\"job/sectors/recruiter-defense.json\\\",\\\"utf8\\\"));\nconst touched=[\\\"C0895\\\",\\\"C0896\\\",\\\"C0897\\\",\\\"C0898\\\",\\\"C0899\\\",\\\"C0900\\\",\\\"C0901\\\",\\\"C0902\\\",\\\"C0903\\\",\\\"C0904\\\",\\\"C0905\\\",\\\"C0906\\\",\\\"C0907\\\",\\\"C0908\\\"];\nfor (const id of touched) {\n  const c=d.companies.find(x=>x.id===id);\n  const words=String(c.description||\\\"\\\").trim().split(/\\\\s+/).filter(Boolean).length;\n  console.log(id, c.name, words, c.description);\n}\nconsole.log(\\\"missing\\\", d.companies.filter(c=>\"'!String(c.description||\"\").trim()).length);\nconsole.log(\"unpop\", d.companies.filter(c=>!(c.recruiters||[]).length).length);\nconsole.log(\"recruiters\", d.companies.reduce((s,c)=>s+(c.recruiters||[]).length,0));\n'\"'\"","aggregated_output":"C0895 Ball Aerospace 23 Ball Aerospace, now part of BAE Systems, develops spacecraft, mission payloads, optical systems, antennas, and sensors for defense, civil space, and commercial missions.\nC0896 Sierra Nevada Corporation 18 Sierra Nevada Corporation integrates aircraft, mission systems, sensors, and secure technologies for U.S. defense, security, and aerospace customers.\nC0897 Sierra Space 21 Sierra Space builds Dream Chaser spaceplanes, satellite platforms, propulsion, habitats, and defense space systems for commercial, civil, and national security missions.\nC0898 Firefly Aerospace 23 Firefly Aerospace develops launch vehicles, lunar landers, spacecraft, and mission services for commercial, NASA, and defense customers from Earth orbit to the Moon.\nC0899 Astra Space 20 Astra Space provides responsive launch services and satellite propulsion systems, including electric spacecraft engines, for small-satellite and government space missions.\nC0900 Astranis 20 Astranis designs small geostationary and high-orbit communications satellites with digital payloads for commercial broadband, government science, PNT, and defense missions.\nC0901 Vast 22 Vast develops commercial space stations, Haven orbital habitats, and high-power satellite buses to support microgravity research, manufacturing, communications, and national security missions.\nC0902 Varda Space 22 Varda Space builds in-orbit manufacturing spacecraft and reentry capsules that return materials from low Earth orbit for pharmaceutical, industrial, and defense applications.\nC0903 Momentus 20 Momentus develops orbital service vehicles, satellite buses, hosted payload support, and in-space transportation infrastructure for commercial and government spacecraft missions.\nC0904 Spire Global 20 Spire Global operates satellite constellations and data platforms for weather forecasting, aviation tracking, maritime intelligence, climate risk, and space services.\nC0905 BlackSky 20 BlackSky operates a high-revisit satellite imaging constellation and Spectra analytics platform for real-time geospatial intelligence, monitoring, and national security workflows.\nC0906 Capella Space 21 Capella Space designs, builds, and operates synthetic aperture radar satellites that deliver all-weather Earth imagery for government, commercial, and scientific missions.\nC0907 Astrobotic 21 Astrobotic develops lunar landers, rovers, payload delivery services, navigation systems, and surface power technologies for NASA, commercial, and government Moon missions.\nC0908 Intuitive Machines 21 Intuitive Machines builds lunar landers, payload delivery services, cislunar communications, and exploration infrastructure supporting NASA CLPS, Artemis, and commercial Moon operations.\nmissing 26\nunpop 0\nrecruiters 181\n","exit_code":0,"status":"completed"}}
