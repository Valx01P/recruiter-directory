ilson, M.Ed.\",\n      \"title\": \"University Recruiting & Intern Programs\",\n      \"linkedin_url\": \"https://www.linkedin.com/in/nscottwilson\",\n      \"email\": \"\",\n      \"location\": \"United States\",\n      \"focus_area\": \"University Recruiting & Intern Programs\",\n      \"connected\": false,\n      \"messaged\": false,\n      \"responded\": false,\n      \"date_contacted\": \"\",\n      \"notes\": \"Previously Emerging Talent at Meta\"\n    },\n    {\n      \"name\": \"Amy Traylor\",\n      \"title\": \"Director, Early Careers\",\n      \"linkedin_url\": \"https://www.linkedin.com/in/amy-traylor-92b0b884\",\n      \"email\": \"\",\n      \"location\": \"Brownsville, TX, United States\",\n      \"focus_area\": \"Early Careers leadership (university + intern programs)\",\n      \"connected\": false,\n      \"messaged\": false,\n      \"responded\": false,\n      \"date_contacted\": \"\",\n      \"notes\": \"Director-level ownership of Early Careers at SpaceX\"\n    }\n  ]\n}\n--- C0113 Blue Origin\n{\n  \"id\": \"C0113\",\n  \"name\": \"Blue Origin\",\n  \"priority\": 2,\n  \"hq\": \"Kent, WA\",\n  \"category\": \"Aerospace\",\n  \"sector\": \"defense\",\n  \"description\": \"\",\n  \"size\": \"11k+\",\n  \"intern\": true,\n  \"companyUrl\": \"https://www.linkedin.com/company/blue-origin/\",\n  \"verified\": true,\n  \"search\": \"https://www.linkedin.com/search/results/people/?keywords=Blue%20Origin%20recruiter\",\n  \"careers\": \"\",\n  \"recruiters\": [\n    {\n      \"name\": \"Emily Smith\",\n      \"title\": \"Early Career & Emerging Talent Strategist\",\n      \"linkedin_url\": \"https://www.linkedin.com/in/emily-smith-northwest\",\n      \"email\": \"\",\n      \"location\": \"Seattle, Washington, United States\",\n      \"focus_area\": \"Internship Program / Early Career Programs (aerospace/engineering talent)\",\n      \"connected\": false,\n      \"messaged\": false,\n      \"responded\": false,\n      \"date_contacted\": \"\",\n      \"n