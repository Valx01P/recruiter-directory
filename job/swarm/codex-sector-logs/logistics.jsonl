throw new Error(`Missing company ${id}`);\n  company.description = update.description;\n  company.recruiters = company.recruiters || [];\n  const before = company.recruiters.length;\n  const seen = new Set(company.recruiters.map((r) => `${(r.linkedin_url || '\"'').toLowerCase()}|\"'${(r.name || '\"'').toLowerCase()}\"'`));\n  for (const recruiter of update.recruiters) {\n    const full = { ...schemaDefaults, ...recruiter };\n    const key = `${(full.linkedin_url || '\"'').toLowerCase()}|\"'${(full.name || '\"'').toLowerCase()}\"'`;\n    if (!seen.has(key)) {\n      company.recruiters.push(full);\n      seen.add(key);\n    }\n  }\n  if (company.recruiters.length > 10) throw new Error(`${id} exceeds 10 recruiters`);\n  if (company.description !== update.description || company.recruiters.length !== before) touched += 1;\n  added += company.recruiters.length - before;\n}\n\nfs.writeFileSync(file, JSON.stringify(data, null, 2) + '\"'\\\\n');\nconsole.log(JSON.stringify({ touched: Object.keys(updates).length, added }, null, 2));\nNODE\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
