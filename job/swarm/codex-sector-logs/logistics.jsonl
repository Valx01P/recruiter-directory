{"type":"item.started","item":{"id":"item_22","type":"command_execution","command":"/bin/zsh -lc \"node <<'NODE'\nconst fs = require('fs');\nconst path = 'job/sectors/recruiter-logistics.json';\nconst d = JSON.parse(fs.readFileSync(path, 'utf8'));\n\nconst descriptions = {\n  C1079: 'Convoy built a digital freight marketplace connecting shippers with truck carriers before shutting down in 2023; its platform moved through Flexport to DAT Freight & Analytics.',\n  C1083: 'CarMax operates a nationwide used-car retail and ecommerce platform, combining vehicle inventory, financing, appraisal, service, and logistics across physical stores and digital channels.',\n  C1084: 'Vroom formerly operated an online used-car marketplace and now focuses on United Auto Credit auto finance and CarStory automotive retail analytics after winding down ecommerce operations.',\n  C1086: 'Cars Commerce operates Cars.com, Dealer Inspire, AccuTrade, marketplace media, and AI-backed retail tools that help dealers and consumers buy, sell, and market vehicles.',\n  C1088: 'Shift Technologies operated an online used-car buying and selling platform before filing Chapter 11 in 2023 to wind down its business and liquidate assets.',\n  C1090: 'Cazoo was a UK online used-car marketplace that shifted to a listings model before entering administration in 2024 and selling the brand to MOTORS.',\n  C0062: 'DoorDash operates a global local-commerce marketplace and logistics platform connecting consumers with restaurants, grocers, retailers, merchants, Dashers, and fulfillment software.',\n  C0060: 'Lyft runs a North American mobility marketplace for rideshare, bikes, scooters, car rentals, and transit connections through consumer apps and transportation operations software.',\n  C0063: 'Instacart provides grocery delivery, pickup, retail media, and commerce technology connecting consumers, shoppers, retailers, and CPG brands across North American grocery.',\n  C0074: 'Expedia Group operates a global travel platform spanning Expedia, Hotels.com, Vrbo, B2B partner tools, lodging supply, payments, and travel data products.',\n  C0167: 'Royal Caribbean Group operates cruise brands, private destinations, loyalty programs, and guest technology across a global fleet serving leisure travelers worldwide.',\n  C0075: 'Booking Holdings runs online travel and restaurant platforms including Booking.com, Priceline, Agoda, KAYAK, and OpenTable, connecting travelers with suppliers worldwide.',\n  C0165: 'Ryder provides third-party logistics, dedicated transportation, fleet management, leasing, and supply chain technology for retailers, manufacturers, and enterprise transportation networks.',\n  C0166: 'Carnival Corporation operates a global portfolio of cruise lines, ships, destination operations, and onboard technology serving vacation travelers across major leisure brands.'\n};\n\nconst recruiters = {\n  C1083: [\n    {\n      name: 'Kristy Jordan',\n      title: 'Assistant Vice President, Talent Acquisition',\n      linkedin_url: 'https://www.linkedin.com/in/kristy-jordan',\n      email: '',\n      location: 'Richmond, VA / Chesterfield, VA, United States',\n      focus_area: 'Talent Acquisition leadership / Campus and early-career programs',\n      connected: false,\n      messaged: false,\n      responded: false,\n      date_contacted: '',\n      notes: 'Public LinkedIn and The Org profiles show CarMax talent acquisition leadership; LinkedIn activity references Campus Forward recognition for early-career hiring.'\n    },\n    {\n      name: 'Ashutosh Sharma',\n      title: 'Talent Acquisition Leader | IT, Finance & Operations Hiring',\n      linkedin_url: 'https://www.linkedin.com/in/ashutosh-sharma-8b904777',\n      email: '',\n      location: 'Greater Chicago Area, United States',\n      focus_area: 'IT, software, finance, and operations recruiting',\n      connected: false,\n      messaged: false,\n      responded: false,\n      date_contacted: '',\n      notes: 'Public LinkedIn profile lists CarMax and Talent Acquisition Leader with IT, Finance & Operations Hiring; relevant for software and technical operations outreach.'\n    },\n    {\n      name: 'Ginger Turner, CIR CDR',\n      title: 'Senior Recruiter',\n      linkedin_url: 'https://www.linkedin.com/in/ginger-turner-cir-cdr-b599398',\n      email: '',\n      location: 'Richmond, VA, United States',\n      focus_area: 'Full-cycle recruiting / logistics, fleet, and business roles',\n      connected: false,\n      messaged: false,\n      responded: false,\n      date_contacted: '',\n      notes: 'Public LinkedIn and The Org profiles show Senior Recruiter at CarMax; LinkedIn activity references vehicle delivery, fleet, and retail hiring.'\n    }\n  ],\n  C1084: [\n    {\n      name: 'Albert Pugrad',\n      title: 'Recruiting Manager / Talent Acquisition Professional, United Auto Credit',\n      linkedin_url: 'https://www.linkedin.com/in/albert-pugrad-ab613b121',\n      email: 'albert.pugrad@unitedautocredit.net',\n      location: 'Dallas, TX, United States',\n      focus_area: 'Recruiting for Vroom remaining UACC auto finance business',\n      connected: false,\n      messaged: false,\n      responded: false,\n      date_contacted: '',\n      notes: 'United Auto Credit public LinkedIn updates identify him as Recruiting Manager with active hiring posts; UACC job posts state it is a wholly owned indirect subsidiary of Vroom.'\n    },\n    {\n      name: 'Angel Rosales',\n      title: 'Recruiting / Talent Acquisition, United Auto Credit',\n      linkedin_url: 'https://www.linkedin.com/in/angel-rosales-45882a1',\n      email: '',\n      location: 'Dallas-Fort Worth Metroplex, United States',\n      focus_area: 'IT, software engineering, cybersecurity, R&D, and operations recruiting',\n      connected: false,\n      messaged: false,\n      responded: false,\n      date_contacted: '',\n      notes: 'Public LinkedIn profile lists United Auto Credit and recruiting experience across IT, software engineering, cybersecurity, R&D, project, and operations roles.'\n    }\n  ],\n  C1086: [\n    {\n      name: 'Tanya Williams',\n      title: 'Head of Talent Acquisition / Manager, Talent Acquisition (Technology)',\n      linkedin_url: 'https://www.linkedin.com/in/tanyasstewart',\n      email: '',\n      location: 'Greater St. Louis, United States',\n      focus_area: 'Technology talent acquisition / software engineering, infrastructure, and security',\n      connected: false,\n      messaged: false,\n      responded: false,\n      date_contacted: '',\n      notes: 'Public LinkedIn profile shows Cars Commerce and a Manager, Talent Acquisition (Technology) role; third-party profile also lists Head of Talent Acquisition.'\n    },\n    {\n      name: 'Alisa Scroggins',\n      title: 'Sr. Sales Recruiter',\n      linkedin_url: 'https://www.linkedin.com/in/alisa-scroggins',\n      email: '',\n      location: 'Dallas-Fort Worth Metroplex, United States',\n      focus_area: 'Sales, data analytics, and GTM recruiting',\n      connected: false,\n      messaged: false,\n      responded: false,\n      date_contacted: '',\n      notes: 'Public LinkedIn and SignalHire results show current Cars Commerce recruiting work; background includes TA leadership across apps, infrastructure, security, and data analytics.'\n    },\n    {\n      name: 'Lacey Kuta',\n      title: 'Associate Recruiter / Talent Acquisition',\n      linkedin_url: 'https://www.linkedin.com/in/lacey-kuta-66194122a',\n      email: '',\n      location: 'Chicago, IL, United States',\n      focus_area: 'Talent acquisition / early-career recruiting support',\n      connected: false,\n      messaged: false,\n      responded: false,\n      date_contacted: '',\n      notes: 'Public LinkedIn result shows Cars Commerce talent acquisition experience; third-party company profile lists Associate Recruiter at Cars Commerce.'\n    }\n  ]\n};\n\nfunction findCompany(id) {\n  const company = d.companies.find(c => c.id === id);\n  if (\"'!company) throw new Error(`Missing company ${id}`);\n  return company;\n}\n\nfunction normalize(v) {\n  return String(v || '\"'').trim().toLowerCase();\n}\n\nlet descriptionsAdded = 0;\nlet recruiterEntriesAdded = 0;\nconst touched = new Set();\n\nfor (const [id, description] of Object.entries(descriptions)) {\n  const company = findCompany(id);\n  if (\"'!String(company.description || '\"'').trim()) {\n    company.description = description;\n    descriptionsAdded++;\n  }\n  touched.add(id);\n}\n\nfor (const [id, people] of Object.entries(recruiters)) {\n  const company = findCompany(id);\n  company.recruiters = company.recruiters || [];\n  for (const person of people) {\n    const duplicate = company.recruiters.some(existing =>\n      normalize(existing.linkedin_url) === normalize(person.linkedin_url) || normalize(existing.name) === normalize(person.name)\n    );\n    if (\"'!duplicate && company.recruiters.length < 10) {\n      company.recruiters.push(person);\n      recruiterEntriesAdded++;\n    }\n  }\n  touched.add(id);\n}\n\nfs.writeFileSync(path, JSON.stringify(d, null, 2) + '\"'\\\\n');\nconsole.log(JSON.stringify({companiesTouched: touched.size, descriptionsAdded, recruiterEntriesAdded}, null, 2));\nNODE\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
