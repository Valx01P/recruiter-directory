{"type":"item.started","item":{"id":"item_25","type":"command_execution","command":"/bin/zsh -lc \"node <<'NODE'\nconst fs = require('fs');\nconst path = 'job/sectors/recruiter-logistics.json';\nconst data = JSON.parse(fs.readFileSync(path, 'utf8'));\n\nconst defaults = {\n  email: '',\n  connected: false,\n  messaged: false,\n  responded: false,\n  date_contacted: ''\n};\n\nconst additions = {\n  C0060: [\n    {\n      name: 'Tunia Fallah',\n      title: 'Recruiter / Talent Acquisition Professional',\n      linkedin_url: 'https://www.linkedin.com/in/tunia-fallah-a83581247',\n      location: 'Bowie, MD / San Diego, CA, United States',\n      focus_area: 'Talent acquisition / Recruiting',\n      notes: 'Public LinkedIn profile lists Lyft experience in San Diego and describes 5+ years of talent acquisition and recruiting experience.'\n    },\n    {\n      name: 'Nabila Shaikh',\n      title: 'Technical Sourcer, Specialized Tech',\n      linkedin_url: 'https://ca.linkedin.com/in/nabilashaikh',\n      location: 'Canada / North America',\n      focus_area: 'Technical sourcing / Specialized technology roles',\n      notes: 'Public LinkedIn profile activity says she joined Lyft as a Technical Sourcer on the Specialized Tech team; profile lists Lyft experience.'\n    }\n  ],\n  C0166: [\n    {\n      name: 'Shellye Roberts',\n      title: 'Senior Talent Acquisition Partner',\n      linkedin_url: 'https://www.linkedin.com/in/shellyeroberts',\n      location: 'Miami-Fort Lauderdale Area, United States',\n      focus_area: 'Talent acquisition / Corporate and technical-adjacent recruiting',\n      notes: 'Public LinkedIn profile describes her as a Senior Talent Acquisition Partner at Carnival Cruise Line and shows Miami-Fort Lauderdale location.'\n    }\n  ],\n  C0173: [\n    {\n      name: 'Gabriela Ramirez',\n      title: 'Recruiter',\n      linkedin_url: 'https://cr.linkedin.com/in/gabriela-ramirez-m',\n      location: 'San Jose, Costa Rica',\n      focus_area: 'Recruiting / Software and corporate roles',\n      notes: 'Public LinkedIn profile and a World Kinect software developer job page identify Gabriela as Recruiter @ World Kinect, hiring top talent, with recruiter tenure since Jan 2024.'\n    },\n    {\n      name: 'Sam Suleman',\n      title: 'Global Tech Recruiter',\n      linkedin_url: 'https://uk.linkedin.com/in/sam-suleman',\n      location: 'Greater London, England, United Kingdom',\n      focus_area: 'Global technology recruiting',\n      notes: 'Public LinkedIn profile describes Sam as a global tech recruiter with World Kinect experience and LinkedIn Recruiter talent acquisition certification.'\n    }\n  ],\n  C0181: [\n    {\n      name: 'Priscilla Messir, PHR',\n      title: 'Chief People Officer',\n      linkedin_url: '',\n      location: 'Orlando, FL, United States',\n      focus_area: 'People leadership / Talent acquisition strategy',\n      notes: 'The Org lists Priscilla Messir as Chief People Officer at Brightline Trains, with HR leadership experience spanning talent acquisition and employee engagement.'\n    },\n    {\n      name: 'Sandy Pinos-Chin',\n      title: 'Senior Director, People & Culture',\n      linkedin_url: '',\n      location: 'United States',\n      focus_area: 'People and culture / Talent programs',\n      notes: 'The Org Brightline Trains profile lists Sandy Pinos-Chin as Senior Director, People & Culture, tied to Brightline people leadership.'\n    }\n  ],\n  C0192: [\n    {\n      name: 'Paul Tesar',\n      title: 'Chief Technology Officer',\n      linkedin_url: '',\n      location: 'United States',\n      focus_area: 'Engineering leadership / Technical hiring',\n      notes: 'CB Insights lists Paul Tesar as Boatsetter current Chief Technology Officer; appropriate technical hiring leader for a small marketplace engineering team.'\n    },\n    {\n      name: 'Michael Switzer',\n      title: 'VP Engineering',\n      linkedin_url: '',\n      location: 'United States',\n      focus_area: 'Engineering leadership / Technical hiring',\n      notes: 'Growjo lists Michael Switzer as Boatsetter VP Engineering, making him a relevant technical hiring manager for engineering outreach.'\n    }\n  ],\n  C0195: [\n    {\n      name: 'Jennifer Brennan',\n      title: 'Talent Acquisition Specialist',\n      linkedin_url: 'https://www.linkedin.com/in/jennifer-brennan-5ab57892',\n      location: 'Davenport, FL, United States',\n      focus_area: 'Talent acquisition / Candidate screening and offer process',\n      notes: 'Public LinkedIn profile lists Marriott Vacations Worldwide; recommendations describe her as a Talent Acquisition Specialist supporting requisitions, candidate management, offers, and background checks.'\n    },\n    {\n      name: 'Vanessa Carty',\n      title: 'Manager of Talent Acquisition',\n      linkedin_url: 'https://www.linkedin.com/in/vanessa-carty-7b7568205',\n      location: 'San Diego, CA, United States',\n      focus_area: 'Talent acquisition / Sales and marketing hiring',\n      notes: 'Public LinkedIn profile states Manager of Talent Acquisition at Marriott Vacations Worldwide with West Coast hiring-event activity.'\n    }\n  ],\n  C1051: [\n    {\n      name: \\\"E'Tiyah Needam\\\",\n      title: 'Talent Acquisition Recruiter',\n      linkedin_url: 'https://www.linkedin.com/in/etiyahneedam',\n      location: 'Mechanicsburg, PA, United States',\n      focus_area: 'Talent acquisition recruiting / Operations and logistics roles',\n      notes: 'Public LinkedIn profile says she started as a Talent Acquisition Recruiter at UPS and lists UPS experience in Middletown, PA.'\n    },\n    {\n      name: 'Vani Gundlapally',\n      title: 'Talent Acquisition / Recruiting Lead',\n      linkedin_url: 'https://www.linkedin.com/in/gvani',\n      location: 'Mahwah, NJ, United States',\n      focus_area: 'Talent acquisition / IT and operations recruiting',\n      notes: 'Public LinkedIn profile says Vani oversees talent acquisition activities and recruiting for open positions across UPS; recommendations reference Network and IT talent acquisition support.'\n    }\n  ],\n  C1055: [\n    {\n      name: 'Vinicius V.',\n      title: 'Talent Development Leader',\n      linkedin_url: '',\n      location: 'United States',\n      focus_area: 'Talent development / Recruiting and culture systems',\n      notes: 'Public Knight-Swift Supply Chain recruiter job page lists Vinicius V. as the job poster and Talent Development Leader, tied to full-cycle recruiting for logistics and distribution roles.'\n    }\n  ]\n};\n\nlet added = 0;\nfor (const [id, contacts] of Object.entries(additions)) {\n  const company = data.companies.find(c => c.id === id);\n  if (\"'!company) throw new Error(`Missing company ${id}`);\n  company.recruiters ||= [];\n  for (const contact of contacts) {\n    const normName = contact.name.toLowerCase();\n    const normUrl = (contact.linkedin_url || '\"'').toLowerCase().replace(/\\\\/\"'$/, '\"'');\n    const exists = company.recruiters.some(r =>\n      String(r.name || '').toLowerCase() === normName ||\n      (normUrl && String(r.linkedin_url || '').toLowerCase().replace(/\\\\/\"'$/, '\"'') === normUrl)\n    );\n    if (exists) continue;\n    if (company.recruiters.length >= 10) throw new Error(\"'`${company.name} already has 10 contacts`);\n    company.recruiters.push({\n      name: contact.name,\n      title: contact.title,\n      linkedin_url: contact.linkedin_url,\n      email: defaults.email,\n      location: contact.location,\n      focus_area: contact.focus_area,\n      connected: defaults.connected,\n      messaged: defaults.messaged,\n      responded: defaults.responded,\n      date_contacted: defaults.date_contacted,\n      notes: contact.notes\n    });\n    added++;\n  }\n}\n\nfs.writeFileSync(path, JSON.stringify(data, null, 2) + '\"'\\\\n');\nconsole.log(\"'`Added ${added} recruiters/contact entries.`);\nNODE'","aggregated_output":"","exit_code":null,"status":"in_progress"}}
