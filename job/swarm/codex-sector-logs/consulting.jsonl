blic LinkedIn profile lists Globant and describes seasoned talent acquisition work; profile activity references Globant recruiting and US developer hiring.'\n      }\n    ]\n  },\n  C1242: {\n    description: 'Thoughtworks is a technology consultancy that builds custom software, data platforms, AI products, and digital transformation capabilities for enterprise and public-sector clients.',\n    recruiters: [\n      {\n        name: 'Carla Catelan',\n        title: 'Americas Head of Talent Acquisition',\n        linkedin_url: 'https://www.linkedin.com/in/carla-catelan',\n        email: '',\n        location: 'Winter Garden, FL',\n        focus_area: 'Americas Talent Acquisition / Technology Consulting Hiring',\n        connected: false,\n        messaged: false,\n        responded: false,\n        date_contacted: '',\n        notes: 'Public LinkedIn profile identifies her as Americas Head of Talent Acquisition at Thoughtworks, leading a 50+ person recruiting team.'\n      }\n    ]\n  }\n};\n\nlet touched = 0;\nlet added = 0;\nfor (const company of data.companies || []) {\n  const update = updates[company.id];\n  if (\"'!update) continue;\n  touched++;\n  company.description = update.description;\n  if (!Array.isArray(company.recruiters)) company.recruiters = [];\n  const seen = new Set(company.recruiters.map(r => `${String(r.name || '\"'').toLowerCase()}|\"'${String(r.linkedin_url || '\"'').toLowerCase()}\"'`));\n  for (const recruiter of update.recruiters) {\n    const key = `${recruiter.name.toLowerCase()}|${recruiter.linkedin_url.toLowerCase()}`;\n    if (!seen.has(key)) {\n      company.recruiters.push(recruiter);\n      seen.add(key);\n      added++;\n    }\n  }\n}\n\nfs.writeFileSync(path, JSON.stringify(data, null, 2) + '\"'\\\\n');\nconsole.log(\"'`updated ${touched} companies, added ${added} recruiters`);\nNODE'","aggregated_output":"","exit_code":null,"status":"in_progress"}}
