# Copy to .env for local dev. On Render, set these in the dashboard (Environment).
# PORT is injected by Render automatically — only set it locally.
PORT=8787

# Embedding model (must match the vector(N) dimension in the recruiter-directory schema).
# Supabase/gte-small (384d) = light, fits small hosts; Xenova/gte-base (768d) = stronger, heavier.
EMBEDDING_MODEL=Supabase/gte-small
EMBEDDING_DIM=384

# Supabase — only needed for the /search endpoint (server holds the secret key)
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxx

# CORS allowlist of frontend origins (comma-separated). With cookie auth, credentials
# are reflected to these exact origins. "*" reflects any origin (local dev only).
ALLOWED_ORIGINS=https://recruiter-directory.vercel.app

# Auth — JWT signing secret (any long random string; `openssl rand -hex 32`). Required for sign-in.
AUTH_JWT_SECRET=change-me-to-a-long-random-secret
# Google OAuth client ID (for /auth/google ID-token verification)
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# Session cookie flags. Production (cross-site vercel↔render): leave defaults (secure + sameSite=none).
# Local dev over http://localhost: set COOKIE_SECURE=false and COOKIE_SAMESITE=lax.
# COOKIE_SECURE=true
# COOKIE_SAMESITE=none
# COOKIE_DOMAIN=.yourdomain.com   # set only if frontend+api share a parent domain (first-party cookies)
